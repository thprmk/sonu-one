\n    \"(min-width: 1500px)\":{\n\n      slides:{\n        perView:2.8,\n        spacing:20,\n      }\n\n    }\n\n  },\n\n  detailsChanged(slider){\n\n    const progress =\n      slider.track.details.progress;\n\n    if(progress >= 0.99){\n      slider.container.classList.add(\"end-slide\");\n    }else{\n      slider.container.classList.remove(\"end-slide\");\n    }\n\n  },\n\n  created(slider){\n    updateActiveSlide(slider);\n  },\n\n  slideChanged(slider){\n    updateActiveSlide(slider);\n  }\n\n});\n\nfunction updateActiveSlide(slider){\n\n  slider.slides.forEach((slide)=>{\n    slide.classList.remove(\"active-slide\");\n  });\n\n  const current =\n    slider.slides[slider.track.details.rel];\n\n  if(current){\n    current.classList.add(\"active-slide\");\n  }\n\n}\n\ndocument.getElementById(\"prevBtn\")\n.addEventListener(\"click\",()=>{\n  slider.prev();\n});\n\ndocument.getElementById(\"nextBtn\")\n.addEventListener(\"click\",()=>{\n  slider.next();\n});\n\n</script>\n\n</div>",
