    "custom_liquid_WNmYyJ": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<link\n  rel=\"stylesheet\"\n  href=\"https://cdn.jsdelivr.net/npm/keen-slider@6.8.6/keen-slider.min.css\"\n/>\n\n<style>\n\n/* =========================\nGLOBAL\n========================= */\n\n\n\n.body{\n\n  overflow-x:hidden;\n}\n\n/* =========================\nMAIN LAYOUT\n========================= */\n\n.sleep-layout{\n  display:grid;\n  grid-template-columns:450px minmax(0,1fr);\n  gap:48px;\n  max-width:1800px;\n  margin:auto;\n  padding:70px 40px;\n  align-items:start;\n}\n\n/* =========================\nLEFT CONTENT\n========================= */\n\n.left-content{\n  position:sticky;\n  top:40px;\n}\n\n.publication-title{\n  font-size:68px;\n  line-height:.98;\n  font-weight:400;\n  letter-spacing:-3px;\n  color:#3D1B03;\n  margin-bottom:28px;\n}\n\n.publication-text{\n  font-size:18px;\n  line-height:1.7;\n  color:#4a4a4a;\n  margin-bottom:18px;\n  max-width:380px;\n}\n\n.publication-text.small{\n  margin-bottom:40px;\ndisplay:none !important;\n\n}\n\n.publication-btn{\ndisplay:none !important;\n  width:100%;\n  max-width:360px;\n  height:72px;\n  border-radius:100px;\n  background:#001a72;\n  color:#fff;\n  text-decoration:none;\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  font-size:14px;\n  font-weight:700;\n  letter-spacing:.5px;\n  transition:.3s ease;\n}\n\n.publication-btn:hover{\n  transform:translateY(-2px);\n}\n\n/* =========================\nRIGHT SIDE\n========================= */\n\n.comparison-area{\n  min-width:0;\n}\n\n.comparison-layout{\n  display:grid;\n  grid-template-columns:180px 180px minmax(0,1fr);\n  gap:16px;\n  align-items:start;\n}\n\n/* =========================\nLABELS\n========================= */\n\n.feature-labels{\n  display:grid;\n  grid-template-rows:120px repeat(5,110px);\n}\n\n.feature-label{\n  display:flex;\n  align-items:center;\n}\n\n.feature-label h3{\n  font-size:20px;\n  line-height:1.2;\n  font-weight:600;\n  letter-spacing:-0.5px;\n  color:#3D1B03;\n}\n\n/* =========================\nFEATURED CARD\n========================= */\n\n.featured-card{\n  background:#CEC4BC;\n  border-radius:34px;\n  padding:24px 16px;\n  display:grid;\n  grid-template-rows:120px repeat(5,110px);\n}\n\n.featured-header{\n  display:flex;\n  align-items:flex-start;\n  justify-content:center;\n  text-align:center;\n}\n\n.featured-header h2{\n  color:#3D1B03;\n  font-size:18px;\n  line-height:1.15;\n  font-weight:800;\n}\n\n.featured-row{\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  text-align:center;\n}\n\n.featured-text{\n  color:#3D1B03;\n  font-size:16px;\n  line-height:1.45;\n  font-weight:400;\n}\n\n.featured-icon{\n  width:42px;\n  height:42px;\n  border-radius:50%;\n  border:1px solid #3D1B03;\n  color:#3D1B03;\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  font-size:20px;\n}\n\n/* =========================\nSLIDER\n========================= */\n\n.slider-area{\n  min-width:0;\n}\n\n.slider-wrapper{\n  overflow:hidden;\n}\n\n.keen-slider{\n  overflow:visible !important;\n  transition:.3s ease;\n}\n\n@media(min-width:992px){\n\n  .keen-slider.end-slide{\n    transform:translateX(-40px);\n  }\n\n}\n\n.keen-slider__slide{\n  transform:scale(.92);\n  opacity:.45;\n}\n\n.keen-slider__slide.active-slide{\n  transform:scale(1);\n  opacity:1;\n}\n\n/* =========================\nCOMPARE CARDS\n========================= */\n\n.compare-card{\n  border-radius:34px;\n  padding:24px 16px;\n  display:grid;\n  grid-template-rows:120px repeat(5,110px);\n  border:1px solid #4a474138;\n}\n\n.compare-header{\n  display:flex;\n  align-items:flex-start;\n  justify-content:center;\n  text-align:center;\n}\n\n.compare-header h2{\n  font-size:18px;\n  line-height:1.15;\n  font-weight:800;\n  color:#3D1B03;\n}\n\n.compare-row{\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  text-align:center;\n}\n\n.compare-text{\n  font-size:16px;\n  line-height:1.45;\n  color:#666;\n  font-weight:400;\n}\n\n.compare-icon{\n  width:42px;\n  height:42px;\n  border-radius:50%;\n  border:1px solid #999;\n  color:#666;\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  font-size:20px;\n}\n\n/* =========================\nARROWS\n========================= */\n\n.slider-nav{\n  display:flex;\n  justify-content:flex-end;\n  gap:5px;\n  margin-top:28px;\n}\n\n.slider-btn-table, .slider-btn-table svg{\n  width:54px;\n  height:54px;\nborder:none;\n  border-radius:50%;\n  background:transparent;\n  cursor:pointer;\n  font-size:22px;\n  transition:.3s ease;\n}\n\n\n/* =========================\nRESPONSIVE\n========================= */\n\n@media(max-width:1500px){\n\n  .publication-title{\n    font-size:52px;\n    letter-spacing:-1px;\n\n  }\n\n}\n\n@media(max-width:1200px){\n\n  .sleep-layout{\n    grid-template-columns:340px minmax(0,1fr);\n  }\n\n  .publication-title{\n    font-size:42px;\n    letter-spacing:-1px;\n\n  }\n\n}\n\n@media(max-width:991px){\n\n  .sleep-layout{\n    grid-template-columns:1fr;\n    gap:40px;\n    padding:40px 0px 40px 10px;\n  }\n\n.comparison-area{\n  order:1;\n}\n\n.left-content{\n  order:2;\n}\n  .left-content{\n    position:relative;\n    top:auto;\n  }\n\n  .publication-title{\n    font-size:34px;\n    line-height:1.08;\n    letter-spacing:-1px;\n  }\n\n  .publication-text{\n    font-size:14px;\n    max-width:100%;\n  }\n\n  .publication-btn{\n    max-width:100%;\n    height:58px;\n    font-size:13px;\n  }\n\n  .comparison-layout{\n    grid-template-columns:110px 120px minmax(0,1fr);\n    gap:10px;\n  }\n\n  .feature-labels{\n    grid-template-rows:55px repeat(5,88px);\n  }\n\n  .featured-card{\n    grid-template-rows:38px repeat(5,88px);\n    padding:16px 10px;\n    border-radius:18px;\n  }\n\n  .compare-card{\n    grid-template-rows:38px repeat(5,88px);\n    padding:16px 10px;\n    border-radius:18px;\n  }\n\n  .feature-label h3{\n           font-size: 14px;\n        line-height: 1.3;\n        letter-spacing: .3px;\n        text-wrap: wrap;\n  }\n\n  .featured-header h2,\n  .compare-header h2{\n    font-size:13px;\n  }\n\n  .featured-text,\n  .compare-text{\n    font-size:11px;\n  }\n\n  .featured-icon,\n  .compare-icon{\n    width:26px;\n    height:26px;\n    font-size:14px;\n  }\n\n  .slider-nav{\n    justify-content:center;\n    margin-top:18px;\n  }\n\n  .slider-btn-table, .slider-btn-table svg{\n    width:50px !important;\n    height:50px !important;\n    font-size:18px;\n  }\n\n}\n\n@media (max-width:500px){\n.comparison-area{\nmargin-bottom:80px;\n}\n.slider-nav{\nposition:absolute;\nright:10px;\n}\n\n}\n\n@media(max-width:390px){\n\n  .comparison-layout{\n    grid-template-columns:110px 105px minmax(0,1fr);\n    gap:12px;\n  }\n\n}\n\n</style>\n\n\n<div class=\"body\">\n\n<section class=\"sleep-layout\">\n\n  <!-- LEFT CONTENT -->\n\n  <div class=\"left-content\">\n\n    <h2 class=\"publication-title\">\n     Backed by Science.\nTrusted by Doctors.\n    </h2>\n\n    <p class=\"publication-text\">\n    SONU uses acoustic resonance therapy — a clinically studied method that reduces inflammation, improves mucus clearance, and opens nasal airways.\n    </p>\n<p class=\"publication-text small\">\n      Read our published study in the Journal of Sleep Medicine.\n    </p>\n\n\n\n    <a href=\"#\" class=\"publication-btn\">\n      READ PUBLICATION\n    </a>\n\n  </div>\n\n  <!-- RIGHT CONTENT -->\n\n  <div class=\"comparison-area\">\n\n    <div class=\"comparison-layout\">\n\n      <!-- LABELS -->\n\n      <div class=\"feature-labels\">\n\n        <div></div>\n\n        <div class=\"feature-label\">\n          <h3>Clinically Proven</h3>\n        </div>\n\n        <div class=\"feature-label\">\n          <h3>Side Effects</h3>\n        </div>\n\n        <div class=\"feature-label\">\n          <h3>Personalization</h3>\n        </div>\n\n        <div class=\"feature-label\">\n          <h3>Monitoring</h3>\n        </div>\n\n        <div class=\"feature-label\">\n          <h3>Time to Relief</h3>\n        </div>\n\n      </div>\n\n      <!-- FEATURED CARD -->\n\n      <div class=\"featured-card\">\n\n        <div class=\"featured-header\">\n          <h2>SONU Band</h2>\n        </div>\n\n        <div class=\"featured-row\">\n          <div class=\"featured-icon\">✓</div>\n        </div>\n\n        <div class=\"featured-row\">\n          <div class=\"featured-icon\">x</div>\n        </div>\n\n        <div class=\"featured-row\">\n          <div class=\"featured-icon\">✓</div>\n        </div>\n\n        <div class=\"featured-row\">\n          <div class=\"featured-icon\">✓</div>\n        </div>\n\n        <div class=\"featured-row\">\n          <div class=\"featured-text\">\n            Minutes\n          </div>\n        </div>\n\n      </div>\n\n      <!-- SLIDER -->\n\n      <div class=\"slider-area\">\n\n        <div class=\"slider-wrapper\">\n\n          <div id=\"comparison-slider\" class=\"keen-slider\">\n\n            <!-- CARD 1 -->\n\n            <div class=\"keen-slider__slide compare-card\">\n\n              <div class=\"compare-header\">\n                <h2>Intranasal\nSteroids</h2>\n              </div>\n\n              <div class=\"compare-row\">\n               <div class=\"compare-icon\">✓</div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-icon\">✓</div>\n              </div>\n\n              <div class=\"compare-row\">\n              <div class=\"compare-icon\">✕</div>\n              </div>\n\n              <div class=\"compare-row\">\n               <div class=\"compare-icon\">✕</div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-text\">\n                  Days\n                </div>\n              </div>\n\n            </div>\n\n            <!-- CARD 2 -->\n\n            <div class=\"keen-slider__slide compare-card\">\n\n              <div class=\"compare-header\">\n                <h2>Melatonin & Other Supplements</h2>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-icon\">✕</div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-icon\">✕</div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-text\">\n                  Increase melatonin and magnesium\n                </div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-text\">\n                  Headache, dizziness, nausea\n                </div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-text\">\n                  Days\n                </div>\n              </div>\n\n            </div>\n\n            <!-- CARD 3 -->\n\n            <div class=\"keen-slider__slide compare-card\">\n\n              <div class=\"compare-header\">\n                <h2>CBT-I</h2>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-icon\">✓</div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-icon\">✕</div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-text\">\n                  Sessions with sleep therapist\n                </div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-text\">\n                  Emotional discomfort\n                </div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-text\">\n                  Months\n                </div>\n              </div>\n\n            </div>\n\n            <!-- CARD 4 -->\n\n            <div class=\"keen-slider__slide compare-card\">\n\n              <div class=\"compare-header\">\n                <h2>Other Sleep Wearables & Trackers</h2>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-icon\">✕</div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-icon\">✕</div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-text\">\n                  Electric currents\n                </div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-text\">\n                  Undeterminable due to lack of data\n                </div>\n              </div>\n\n              <div class=\"compare-row\">\n                <div class=\"compare-icon\">✕</div>\n              </div>\n\n            </div>\n\n          </div>\n\n        </div>\n\n        <!-- ARROWS -->\n\n        <div class=\"slider-nav\">\n\n          <button class=\"slider-btn-table\" id=\"prevBtn\">\n            <svg width=\"42\" height=\"42\" viewBox=\"0 0 42 42\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<path d=\"M23.1797 30.8344C23.3564 31.0465 23.6717 31.0752 23.8839 30.8984C24.096 30.7216 24.1247 30.4063 23.9479 30.1942L23.5638 30.5143L23.1797 30.8344ZM16.0139 21.4544L15.6298 21.1343C15.4753 21.3197 15.4753 21.5891 15.6298 21.7745L16.0139 21.4544ZM23.9479 12.7146C24.1247 12.5025 24.096 12.1872 23.8839 12.0104C23.6717 11.8337 23.3564 11.8623 23.1797 12.0745L23.5638 12.3945L23.9479 12.7146ZM23.5638 30.5143L23.9479 30.1942L16.398 21.1343L16.0139 21.4544L15.6298 21.7745L23.1797 30.8344L23.5638 30.5143ZM16.0139 21.4544L16.398 21.7745L23.9479 12.7146L23.5638 12.3945L23.1797 12.0745L15.6298 21.1343L16.0139 21.4544ZM21 41.5L21 41C9.9543 41 0.999997 32.0457 0.999998 21L0.499998 21L-2.02253e-06 21C-3.03646e-06 32.598 9.40202 42 21 42L21 41.5ZM0.499998 21L0.999998 21C0.999999 9.95431 9.95431 1 21 1L21 0.500002L21 2.02253e-06C9.40202 1.0086e-06 -1.0086e-06 9.40202 -2.02253e-06 21L0.499998 21ZM21 0.500002L21 1C32.0457 1 41 9.95431 41 21L4