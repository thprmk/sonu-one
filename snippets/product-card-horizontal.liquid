{% liquid
  assign variant_to_link = product.selected_or_first_available_variant

  assign combined_listing_count = product.options_with_values | map: 'values' | map: 'product_url' | compact | size
  assign no_swatch_selected = null

  unless combined_listing_count > 0
    # Simple direct check: which variant owns the featured image?
    if product.featured_media
      assign found_variant = false

      for variant in product.variants
        if variant.featured_media.id == product.featured_media.id
          assign variant_to_link = variant
          assign found_variant = true
          break
        endif
      endfor

      # Check if we need to set no_swatch_selected
      unless found_variant
        # Featured image is not a variant image
        # Check if product has swatches
        for option in product.options_with_values
          assign swatch_count = option.values | map: 'swatch' | compact | size
          if swatch_count > 1
            # Multiple swatches exist but featured image doesn't match any
            assign no_swatch_selected = true
            break
          endif
        endfor
      endunless
    endif
  endunless

  assign featured_image = product.featured_media
  assign featured_image_alt = product.featured_media.alt | default: product.title
  assign first_media_type = product.featured_media.media_type

  if first_media_type == 'model' or first_media_type == 'video'
    assign featured_image = product.featured_media.preview_image
  endif

  assign second_image = ''
  if settings.show_second_image_on_hover and product.images.size > 1 and product.images[1] != blank
    assign second_image = product.images[1]
  endif

  if image_ratio == blank
    assign image_ratio = settings.pcard_aspect_ratio | default: '1'
  endif
  if image_ratio == 'auto'
    if featured_image != blank
      assign image_ratio = featured_image.aspect_ratio
    else
      assign image_ratio = '1'
    endif
  endif

  assign use_card_style = use_card_style | default: false, allow_false: true
  assign mobile_box_style = mobile_box_style | default: false, allow_false: true
  assign pcard_style = settings.pcard_style
  assign pcard_color_scheme = settings.pcard_color_scheme
  assign show_swatch = show_swatch | default: true, allow_false: true
  assign show_badges = show_badges | default: true, allow_false: true
  assign product_title_line_limit = product_title_line_limit | default: 'none'

  assign has_quick_add = false
  assign show_quick_add = show_quick_add | default: settings.pcard_show_quick_add, allow_false: true
  assign show_quick_add_mobile = show_quick_add_mobile | default: settings.pcard_show_quick_add_mobile, allow_false: true
  if product.available
    if show_quick_add or show_quick_add_mobile
      assign has_quick_add = true
    endif
  endif

  assign loading = loading | default: 'lazy'
  assign fetchpriority = fetchpriority | default: 'auto'

  assign onboarding = false
  assign product_title = product.title
  if product.id == empty or product == blank
    assign onboarding = true
    assign product_title = 'placeholders.product_title' | t
  endif

  assign media_width_desktop = media_width_desktop | default: 130
  assign media_width_mobile = media_width_mobile | default: 90
%}
{%- capture media_sizes -%}{%- if media_width_desktop != media_width_mobile -%}(min-width: 1440px) {{ media_width_desktop }}px, {%- endif -%}{{ media_width_mobile }}px{%- endcapture -%}
{%- capture media_widths -%}{%- if media_width_desktop != media_width_mobile -%}{{ media_width_desktop }}, {{ media_width_desktop | times: 2 }}, {%- endif -%}{{ media_width_mobile }}, {{ media_width_mobile | times: 2 }}{%- endcapture -%}
{%- capture card_style -%}
  {%- if has_quick_add -%}
  --quick-add-display: {% if show_quick_add %}flex{% else %}none{% endif %};
  --quick-add-display-mobile: {% if show_quick_add_mobile %}flex{% else %}none{% endif %};
  {%- endif -%}
{%- endcapture -%}
<product-card
  class="block product-card product-card--horizontal{% if show_mobile_background %} product-card--mobile-solid{% endif %}{% if use_card_style %} product-card--style-{{ pcard_style }}{% if pcard_style == 'card' %} color-{{ pcard_color_scheme }} overflow-hidden{% endif %}{% endif %}{% if mobile_box_style %} product-card--mobile-box-style{% endif %}"
  {% if no_swatch_selected %}
    data-no-swatch-selected="true"
  {% endif %}
  style="{{ card_style | strip | strip_newlines }}"
>
  <a
    {% unless onboarding %}
      href="{{ variant_to_link.url }}"
    {% else %}
      role="link"
    {% endunless %}
    class="product-card__link focus-visible--inset absolute inset-0"
    ref="productCardLink"
    aria-label="{{ product_title | escape }}"
  ></a>
  <div class="product-card__wrapper flex items-center">
    <div
      class="product-card__media media-hover--scale{% if second_image != blank %} product-card__media--has-second-image{% endif %} relative media-mask-clip shrink-0"
      style="--ratio: {{ image_ratio }};"
    >
      <a
        {% unless onboarding %}
          href="{{ variant_to_link.url }}"
        {% else %}
          role="link"
        {% endunless %}
        ref="cardGalleryLink"
        aria-label="{{ product_title | escape }}"
        tabindex="-1"
      >
        {%- if featured_image -%}
          {% comment %}
             // Backup when need use video media instead of image
            {%- unless first_media_type == 'video' or first_media_type == 'external_video' -%}
            {%- else -%}
              <div class="media">
                {% render 'video',
                  video: featured_media,
                  video_autoplay: true,
                  video_loop: true,
                  section_id: section.id,
                  disable_controls: true,
                  enable_toggle_button: false
                %}
              </div>
            {%- endunless -%}
          {% endcomment %}

          {% render 'responsive-image',
            mode: 'liquid',
            sizes: media_sizes,
            widths: media_widths,
            image: featured_image,
            default_alt: featured_image_alt,
            image_ratio: image_ratio,
            class: 'product-card__image product-card__image--first',
            img_class: 'w-full product-card-main-image'
          %}

          {%- if second_image != blank -%}
            {% render 'responsive-image',
              mode: 'liquid',
              sizes: media_sizes,
              widths: media_widths,
              image: second_image,
              image_ratio: image_ratio,
              class: 'product-card__image product-card__image--second',
              img_class: 'w-full'
            %}
          {%- endif -%}
        {%- else -%}
          <div class="media media--placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder' }}
          </div>
        {%- endif -%}
      </a>
    </div>
    <div class="product-card__content-wrap flex-grow flex items-center gap-2">
      <div class="product-card__content flex flex-grow flex-col">
        {% if show_badges and product != blank %}
          <product-badge data-product-id="{{ product.id }}" class="product-card-horizontal__badges">
            {% render 'product-badges',
              product: product,
              use_variant: false,
              show_soldout_badge: settings.pcard_show_sold_out_badge,
              sale_badge_type: settings.pcard_sale_badge_type,
              show_sale_badge: settings.pcard_show_sale_badge,
              show_custom_badges: settings.pcard_show_custom_badges,
              badge_layout: 'horizontal'
            %}
          </product-badge>
        {% endif %}
        {% render 'product-card-metas', product: product, show_vendor: show_vendor, show_type: show_type %}
        {%- if product != blank -%}
          <a
            class="product-card__title text-wrap reversed-link text-limit-{{ product_title_line_limit }}"
            href="{% render 'product-card-variant-url', product: product %}"
            ref="productTitleLink"
            aria-label="{{ product_title | escape }}"
          >
            <span class="reversed-link__text">{{ product_title }}</span>
          </a>
        {%- else -%}
          <p class="product-card__title text-wrap">
            <span>{{ product_title }}</span>
          </p>
        {%- endif -%}

        <product-price class="product-card__price">
          {% render 'price', show_unit_price: true, product_resource: product, use_variant: false %}
        </product-price>

        {%- if show_swatch -%}
          {% liquid
            for product_option in product.options_with_values
              assign swatch_count = product_option.values | map: 'swatch' | compact | size

              if swatch_count > 0 and settings.pcard_show_swatches
                assign product_has_swatches = true
              endif
            endfor
          %}
          {% if product_has_swatches %}
            <product-swatches
              data-product-id="{{ product.id }}"
              data-product-url="{{ product.url }}"
              style="--swatch-width: {{ settings.pcard_swatch_width }}px;"
            >
              {% render 'variant-swatches',
                product_resource: product,
                show_variant_image: settings.pcard_show_variant_image,
                swatch_shape: settings.pcard_swatch_shape,
                swatch_width: settings.pcard_swatch_width,
                context: 'card'
              %}
            </product-swatches>
          {% endif %}
        {%- endif -%}
        {{ children }}
      </div>
      {%- if has_quick_add -%}
        <div class="product-card__action shrink-0">
          {% render 'quick-add',
            product: product,
            section_id: section.id,
            block: block,
            button_icon: 'cart',
            button_style: 'icon_only',
            button_size: 'medium',
            mode: 'combine'
          %}
        </div>
      {%- endif -%}
    </div>
  </div>
</product-card>
