{%- comment -%}
  SONU Design Tokens & Shared Components
  Rendered once in theme.liquid head.
{%- endcomment -%}

<style>
:root {
  /* Brand Colors */
  --sonu-navy:        #001755;
  --sonu-accent:      #656AE3;
  --sonu-bg-light:    #F5F6FB;
  --sonu-bg-blue:     #EAF3FD;
  --sonu-bg-gradient: linear-gradient(90deg, #F2EDF4 0%, #EEF1FA 45%, #E8F2FF 100%);
  
  /* Brand Typography */
  --sonu-font-primary:   'Instrument Sans', var(--font-body-family), sans-serif;
  --sonu-font-serif:     'pp-editorial', 'Times New Roman', var(--font-heading-family), serif;
  
  /* Nav Arrow Size */
  --sonu-arrow-size:     42px;
  
  /* Progress Bar */
  --sonu-progress-height: 3px;
  --sonu-progress-bg:    #dddddd;
  --sonu-progress-fill:  var(--sonu-accent);
  
  /* Card Radius */
  --sonu-card-radius:    20px;
  
  /* Section Padding */
  --sonu-section-pad-desktop: 80px 0;
  --sonu-section-pad-mobile:  60px 20px;
  
  /* Blur Animation */
  --sonu-blur-duration:  1s;
  --sonu-blur-distance:  20px;
}

/* ==========================================================================
   SHARED SHARED STYLES & TRANSITIONS
   ========================================================================== */

/* Blur Fade In Animation */
@keyframes sonuBlurFade {
  to {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }
}

.sonu-blur-in {
  opacity: 1;
  filter: none;
  transform: none;
}

/* Only apply transition/animations if globally enabled in theme editor */
.animations-enabled .sonu-blur-in {
  opacity: 0;
  filter: blur(10px);
  transform: translateY(var(--sonu-blur-distance));
}

.animations-enabled .sonu-blur-in.animated {
  animation: sonuBlurFade var(--sonu-blur-duration) cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.sonu-blur-in--d1 { animation-delay: 0.15s !important; }
.sonu-blur-in--d2 { animation-delay: 0.3s !important; }
.sonu-blur-in--d3 { animation-delay: 0.45s !important; }

/* Reusable Progress Bar */
.sonu-progress {
  height: var(--sonu-progress-height);
  background: var(--sonu-progress-bg);
  width: 100%;
  overflow: hidden;
  border-radius: 2px;
}

.sonu-progress__fill {
  height: 100%;
  width: 0;
  background: var(--sonu-progress-fill);
  transition: width 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Reusable Arrow Button */
.sonu-arrow-btn {
  width: var(--sonu-arrow-size);
  height: var(--sonu-arrow-size);
  padding: 0;
  border: none;
  background: transparent !important;
  color: var(--sonu-navy);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.sonu-arrow-btn:hover {
  transform: scale(1.08);
  background: transparent !important;
  box-shadow: none !important;
}

.sonu-arrow-btn[disabled] {
  opacity: 0.35;
  cursor: not-allowed;
  transform: none !important;
}

.sonu-arrow-btn svg {
  display: block;
  width: 100%;
  height: 100%;
}

/* Standardized Section Header styling */
.sonu-section-header {
  margin-bottom: 40px;
  width: 100%;
}

.sonu-section-header.text-center { text-align: center; }
.sonu-section-header.text-left { text-align: left; }
.sonu-section-header.text-right { text-align: right; }

.sonu-section-header__small-heading {
  font-family: var(--sonu-font-primary);
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--sonu-accent);
  margin: 0 0 10px 0;
}

@media (max-width: 768px) {
  .sonu-section-header__small-heading {
    text-align: center;
  }
}

.sonu-section-header__subheading {
  font-family: var(--sonu-font-primary);
  font-size: 16px;
  line-height: 1.5;
  color: rgba(0, 23, 85, 0.75);
  margin: 15px 0 0 0;
  max-width: 700px;
}
.sonu-section-header.text-center .sonu-section-header__subheading {
  margin-left: auto;
  margin-right: auto;
}

.sonu-section-header .highlight {
  font-family: var(--sonu-font-serif);
  font-style: italic;
  font-weight: normal;
}
</style>

<script>
// Global Intersection Observer for viewport-triggered fade/blur animations
document.addEventListener("DOMContentLoaded", () => {
  if (document.body.classList.contains("animations-enabled")) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("animated");
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05, rootMargin: "0px 0px -50px 0px" });

    document.querySelectorAll(".sonu-blur-in").forEach(el => observer.observe(el));
  }
});
</script>
