{{ 'sonu-custom.css' | asset_url | stylesheet_tag }}
<style>
  #shopify-section-{{ section.id }} .split-content {
    padding-top: {{ section.settings.padding_top | default: 120 }}px !important;
    padding-bottom: {{ section.settings.padding_bottom | default: 120 }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .split-content {
      padding-top: {{ section.settings.mobile_padding_top | default: 72 }}px !important;
      padding-bottom: {{ section.settings.mobile_padding_bottom | default: 48 }}px !important;
    }
  }
</style>
<section class="split-content section">
  <div class="sonu-split-page-width">
    <div class="split-grid">

      <!-- LEFT -->
      <div class="split-left sonu-blur-in">
        {%- assign heading_style = 'color: ' | append: section.settings.heading_color -%}
        {% render 'sonu-section-header',
          heading: section.settings.heading,
          heading_tag: section.settings.heading_tag,
          heading_class: 'main-heading',
          heading_style: heading_style,
          small_heading: section.settings.small_heading,
          subheading: section.settings.subheading,
          text_align: 'left',
          animate: false
        %}
      </div>

      <!-- RIGHT -->
      <div class="split-right animate-blur delay-1">

        {% if section.settings.description != blank %}
          <div class="description">
            {{ section.settings.description }}
          </div>
        {% endif %}

        <div class="features">
          {% for block in section.blocks %}
            <div class="feature-item">

              {% if block.settings.icon_svg != blank %}
                <div class="icon">
                  {{ block.settings.icon_svg }}
                </div>
              {% endif %}

              <p>{{ block.settings.text }}</p>

            </div>
          {% endfor %}
        </div>

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Split Content",
  "settings": [
    {
      "type": "text",
      "id": "small_heading",
      "label": "Small Heading"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading (Use [[text]] for italic serif)"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#001755"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading type",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 120,
      "unit": "px",
      "label": "Padding Top (Desktop)"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 120,
      "unit": "px",
      "label": "Padding Bottom (Desktop)"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 72,
      "unit": "px",
      "label": "Padding Top (Mobile)"
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 48,
      "unit": "px",
      "label": "Padding Bottom (Mobile)"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "SVG Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Split Content",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
