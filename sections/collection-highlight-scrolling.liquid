    },
    {
      "type": "select",
      "id": "collection_title_preset",
      "label": "t:settings.preset",
      "options": [
        {
          "value": "text-subheading",
          "label": "t:options.subheading"
        },
        {
          "value": "h1",
          "label": "t:options.h1"
        },
        {
          "value": "h2",
          "label": "t:options.h2"
        },
        {
          "value": "h3",
          "label": "t:options.h3"
        },
        {
          "value": "h4",
          "label": "t:options.h4"
        },
        {
          "value": "h5",
          "label": "t:options.h5"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "collection_title_font",
      "label": "t:settings.font",
      "options": [
        {
          "value": "var(--font-body--family)",
          "label": "t:options.body"
        },
        {
          "value": "var(--font-heading--family)",
          "label": "t:options.heading"
        }
      ],
      "default": "var(--font-body--family)",
      "visible_if": "{{ section.settings.collection_title_preset == 'custom' }}"
    },
    {
      "id": "collection_title_font_weight",
      "type": "select",
      "label": "t:settings.font_weight",
      "default": "",
      "options": [
        {
          "value": "",
          "label": "t:options.inherit"
        },
        {
          "value": "300",
          "label": "t:options.light"
        },
        {
          "value": "400",
          "label": "t:options.regular"
        },
        {
          "value": "500",
          "label": "t:options.medium"
        },
        {
          "value": "600",
          "label": "t:options.semi_bold"
        },
        {
          "value": "700",
          "label": "t:options.bold"
        },
        {
          "value": "800",
          "label": "t:options.extra_bold"
        },
        {
          "value": "900",
          "label": "t:options.black"
        }
      ],
      "visible_if": "{{ section.settings.collection_title_preset == 'custom' }}"
    },
    {
      "type": "range",
      "id": "collection_title_font_size",
      "label": "t:settings.font_size",
      "default": 15,
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.collection_title_preset == 'custom' }}"
    },
    {
      "type": "range",
      "id": "collection_title_font_size_mobile",
      "label": "t:settings.font_size_mobile",
      "default": 15,
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.collection_title_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "collection_title_line_height",
      "label": "t:settings.line_height",
      "options": [
        {
          "value": "tight",
          "label": "t:options.tight"
        },
        {
          "value": "normal",
          "label": "t:options.normal"
        },
        {
          "value": "loose",
          "label": "t:options.loose"
        }
      ],
      "default": "normal",
      "visible_if": "{{ section.settings.collection_title_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "collection_title_text_color",
      "label": "t:settings.text_color",
      "options": [
        {
          "value": "text",
          "label": "t:options.text"
        },
        {
          "value": "subtext",
          "label": "t:options.subtext"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "subtext"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "collection_title_custom_text_color",
      "label": "t:settings.custom_text_color",
      "visible_if": "{{ section.settings.collection_title_text_color == 'custom' }}"
    },
    {
      "type": "header",
      "content": "t:content.highlighted_collection_title"
    },
    {
      "type": "select",
      "id": "collection_title_highlight_variant",
      "label": "t:settings.font_style",
      "options": [
        { "value": "normal", "label": "t:options.normal" },
        { "value": "bolder", "label": "t:options.bolder" },
        { "value": "italic", "label": "t:options.italic" },
        { "value": "bolder-italic", "label": "t:options.bolder_and_italic" }
      ],
      "default": "bolder"
    },
    {
      "type": "select",
      "id": "collection_title_highlight_text_color",
      "label": "t:settings.text_color",
      "options": [
        {
          "value": "text",
          "label": "t:options.text"
        },
        {
          "value": "subtext",
          "label": "t:options.subtext"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "text"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "collection_title_highlight_custom_text_color",
      "label": "t:settings.custom_text_color",
      "visible_if": "{{ section.settings.collection_title_highlight_text_color == 'custom' }}"
    },
    {
      "type": "select",
      "id": "collection_title_highlight_style",
      "label": "t:settings.underline_style",
      "options": [
        { "value": "wavy-underline", "label": "t:options.wavy_underline" },
        { "value": "underline", "label": "t:options.underline" }
      ],
      "default": "underline"
    },
    {
      "type": "color",
      "id": "collection_title_highlight_shape_color",
      "label": "t:settings.underline_color"
    },
    {
      "type": "header",
      "content": "t:content.collection_image"
    },
    {
      "type": "range",
      "id": "collection_image_border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color_scheme",
      "id": "collection_image_overlay_color_scheme",
      "label": "t:settings.overlay_color_scheme",
      "default": "scheme-inverse",
      "info": "t:info.applies_only_on_mobile"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "select",
      "id": "device",
      "label": "t:settings.devices",
      "options": [
        {
          "value": "desktop",
          "label": "t:options.desktop"
        },
        {
          "value": "mobile",
          "label": "t:options.mobile"
        }
      ],
      "default": "desktop"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 50,
      "visible_if": "{{ section.settings.device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 50,
      "visible_if": "{{ section.settings.device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48,
      "visible_if": "{{ section.settings.device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48,
