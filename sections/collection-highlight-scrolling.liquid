{%- liquid
  assign container = section.settings.container
  assign content_position = section.settings.content_position

  capture section_header
    content_for 'block', type: '_section-header-vertical', id: 'section-header-vertical'
  endcapture

  capture blocks
    content_for 'blocks'
  endcapture

  assign parts = blocks | strip | split: '<!-- @collectionHighlight/split -->'
  assign images_html = ''
  assign titles_html = ''

  for item in parts
    assign mod = forloop.index0 | modulo: 2
    if mod == 0
      assign titles_html = titles_html | append: item
    elsif mod == 1
      assign images_html = images_html | append: item
    endif
  endfor

  assign title_preset = section.settings.collection_title_preset
  assign title_font = section.settings.collection_title_font
  assign title_font_size = section.settings.collection_title_font_size
  assign title_font_size_mobile = section.settings.collection_title_font_size_mobile
  assign title_font_weight = section.settings.collection_title_font_weight
  assign title_line_height = section.settings.collection_title_line_height

  capture title_classes
    if title_preset == 'custom'
      echo ' custom-typography'
      if title_font_size != ''
        echo ' custom-font-size'
      endif
    endif
    if section.settings.collection_title_highlight_variant contains 'bolder'
      echo ' collection-highlight-scrolling--highlighted-title-bolder'
    endif
    if section.settings.collection_title_highlight_variant contains 'italic'
      echo ' collection-highlight-scrolling--highlighted-title-italic'
    endif
  endcapture
-%}
{%- capture inline_style -%}
  {% render 'border-style', settings: section.settings %}
  {% render 'clamp-calculate-style', property_name: 'descriptions-gap', min_value: 48, max_value: 100 %}
{%- endcapture -%}

{%- capture title_style -%}
  {%- render 'collection-highlight-title-style', settings: section.settings -%}
  {%- if section.settings.collection_title_highlight_shape_color.alpha > 0 -%}--shape-color: {{ section.settings.collection_title_highlight_shape_color }};{%- endif -%}
  {%- render 'typography-style',
    preset: title_preset,
    font_family: title_font, 
    font_size: title_font_size,
    font_size_mobile: title_font_size_mobile,
    font_weight: title_font_weight,
    line_height: title_line_height
  -%}
{%- endcapture -%}
{%- capture wrapper_style -%}
  {% render 'spacing-style', settings: section.settings %}
  {% render 'clamp-calculate-style', property_name: 'content-padding-y', min_value: 48, max_value: 100 %}
{%- endcapture -%}
<collection-highlight-scrolling
  class="inherit-color-scheme section block spacing-style collection-highlight-scrolling collection-highlight-scrolling--container-{{ container }} collection-highlight-scrolling--title-{{ section.settings.collection_title_highlight_style }}{% if container == 'full' %} collection-highlight-scrolling--content-{{ content_position }}{% endif %}"
  style="{{ wrapper_style }}"
  data-section-id="{{ section.id }}"
>
  <div
    ref="sectionContainer"
    class="relative flex"
  >
    <div ref="spacer"></div>
    <div
      ref="container"
      class="collection-highlight-scrolling__container section-grid section-grid--{{ container }} top-0 left-0 w-full"
      style="{{ inline_style }}"
    >
      <div
        ref="wrapper"
        class="collection-highlight-scrolling__wrapper overflow-hidden{% if container == 'full' and content_position == 'inside' %} section-grid{% else %} grid{% endif %} border-style color-{{ section.settings.color_scheme }}"
      >
        <div
          class="collection-highlight-scrolling__wrapper-inner flex flex-col md:flex-row items-start gap-style"
          style="{% render 'gap-style', column_gap_mobile: 30, column_gap: 50 %}"
        >
          <div class="collection-highlight-scrolling__content w-full flex flex-col relative z-0">
            {{ section_header }}
            <div
              ref="titlesContainer"
              class="collection-highlight-scrolling__titles-container hidden md:block flex-1 overflow-y-clip relative z--1 {{ title_classes }}"
              style="{{ title_style }}"
            >
              <div
                ref="titlesWrap"
                class="collection-highlight-scrolling__titles"
              >
                {{ titles_html }}
              </div>
            </div>
          </div>
          <div
            ref="imagesWrap"
            class="collection-highlight-scrolling__images w-full flex flex-col"
            style="{{ title_style }}"
          >
            {{ images_html }}
          </div>
        </div>
      </div>
    </div>
  </div>
</collection-highlight-scrolling>
{% schema %}
{
