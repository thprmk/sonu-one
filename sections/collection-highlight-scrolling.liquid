    }
  ],
  "blocks": [
    {
      "type": "_collection-highlight-scrolling"
    }
  ],
  "presets": [
    {
      "name": "t:names.collection_highlight_scrolling",
      "category": "t:categories.collections",
      "settings": {
        "container": "fixed",
        "content_position": "inside",
        "show_product_count": true,
        "collection_title_preset": "custom",
        "collection_title_font": "var(--font-heading--family)",
        "collection_title_font_weight": "",
        "collection_title_font_size": 60,
        "collection_title_font_size_mobile": 28,
        "collection_title_line_height": "loose",
        "collection_title_highlight_variant": "normal",
        "collection_title_highlight_text_color": "",
        "collection_title_highlight_style": "underline",
        "collection_title_highlight_shape_color": "",
        "collection_image_border_radius": 20,
        "collection_image_overlay_color_scheme": "",
        "color_scheme": "scheme-2",
        "border_radius": 20,
        "device": "desktop",
        "padding-block-start": 50,
        "padding-block-end": 50,
        "padding-block-start-mobile": 48,
        "padding-block-end-mobile": 48
      },
      "blocks": {
        "section-header-vertical": {
