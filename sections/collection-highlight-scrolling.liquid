                "font_size": 15,
                "font_size_mobile": 15,
                "line_height": "normal",
                "text_color": "text",
                "width": "100%",
                "text_alignment": "left",
                "width_mobile": "100%",
                "text_alignment_mobile": "left",
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0,
                "mobile-padding-scale": 80,
                "animation_type": "none",
                "animation_delay": 250
              }
            }
          },
          "block_order": ["subheading"]
        },
        "collection_1": {
          "type": "_collection-highlight-scrolling"
        },
        "collection_2": {
          "type": "_collection-highlight-scrolling"
        },
        "collection_3": {
          "type": "_collection-highlight-scrolling"
        },
        "collection_4": {
          "type": "_collection-highlight-scrolling"
        },
        "collection_5": {
          "type": "_collection-highlight-scrolling"
        },
        "collection_6": {
          "type": "_collection-highlight-scrolling"
        },
        "collection_7": {
          "type": "_collection-highlight-scrolling"
        },
        "collection_8": {
          "type": "_collection-highlight-scrolling"
        },
        "collection_9": {
          "type": "_collection-highlight-scrolling"
        },
        "collection_10": {
          "type": "_collection-highlight-scrolling"
        },
        "collection_11": {
          "type": "_collection-highlight-scrolling"
        },
        "collection_12": {
          "type": "_collection-highlight-scrolling"
        }
      },
      "block_order": [
