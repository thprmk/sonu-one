{{ 'sonu-custom.css' | asset_url | stylesheet_tag }}
<style>
  .split-video-testimonial-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    {%- if section.settings.bg_image != blank -%}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {%- endif -%}
    margin: 0;
    display: flex;
    flex-direction: column;
    width: 100%;
    overflow: hidden;
    position: relative;
    padding-top: {{ section.settings.padding_top | default: 0 }}px !important;
    padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px !important;
  }

  /* Adjust padding on mobile screens (768px wide and below) */
  @media screen and (max-width: 768px) {
    .split-video-testimonial-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top | default: 0 }}px !important;
      padding-bottom: {{ section.settings.mobile_padding_bottom | default: 0 }}px !important;
    }
  }

  /* Main Slider Architecture Grid/Wrapper */
  .split-video-testimonial-{{ section.id }} .testimonial-slider-container {
    display: flex;
    width: 100%;
    position: relative;
    overflow: hidden;
    flex-direction: column;
  }

  .split-video-testimonial-{{ section.id }} .testimonial-slider-track {
    display: flex;
    width: 100%;
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }

  .split-video-testimonial-{{ section.id }} .testimonial-slide {
    width: 100%;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  /* Left Side Media Panel Box styling */
  .split-video-testimonial-{{ section.id }} .media-panel {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Becomes transparent if a background image is present */
    background-color: {% if section.settings.bg_image != blank %}transparent{% else %}{{ section.settings.video_bg_color }}{% endif %};
    padding: 30px 20px;
    box-sizing: border-box;
  }

  /* Contained Video Frame Wrapper Box */
  .split-video-testimonial-{{ section.id }} .video-wrapper-box {
    position: relative;
    width: 100%;
    max-width: 320px; 
    aspect-ratio: 9 / 16; 
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0px 8px 32px rgba(0, 0, 0, 0.12);
    line-height: 0;
    background-color: #000000;
  }

  .split-video-testimonial-{{ section.id }} .video-wrapper-box video,
  .split-video-testimonial-{{ section.id }} .video-wrapper-box iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: none;
  }

  /* Right Side Content Container */
  .split-video-testimonial-{{ section.id }} .content-panel {
    width: 100%;
    padding: 40px 20px; /* Adjusted to accommodate card border */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    box-sizing: border-box;
    /* Becomes transparent if a background image is present so the image shows through */
    background-color: {% if section.settings.bg_image != blank %}transparent{% else %}{{ section.settings.content_bg_color }}{% endif %};
  }

  /* Bordered Review Card from image_1cf8ac.png */
  .split-video-testimonial-{{ section.id }} .review-card {
    border: 1px solid #7C81E7;
    border-radius: 25px;
    padding: 40px 25px;
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-sizing: border-box;
  }

  .split-video-testimonial-{{ section.id }} .subheading {
    font-family: var(--sonu-font-primary);
    font-style: normal;
    font-weight: 600;
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #3D1B03;
    margin-bottom: 24px;
  }

  .split-video-testimonial-{{ section.id }} .main-quote {
    font-family: var(--sonu-font-primary);
    font-style: normal;
    font-weight: 400;
    font-size: var(--quote-font-size-mobile, 28px);
    line-height: 1.35;
    color: #000000;
    max-width: 500px;
    margin: 0 auto 24px auto;
  }

  .split-video-testimonial-{{ section.id }} .author-name {
    font-family: var(--sonu-font-primary);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    line-height: 26px;
    color: #3D1B03;
    margin-bottom: 6px;
  }

  .split-video-testimonial-{{ section.id }} .author-bio {
    font-family: var(--sonu-font-primary);
    font-style: normal;
    font-weight: 400;
    font-size: 14px;
    line-height: 18px;
    color: #4A5568;
    margin-bottom: 20px;
  }

  /* Star Rating Elements */
  .split-video-testimonial-{{ section.id }} .star-wrapper {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 0; /* Removed margin to sit at bottom of card */
  }

  .split-video-testimonial-{{ section.id }} .star-wrapper svg {
    width: 15px;
    height: 15px;
    fill: #FFCD0F;
  }

  /* Fixed Stationary Navigation Control Footer Block */
  .split-video-testimonial-{{ section.id }} .carousel-indicator-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 320px;
    margin: 20px auto 40px auto;
    font-family: var(--sonu-font-primary);
    font-size: 16px;
    color: #000000;
    user-select: none;
    position: relative;
    z-index: 10;
  }

  .split-video-testimonial-{{ section.id }} .slide-counter-label {
    min-width: 45px;
    text-align: left;
    letter-spacing: 0.05em;
  }

  .split-video-testimonial-{{ section.id }} .indicator-line-track {
    flex: 1;
    height: 2px;
    background-color: rgba(0, 0, 0, 0.15);
    margin: 0 20px;
    position: relative;
    border-radius: 2px;
  }

  .split-video-testimonial-{{ section.id }} .indicator-line-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%; 
    background-color: #000000;
    transition: width 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border-radius: 2px;
  }

  .split-video-testimonial-{{ section.id }} .nav-arrows {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .split-video-testimonial-{{ section.id }} .nav-arrow {
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000000;
    transition: transform 0.2s ease;
  }
  
  .split-video-testimonial-{{ section.id }} .nav-arrow:active {
    transform: scale(0.85);
  }

  /* Responsive split layout logic */
  @media screen and (min-width: 769px) {
    .split-video-testimonial-{{ section.id }} .testimonial-slide {
      flex-direction: row;
    }

    .split-video-testimonial-{{ section.id }} .media-panel {
      width: 50%;
      padding: 60px 40px;
    }

    .split-video-testimonial-{{ section.id }} .video-wrapper-box {
      max-width: 360px; 
    }

    .split-video-testimonial-{{ section.id }} .content-panel {
      width: 50%;
      padding: 80px 60px 140px 60px;
    }
    
    .split-video-testimonial-{{ section.id }} .main-quote {
      font-size: var(--quote-font-size-desktop, 36px);
      line-height: 1.3;
    }

    .split-video-testimonial-{{ section.id }} .carousel-indicator-bar {
      position: absolute;
      bottom: 50px;
      left: 75%; 
      transform: translateX(-50%);
      margin: 0;
    }
  }
  .split-video-testimonial-{{ section.id }} .testimonial-section-header-wrap {
    margin: 40px auto 20px auto;
    width: 100%;
    box-sizing: border-box;
  }
  @media screen and (max-width: 768px) {
    .split-video-testimonial-{{ section.id }} .testimonial-section-header-wrap {
      margin: 30px auto 10px auto;
      padding: 0 20px;
    }
  }

  /* Mobile-only slider styling */
  @media screen and (min-width: 769px) {
    .split-video-testimonial-{{ section.id }} .desktop-only-slider {
      display: block !important;
    }
    .split-video-testimonial-{{ section.id }} .mobile-only-slider {
      display: none !important;
    }
  }

  @media screen and (max-width: 768px) {
    .split-video-testimonial-{{ section.id }} .desktop-only-slider {
      display: none !important;
    }
    .split-video-testimonial-{{ section.id }} .mobile-only-slider {
      display: block !important;
      width: 100%;
    }

    .split-video-testimonial-{{ section.id }} .mobile-video-slider {
      position: relative;
      width: 100%;
      max-width: 320px;
      margin: 30px auto 20px auto;
      overflow: hidden;
      border-radius: 16px;
      line-height: 0;
    }

    .split-video-testimonial-{{ section.id }} .mobile-video-track {
      display: flex;
      width: 100%;
      transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .split-video-testimonial-{{ section.id }} .mobile-video-slide {
      width: 100%;
      flex-shrink: 0;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .split-video-testimonial-{{ section.id }} .mobile-video-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      padding: 10px;
      cursor: pointer;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s ease;
    }

    .split-video-testimonial-{{ section.id }} .mobile-video-arrow:active {
      opacity: 0.7;
    }

    .split-video-testimonial-{{ section.id }} .mobile-video-prev {
      left: 15px;
    }

    .split-video-testimonial-{{ section.id }} .mobile-video-next {
      right: 15px;
    }

    .split-video-testimonial-{{ section.id }} .mobile-video-arrow svg {
      width: 36px;
      height: 36px;
      display: block;
    }

    .split-video-testimonial-{{ section.id }} .mobile-testimonial-slider {
      width: 100%;
      overflow: hidden;
      margin-bottom: 20px;
    }

    .split-video-testimonial-{{ section.id }} .mobile-testimonial-track {
      display: flex;
      width: 100%;
      transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .split-video-testimonial-{{ section.id }} .mobile-testimonial-slide {
      width: 100%;
      flex-shrink: 0;
      box-sizing: border-box;
      padding: 0 20px;
    }
  }
</style>

<div class="split-video-testimonial-{{ section.id }}" id="TestimonialSection-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <div class="testimonial-section-header-wrap page-width">
      {%- assign heading_style = 'color: ' | append: section.settings.heading_color | append: ';' -%}
      {%- render 'sonu-section-header',
        heading: section.settings.heading,
        heading_tag: section.settings.heading_tag,
        heading_style: heading_style,
        text_align: 'center'
      -%}
    </div>
  {%- endif -%}

  <!-- DESKTOP LAYOUT (Hidden on mobile) -->
  <div class="testimonial-slider-container desktop-only-slider">
    <div class="testimonial-slider-track">
      {%- for block in section.blocks -%}
        <div class="testimonial-slide" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          
          <div class="media-panel">
            <div class="video-wrapper-box">
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
              {%- elsif block.settings.video_url != blank -%}
                {%- if block.settings.video_url.type == 'youtube' -%}
                  <iframe src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ block.settings.video_url.id }}" allow="autoplay; encrypted-media" allowfullscreen></iframe>
                {%- else -%}
                  <iframe src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autoplay=1&muted=1&loop=1" allow="autoplay; encrypted-media" allowfullscreen></iframe>
                {%- endif -%}
              {%- else -%}
                <div style="width: 100%; height: 100%; background: #eaeaea; display: flex; align-items: center; justify-content: center; font-family: sans-serif; color: #999; line-height: normal; padding: 20px; text-align: center;">
                  Upload Video Asset
                </div>
              {%- endif -%}
            </div>
          </div>

          <div class="content-panel">
            <div class="review-card">
              {%- if block.settings.subheading != blank -%}
                <div class="subheading">{{ block.settings.subheading | escape }}</div>
              {%- endif -%}

              {%- if block.settings.quote != blank -%}
                {%- assign quote_tag = block.settings.heading_tag | default: 'h2' -%}
                <{{ quote_tag }} class="main-quote" style="
                  {% if block.settings.quote_font_size != blank %}
                    --quote-font-size-mobile: {{ block.settings.quote_font_size }}px;
                  {% endif %}
                  {% if block.settings.quote_font_size_desktop != blank %}
                    --quote-font-size-desktop: {{ block.settings.quote_font_size_desktop }}px;
                  {% endif %}
                ">
                  “{{ block.settings.quote | replace: '"', '' | replace: '“', '' }}”
                </{{ quote_tag }}>
              {%- endif -%}

              {%- if block.settings.author_name != blank -%}
                <div class="author-name">{{ block.settings.author_name | escape }}</div>
              {%- endif -%}

              {%- if block.settings.author_bio != blank -%}
                <div class="author-bio">{{ block.settings.author_bio | escape }}</div>
              {%- endif -%}

              {%- if block.settings.show_stars -%}
                <div class="star-wrapper" aria-label="5 star rating">
                  {%- for i in (1..5) -%}
                    <svg viewBox="0 0 15 15" xmlns="http://www.w3.org/2000/svg">
                      <path d="M7.415 0L9.58 4.793L14.83 5.174L10.806 8.572L12.062 13.682L7.415 10.913L2.768 13.682L4.024 8.572L0 5.174L5.25 4.793L7.415 0Z"/>
                    </svg>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="carousel-indicator-bar">
        <span class="slide-counter-label">
          <span class="current-index">1</span> / {{ section.blocks.size }}
        </span>
        <div class="indicator-line-track">
          <div class="indicator-line-fill"></div>
        </div>
        <div class="nav-arrows">
          <button class="nav-arrow desktop-testimonial-prev" aria-label="Previous Slide">
            <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 13L1 7L7 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="nav-arrow desktop-testimonial-next" aria-label="Next Slide">
            <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 13L7 7L1 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    {%- endif -%}
  </div>

  <!-- MOBILE LAYOUT (Hidden on desktop) -->
  <div class="testimonial-slider-container mobile-only-slider">
    <!-- Video Slider with navigation arrows overlay -->
    <div class="mobile-video-slider">
      <div class="mobile-video-track">
        {%- for block in section.blocks -%}
          <div class="mobile-video-slide" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <div class="video-wrapper-box">
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
              {%- elsif block.settings.video_url != blank -%}
                {%- if block.settings.video_url.type == 'youtube' -%}
                  <iframe src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ block.settings.video_url.id }}" allow="autoplay; encrypted-media" allowfullscreen></iframe>
                {%- else -%}
                  <iframe src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autoplay=1&muted=1&loop=1" allow="autoplay; encrypted-media" allowfullscreen></iframe>
                {%- endif -%}
              {%- else -%}
                <div style="width: 100%; height: 100%; background: #eaeaea; display: flex; align-items: center; justify-content: center; font-family: sans-serif; color: #999; line-height: normal; padding: 20px; text-align: center;">
                  Upload Video Asset
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 1 -%}
        <button class="mobile-video-arrow mobile-video-prev" aria-label="Previous Video">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10" stroke="white" stroke-width="1.5" fill="black" fill-opacity="0.3"/>
            <path d="M14 8L10 12L14 16" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="mobile-video-arrow mobile-video-next" aria-label="Next Video">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10" stroke="white" stroke-width="1.5" fill="black" fill-opacity="0.3"/>
            <path d="M10 8L14 12L10 16" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      {%- endif -%}
    </div>

    <!-- Testimonial Text/Card Slider -->
    <div class="mobile-testimonial-slider">
      <div class="mobile-testimonial-track">
        {%- for block in section.blocks -%}
          <div class="mobile-testimonial-slide" data-index="{{ forloop.index0 }}">
            <div class="review-card">
              {%- if block.settings.subheading != blank -%}
                <div class="subheading">{{ block.settings.subheading | escape }}</div>
              {%- endif -%}

              {%- if block.settings.quote != blank -%}
                {%- assign quote_tag = block.settings.heading_tag | default: 'h2' -%}
                <{{ quote_tag }} class="main-quote" style="
                  {% if block.settings.quote_font_size != blank %}
                    --quote-font-size-mobile: {{ block.settings.quote_font_size }}px;
                  {% endif %}
                ">
                  “{{ block.settings.quote | replace: '"', '' | replace: '“', '' }}”
                </{{ quote_tag }}>
              {%- endif -%}

              {%- if block.settings.author_name != blank -%}
                <div class="author-name">{{ block.settings.author_name | escape }}</div>
              {%- endif -%}

              {%- if block.settings.author_bio != blank -%}
                <div class="author-bio">{{ block.settings.author_bio | escape }}</div>
              {%- endif -%}

              {%- if block.settings.show_stars -%}
                <div class="star-wrapper" aria-label="5 star rating">
                  {%- for i in (1..5) -%}
                    <svg viewBox="0 0 15 15" xmlns="http://www.w3.org/2000/svg">
                      <path d="M7.415 0L9.58 4.793L14.83 5.174L10.806 8.572L12.062 13.682L7.415 10.913L2.768 13.682L4.024 8.572L0 5.174L5.25 4.793L7.415 0Z"/>
                    </svg>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <!-- Mobile Indicator and navigation below card -->
    {%- if section.blocks.size > 1 -%}
      <div class="carousel-indicator-bar">
        <span class="slide-counter-label">
          <span class="current-index">1</span> / {{ section.blocks.size }}
        </span>
        <div class="indicator-line-track">
          <div class="indicator-line-fill"></div>
        </div>
        <div class="nav-arrows">
          <button class="nav-arrow mobile-testimonial-prev" aria-label="Previous Slide">
            <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 13L1 7L7 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="nav-arrow mobile-testimonial-next" aria-label="Next Slide">
            <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 13L7 7L1 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>
<script>
  (function() {
    function initTestimonialSection(sectionContainer) {
      if (!sectionContainer) return;

      // Helper for native touch swipe support
      function addSwipeSupport(element, onSwipeLeft, onSwipeRight) {
        let startX = 0;
        let endX = 0;
        element.addEventListener('touchstart', function(e) {
          startX = e.touches[0].clientX;
        }, { passive: true });
        element.addEventListener('touchend', function(e) {
          endX = e.changedTouches[0].clientX;
          const diff = startX - endX;
          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              onSwipeLeft();
            } else {
              onSwipeRight();
            }
          }
        }, { passive: true });
      }

      // --- DESKTOP SLIDER LOGIC ---
      let desktopShowSlide = null;
      const desktopSlider = sectionContainer.querySelector('.desktop-only-slider');
      if (desktopSlider) {
        const track = desktopSlider.querySelector('.testimonial-slider-track');
        const slides = desktopSlider.querySelectorAll('.testimonial-slide');
        const totalSlides = slides.length;
        let currentIndex = 0;

        const counterDisplay = desktopSlider.querySelector('.current-index');
        const progressFill = desktopSlider.querySelector('.indicator-line-fill');

        function updateSlider() {
          if (totalSlides === 0) return;
          const translateXValue = -(currentIndex * 100);
          track.style.transform = `translateX(${translateXValue}%)`;
          const fillPercentage = ((currentIndex + 1) / totalSlides) * 100;
          if (counterDisplay) counterDisplay.textContent = currentIndex + 1;
          if (progressFill) progressFill.style.width = fillPercentage + '%';
        }

        function showSlide(index) {
          if (index >= totalSlides) currentIndex = 0;
          else if (index < 0) currentIndex = totalSlides - 1;
          else currentIndex = index;
          updateSlider();
        }
        
        // Store reference for external access
        desktopShowSlide = showSlide;

        desktopSlider.addEventListener('click', function(e) {
          if (e.target.closest('.desktop-testimonial-next')) {
            e.preventDefault();
            showSlide(currentIndex + 1);
          }
          if (e.target.closest('.desktop-testimonial-prev')) {
            e.preventDefault();
            showSlide(currentIndex - 1);
          }
        });

        updateSlider();
      }

      // --- MOBILE SLIDERS LOGIC ---
      let mobileShowVideo = null;
      let mobileShowTestimonial = null;
      let mobileCurrentVideoIndex = 0;
      let mobileCurrentTestimonialIndex = 0;
      let mobileTotalVideos = 0;
      let mobileTotalTestimonials = 0;
      
      const mobileSlider = sectionContainer.querySelector('.mobile-only-slider');
      if (mobileSlider) {
        // 1. Mobile Video Slider
        const videoTrack = mobileSlider.querySelector('.mobile-video-track');
        const videoSlides = mobileSlider.querySelectorAll('.mobile-video-slide');
        mobileTotalVideos = videoSlides.length;
        mobileCurrentVideoIndex = 0;

        function updateVideoSlider() {
          if (mobileTotalVideos === 0) return;
          const translateXValue = -(mobileCurrentVideoIndex * 100);
          videoTrack.style.transform = `translateX(${translateXValue}%)`;
        }

        function showVideo(index) {
          if (index >= mobileTotalVideos) mobileCurrentVideoIndex = 0;
          else if (index < 0) mobileCurrentVideoIndex = mobileTotalVideos - 1;
          else mobileCurrentVideoIndex = index;
          updateVideoSlider();
        }
        
        // Store reference for external access
        mobileShowVideo = showVideo;

        // 2. Mobile Testimonial Text Slider
        const testimonialTrack = mobileSlider.querySelector('.mobile-testimonial-track');
        const testimonialSlides = mobileSlider.querySelectorAll('.mobile-testimonial-slide');
        mobileTotalTestimonials = testimonialSlides.length;
        mobileCurrentTestimonialIndex = 0;

        const counterDisplayMobile = mobileSlider.querySelector('.current-index');
        const progressFillMobile = mobileSlider.querySelector('.indicator-line-fill');

        function updateTestimonialSlider() {
          if (mobileTotalTestimonials === 0) return;
          const translateXValue = -(mobileCurrentTestimonialIndex * 100);
          testimonialTrack.style.transform = `translateX(${translateXValue}%)`;
          const fillPercentage = ((mobileCurrentTestimonialIndex + 1) / mobileTotalTestimonials) * 100;
          if (counterDisplayMobile) counterDisplayMobile.textContent = mobileCurrentTestimonialIndex + 1;
          if (progressFillMobile) progressFillMobile.style.width = fillPercentage + '%';
        }

        function showTestimonial(index) {
          if (index >= mobileTotalTestimonials) mobileCurrentTestimonialIndex = 0;
          else if (index < 0) mobileCurrentTestimonialIndex = mobileTotalTestimonials - 1;
          else mobileCurrentTestimonialIndex = index;
          updateTestimonialSlider();
        }
        
        // Store reference for external access
        mobileShowTestimonial = showTestimonial;

        // Handle all clicks inside mobile slider container
        mobileSlider.addEventListener('click', function(e) {
          // Video navigation arrows
          if (e.target.closest('.mobile-video-next')) {
            e.preventDefault();
            e.stopPropagation();
            showVideo(mobileCurrentVideoIndex + 1);
          }
          if (e.target.closest('.mobile-video-prev')) {
            e.preventDefault();
            e.stopPropagation();
            showVideo(mobileCurrentVideoIndex - 1);
          }
          // Testimonial text navigation (bottom arrows)
          if (e.target.closest('.mobile-testimonial-next')) {
            e.preventDefault();
            e.stopPropagation();
            showTestimonial(mobileCurrentTestimonialIndex + 1);
          }
          if (e.target.closest('.mobile-testimonial-prev')) {
            e.preventDefault();
            e.stopPropagation();
            showTestimonial(mobileCurrentTestimonialIndex - 1);
          }
        });

        // Swipe support for mobile tracks
        if (videoTrack) {
          addSwipeSupport(videoTrack, 
            () => showVideo(mobileCurrentVideoIndex + 1), 
            () => showVideo(mobileCurrentVideoIndex - 1)
          );
        }
        if (testimonialTrack) {
          addSwipeSupport(testimonialTrack, 
            () => showTestimonial(mobileCurrentTestimonialIndex + 1), 
            () => showTestimonial(mobileCurrentTestimonialIndex - 1)
          );
        }

        updateVideoSlider();
        updateTestimonialSlider();
      }

      // Sync block selections in Shopify editor
      if (Shopify.designMode) {
        sectionContainer.addEventListener('shopify:block:select', function(e) {
          if (e.target.closest('.desktop-only-slider')) {
            if (e.target.classList.contains('testimonial-slide')) {
              const targetIndex = parseInt(e.target.getAttribute('data-index'));
              if (!isNaN(targetIndex) && desktopShowSlide) {
                desktopShowSlide(targetIndex);
              }
            }
          }
          if (e.target.closest('.mobile-only-slider')) {
            const targetSlide = e.target.closest('.mobile-video-slide') || e.target.closest('.mobile-testimonial-slide');
            if (targetSlide) {
              const targetIndex = parseInt(targetSlide.getAttribute('data-index'));
              if (!isNaN(targetIndex)) {
                if (mobileShowVideo) mobileShowVideo(targetIndex);
                if (mobileShowTestimonial) mobileShowTestimonial(targetIndex);
              }
            }
          }
        });
      }
    }

    // Run initialization
    function init() {
      const sectionContainers = document.querySelectorAll('[id^="TestimonialSection-"]');
      sectionContainers.forEach(container => initTestimonialSection(container));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    // Handle Shopify theme editor re-renders
    document.addEventListener('shopify:section:load', function(e) {
      const sectionContainer = e.target.querySelector('[id^="TestimonialSection-"]');
      if (sectionContainer) {
        initTestimonialSection(sectionContainer);
      }
    });
  })();
</script>

