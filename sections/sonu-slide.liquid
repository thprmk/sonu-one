
<section class="therapy-mobile">

  <div class="therapy-mobile-container">

    <h2 class="therapy-mobile-heading">
      {{ section.settings.heading }}
    </h2>

    <div class="therapy-mobile-grid">

      {% for block in section.blocks %}
        <div class="therapy-mobile-card" {{ block.shopify_attributes }}>

          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 1000 }}"
              alt="{{ block.settings.title }}"
              class="therapy-mobile-image"
            >
          {% endif %}

          <div class="therapy-mobile-content">

            <h3 class="therapy-mobile-title">
              {{ block.settings.title }}
            </h3>

            <div class="therapy-mobile-description">
              {{ block.settings.description }}
            </div>

          </div>

        </div>
      {% endfor %}

    </div>

  </div>

</section>

<style>

    .therapy-mobile-card{
  background:#fff;
  border-radius:16px;
  overflow:hidden;

  opacity:0;
  transform:translateY(60px);
  transition:all .8s ease;
}

.therapy-mobile-card.show{
  opacity:1;
  transform:translateY(0);
}

/* Hide section on desktop */
.therapy-mobile{
  display:none;
}

/* Show only on mobile */
@media screen and (max-width: 768px){

  .therapy-mobile{
    display:block;
    padding:40px 16px;
  }

}

.therapy-mobile-container{
  max-width:480px;
  margin:0 auto;
}

.therapy-mobile-heading{
  text-align:center;
  color:#4a567d;
  font-size:36px;
  line-height:1.1;
  font-weight:100;
  margin:0 0 30px;
}

.therapy-mobile-grid{
  display:flex;
  flex-direction:column;
  gap:22px;
}

.therapy-mobile-card{
  background:#fff;
  border-radius:16px;
  overflow:hidden;
}

.therapy-mobile-image{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
  border-radius:20px;
}

.therapy-mobile-content{
  padding:16px;
  margin-top: 20px;
}

.therapy-mobile-title{
  color:#4a567d;
  font-size:28px;
  line-height:1.15;
  font-weight:100;
  margin:0 0 10px;
}

.therapy-mobile-description{
  color:#6e6e6e;
  font-size:13px;
  line-height:1.6;
}

</style>

<script>
document.addEventListener('DOMContentLoaded', function(){

  const cards = document.querySelectorAll('.therapy-mobile-card');

  const observer = new IntersectionObserver((entries) => {

    entries.forEach(entry => {

      if(entry.isIntersecting){
        entry.target.classList.add('show');
      }

    });

  }, {
    threshold: 0.2
  });

  cards.forEach(card => {
    observer.observe(card);
  });

});
</script>

{% schema %}
{
  "name": "Therapy Mobile",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Personalized to you. No guesswork."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Therapy Mobile"
    }
  ]
}
{% endschema %}