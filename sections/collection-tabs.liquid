      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10,
      "visible_if": "{{ section.settings.type == 'grid' }}"
    },
    {
      "type": "header",
      "content": "t:content.carousel_settings",
      "visible_if": "{{ section.settings.type == 'carousel' }}"
    },
    {
      "type": "select",
      "id": "control_type",
