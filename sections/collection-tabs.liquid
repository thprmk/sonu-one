        { "value": "fixed", "label": "t:options.fixed" }
      ],
      "default": "fixed"
    },
    {
      "type": "header",
      "content": "t:content.section_header"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "<p>Collection tabs</p>",
      "info": "t:info.highlight_style"
    },
    {
      "type": "select",
      "id": "highlight_style",
      "label": "t:settings.highlight_style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "standard",
          "label": "t:options.standard"
        },
        {
          "value": "wavy-underline",
          "label": "t:options.wavy_underline"
        },
        {
          "value": "solid-background",
          "label": "t:options.solid_background"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "highlight_font_style",
      "label": "t:settings.highlight_font_style",
      "options": [
        {
          "value": "italic",
          "label": "t:options.italic"
        },
        {
          "value": "normal",
          "label": "t:options.normal"
        }
      ],
      "default": "italic",
      "visible_if": "{{ section.settings.highlight_style != 'none' }}"
    },
    {
      "type": "color",
      "id": "highlight_shape_color",
      "label": "t:settings.highlight_shape_color",
      "visible_if": "{{ section.settings.highlight_style != 'none' and section.settings.highlight_style != 'standard' }}"
    },
    {
      "type": "color",
      "id": "highlight_text_color",
      "label": "t:settings.highlight_text_color",
      "visible_if": "{{ section.settings.highlight_style != 'none' }}"
    },
    {
      "type": "select",
      "id": "heading_preset",
      "label": "t:settings.preset",
      "options": [
        {
          "value": "h1",
          "label": "t:options.h1"
        },
        {
          "value": "h2",
          "label": "t:options.h2"
        },
        {
          "value": "h3",
          "label": "t:options.h3"
        },
        {
          "value": "h4",
          "label": "t:options.h4"
        },
        {
          "value": "h5",
          "label": "t:options.h5"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "h1"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "t:settings.font_size",
      "default": 15,
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.heading_preset == 'custom' }}"
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "t:settings.font_size_mobile",
      "default": 15,
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.heading_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "animation_type",
      "label": "t:settings.animation_type",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "fade-in",
          "label": "t:options.fade_in"
        },
        {
          "value": "fade-up",
          "label": "t:options.fade_up"
        },
        {
          "value": "slide-in-left",
          "label": "t:options.slide_in_left"
        },
        {
          "value": "slide-in-right",
          "label": "t:options.slide_in_right"
        }
      ],
      "default": "fade-up",
      "visible_if": "{{ settings.animations_enabled == true }}"
    },
    {
      "type": "range",
      "id": "animation_delay",
      "label": "t:settings.animation_delay",
      "min": 0,
      "max": 2000,
      "step": 50,
      "default": 250,
