{%- liquid
  assign image = section.settings.image
  assign image_mobile = section.settings.image_mobile
  assign container = section.settings.container
  assign color_scheme = section.settings.color_scheme

  assign use_padding_inline = false
  if container == 'full'
    assign use_padding_inline = true
  endif
-%}
{%- capture container_style -%}
  {% render 'border-style', settings: section.settings %}
  {% render 'spacing-style', settings: section.settings, use_padding_inline: use_padding_inline %}
  {%- if container == 'fixed' -%}
    {% render 'clamp-calculate-style', property_name: 'padding-inline', min_value: 0, max_value: 50, min_breakpoint: 1200, max_breakpoint: 1455 %}
  {%- endif -%}
{%- endcapture -%}

<style>
  /* Mobile only: Reorder content - table first, then header */
  @media (max-width: 767px) {
    .quick-comparison-table-container {
      display: flex;
      flex-direction: column;
    }
    .quick-comparison-table-container .comparison-table__header {
      order: 2;
    }
    .quick-comparison-table-container .comparison-table__content {
      order: 1;
    }
  }
</style>

<div
  id="section-{{ section.id }}"
  class="comparison-table relative"
>
  {% if image != blank %}
    <div class="comparison-table__media col-span-full row-span-full relative absolute inset-0 z-0">
      {% render 'responsive-image', mode: 'js', image: image, image_mobile: image_mobile, use_zoom: false %}
    </div>
  {% endif %}
  <div
    class="section__container section-grid section-grid--{{ container }} spacing-style relative z-1"
    style="{{ container_style }}"
  >
    <div class="block quick-comparison-table-container relative z-1 border-style overflow-hidden color-{{ color_scheme }}">
      <div class="comparison-table__header">
        {% comment %} {% content_for 'block', type: '_section-header-vertical', id: 'section-header-vertical' %} {% endcomment %}
        {% content_for 'block', type: '_products-bundle-header', id: 'section-header' %}
      </div>
      <div class="comparison-table__content h-scrollable relative z-0" id="comparison-table-{{ section.id }}">
        {% content_for 'block', type: '_comparison-table-content', id: 'comparison-table' %}
      </div>
    </div>
    {% comment %} <scroll-progress-bar class="scroll-progress-bar" target="comparison-table-{{ section.id }}">
      <div class="progress-container color-{{ color_scheme }}">
        <div class="progress-bar no-empty"></div>
      </div>
    </scroll-progress-bar> {% endcomment %}
  </div>
</div>

