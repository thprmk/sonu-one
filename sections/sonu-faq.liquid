<section class="sonu-faq-section image-bg-{{ section.id }}" style="
  {% if section.settings.bg_gradient != blank %}
    background: {{ section.settings.bg_gradient }};
  {% elsif section.settings.bg_color != blank %}
    background-color: {{ section.settings.bg_color }};
  {% endif %}
  --padding-top: {{ section.settings.padding_top | default: 80 }}px;
  --padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
  --padding-top-mobile: {{ section.settings.padding_top_mobile | default: 70 }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile | default: 14 }}px;
">
  <style>
    #shopify-section-{{ section.id }} .sonu-faq-section {
      padding-top: var(--padding-top, 80px) !important;
      padding-bottom: var(--padding-bottom, 80px) !important;
    }
    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} .sonu-faq-section {
        padding-top: var(--padding-top-mobile, 70px) !important;
        padding-bottom: var(--padding-bottom-mobile, 14px) !important;
      }
    }
  </style>

  <div class="sonu-faq-container">

    <{{ section.settings.heading_tag | default: 'h2' }} class="sonu-faq-heading">
      {{ section.settings.heading }}
    </{{ section.settings.heading_tag | default: 'h2' }}>

    <div class="sonu-faq-list">

      {% for block in section.blocks %}

        <div class="sonu-faq-item {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>

          <button class="sonu-faq-question">

            <span>{{ block.settings.question }}</span>

            <span class="sonu-faq-icon">
              {% if forloop.first %}
                −
              {% else %}
                +
              {% endif %}
            </span>

          </button>

          <div class="sonu-faq-answer">

            <div class="sonu-faq-answer-inner">
              {{ block.settings.answer }}
            </div>

          </div>

        </div>

      {% endfor %}

    </div>

  </div>

</section>

<style>

.sonu-faq-section{
  background-position: center;
  background-repeat: no-repeat;
  background-size: cover;
  padding:80px 20px;
}

/* Dynamic background handling for desktop */
{% if section.settings.bg_image_desktop != blank %}
.image-bg-{{ section.id }} {
  background-image: url('{{ section.settings.bg_image_desktop | image_url: width: 2000 }}');
}
{% endif %}

/* Dynamic background handling for mobile */
@media screen and (max-width: 768px) {
  .image-bg-{{ section.id }} {
    {% if section.settings.bg_image_mobile != blank %}
      background-image: url('{{ section.settings.bg_image_mobile | image_url: width: 1000 }}') !important;
    {% elsif section.settings.bg_image_desktop != blank %}
      background-image: url('{{ section.settings.bg_image_desktop | image_url: width: 1000 }}') !important;
    {% endif %}
  }
}

.sonu-faq-container{
  max-width:780px;
  margin:0 auto;
}

.sonu-faq-heading{
  margin:0 0 55px;
  text-align:center;
  font-family:'Instrument Sans',sans-serif;
  font-weight:400;
  font-size:60px;
  line-height:73px;
  color:#3D1B03;
}

.sonu-faq-list{
  display:flex;
  flex-direction:column;
  gap:12px;
}

.sonu-faq-item {
  overflow: hidden;
  background: rgba(255, 255, 255, 0.75);
  border: 1.5px solid rgba(61, 27, 3, 0.12);
  border-radius: 14px;
  margin-bottom: 16px;
  transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
}

.sonu-faq-item.active {
  background: #ffffff;
  border-color: #3D1B03;
  box-shadow: 0 8px 24px rgba(61, 27, 3, 0.05);
}

.sonu-faq-question {
  width: 100%;
  border: none;
  background: transparent;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22px 28px;
  cursor: pointer;
  font-family: 'Instrument Sans', sans-serif;
  font-weight: 500;
  font-size: 18px;
  line-height: 22px;
  color: #1E1E1E;
  text-align: left;
}

.sonu-faq-icon {
  font-size: 22px;
  line-height: 1;
  flex-shrink: 0;
  color: #3D1B03;
  font-weight: 500;
}

.sonu-faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s ease;
}

.sonu-faq-answer-inner {
  padding: 0 28px 24px 28px;
  font-family: 'Instrument Sans', sans-serif;
  font-weight: 400;
  font-size: 16px;
  line-height: 26px;
  color: rgba(30, 30, 30, 0.85);
}

/* MOBILE */
@media(max-width:767px){

  .sonu-faq-section{
    padding:70px 14px;
  }

  /* Dynamic background handling for mobile overrides */
  {% if section.settings.bg_image_mobile != blank %}
  .image-bg-{{ section.id }} {
    background-image: url('{{ section.settings.bg_image_mobile | image_url: width: 800 }}');
  }
  {% endif %}

  .sonu-faq-container{
    max-width:336px;
  }

  .sonu-faq-heading{
    font-size:32px;
    line-height:39px;
    margin-bottom:39px;
  }

  .sonu-faq-question{
    min-height:47px;
    padding:15px 15px;
    font-size:14px;
    line-height:17px;
  }

  .sonu-faq-answer-inner{
    padding: 0 15px 15px 15px;
    font-size: 14px;
    line-height: 22px;
  }

  .sonu-faq-icon{
    font-size:18px;
  }

}

</style>

<script>
(function() {
  function initFAQ(container) {
    const items = container.querySelectorAll('.sonu-faq-item');
    if (!items.length) return;

    items.forEach(item => {
      const button = item.querySelector('.sonu-faq-question');
      const answer = item.querySelector('.sonu-faq-answer');
      const icon = item.querySelector('.sonu-faq-icon');

      // Sync initial active state heights
      if (item.classList.contains('active') && answer) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        if (icon) icon.textContent = '−';
      } else if (answer) {
        answer.style.maxHeight = '0px';
        if (icon) icon.textContent = '+';
      }

      button.addEventListener('click', function() {
        const isActive = item.classList.contains('active');

        // Close all items
        items.forEach(i => {
          i.classList.remove('active');
          const a = i.querySelector('.sonu-faq-answer');
          if (a) a.style.maxHeight = '0px';
          const ic = i.querySelector('.sonu-faq-icon');
          if (ic) ic.textContent = '+';
        });

        // Open clicked item if it wasn't already active
        if (!isActive) {
          item.classList.add('active');
          if (answer) answer.style.maxHeight = answer.scrollHeight + 'px';
          if (icon) icon.textContent = '−';
        }
      });
    });
  }

  // Initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => initFAQ(document));
  } else {
    initFAQ(document);
  }

  // Theme editor block update load
  document.addEventListener('shopify:section:load', (event) => {
    initFAQ(event.target);
  });
})();
</script>

{% schema %}
{
  "name": "SONU FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQ"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading Tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "p", "label": "Paragraph (P)" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Desktop Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Desktop Padding Bottom"
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 70,
      "unit": "px",
      "label": "Mobile Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 14,
      "unit": "px",
      "label": "Mobile Padding Bottom"
    },
    {
      "type": "image_picker",
      "id": "bg_image_desktop",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Mobile Background Image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#D7CEC7"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Background Gradient"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SONU FAQ",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}