{%- liquid
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
-%}

<div id="shopify-section-{{ section.id }}" class="custom-vid-wrapper" style="background-color: {{ bg_color }}; --text-color: {{ text_color }}; --desktop-slide-width: {{ section.settings.desktop_slide_width }}px; --mobile-slide-width: {{ section.settings.mobile_slide_width }}px; --padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px; --padding-top-mobile: {{ section.settings.padding_top_mobile }}px; --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;">
  <div class="custom-vid-container">
    
    <div class="custom-vid-header">
      {% if section.settings.heading != blank %}
        <h2 class="custom-vid-heading" style="color: {{ text_color }};">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="custom-vid-desc" style="color: {{ text_color }};">{{ section.settings.description | newline_to_br }}</div>
      {% endif %}
    </div>

    <div class="custom-vid-slider-row">
      <div class="swiper custom-vid-swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide custom-vid-slide" {{ block.shopify_attributes }}>
              
              <!-- Video Render -->
              {% if block.settings.video != blank %}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'custom-video-element' }}
              {% elsif block.settings.video_url != blank %}
                <video src="{{ block.settings.video_url }}" autoplay loop muted playsinline class="custom-video-element" poster="{{ block.settings.cover_image | image_url: width: 800 }}"></video>
              {% else %}
                <div style="width: 100%; height: 100%; background: #eaeaea; display: flex; align-items: center; justify-content: center; color: #555;">Video Placeholder</div>
              {% endif %}

              <!-- Overlay Pill -->
              {% if block.settings.overlay_text != blank %}
                <div class="custom-vid-overlay-pill custom-vid-overlay-pill--{{ block.settings.overlay_pos }}">
                  <p class="custom-vid-overlay-pill-text">{{ block.settings.overlay_text }}</p>
                </div>
              {% endif %}

              <!-- Overlay Badge -->
              {% if block.settings.overlay_badge != blank %}
                <div class="custom-vid-overlay-badge" style="width: {{ block.settings.badge_width }}px;">
                  <img src="{{ block.settings.overlay_badge | image_url: width: 300 }}" alt="Badge" loading="lazy">
                </div>
              {% endif %}

            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Bottom Navigation & Progress bar row -->
    <div class="custom-vid-controls-row">
      <div class="custom-vid-progressbar"></div>
      
      <div class="custom-vid-arrows">
        <button class="custom-vid-nav-btn custom-vid-nav-btn--prev" aria-label="Previous">
          <svg width="10" height="18" viewBox="0 0 10 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 17L1 9L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="custom-vid-nav-btn custom-vid-nav-btn--next" aria-label="Next">
          <svg width="10" height="18" viewBox="0 0 10 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 17L9 9L1 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Video Slider",
  "tag": "section",
  "class": "custom-video-slider-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See it to believe it"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Spatial Sleep is a personalized sleep headband that uses gentle sound and vibration to help you drift off naturally."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F6F0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#3D1B03"
    },
    {
      "type": "range",
      "id": "desktop_slide_width",
      "label": "Desktop Slide Width (px)",
      "min": 200,
      "max": 500,
      "step": 10,
      "default": 340
    },
    {
      "type": "range",
      "id": "mobile_slide_width",
      "label": "Mobile Slide Width (px)",
      "min": 150,
      "max": 350,
      "step": 10,
      "default": 240
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Desktop Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Desktop Padding Bottom"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Mobile Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Mobile Padding Bottom"
    }
  ],
  "blocks": [
    {
      "type": "video_slide",
      "name": "Video Slide",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Select Video"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Or Video URL (Fallback)"
        },
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Poster Cover Image"
        },
        {
          "type": "text",
          "id": "overlay_text",
          "label": "Overlay Pill Text"
        },
        {
          "type": "select",
          "id": "overlay_pos",
          "label": "Overlay Position",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "bottom", "label": "Bottom" }
          ],
          "default": "center"
        },
        {
          "type": "image_picker",
          "id": "overlay_badge",
          "label": "Overlay Badge Image (e.g. Product Box)"
        },
        {
          "type": "range",
          "id": "badge_width",
          "label": "Badge Width (px)",
          "min": 50,
          "max": 200,
          "step": 5,
          "default": 100
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Video Slider",
      "blocks": [
        {
          "type": "video_slide",
          "settings": {
            "overlay_text": "This Band Cleared My Daughter's Congestion in MINUTES 🤯",
            "overlay_pos": "center"
          }
        },
        {
          "type": "video_slide",
          "settings": {
            "overlay_pos": "bottom"
          }
        }
      ]
    }
  ]
}
{% endschema %}
