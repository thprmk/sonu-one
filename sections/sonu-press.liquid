<style>
  #sonu-press-{{ section.id }} {
    position: relative;
    z-index: 9999 !important;
    padding-top: {{ section.settings.padding_top | default: 80 }}px !important;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px !important;
    margin-bottom: -{{ section.settings.margin_bottom_negative | default: 40 }}px !important;
    overflow: hidden;
    border-bottom-left-radius: {{ section.settings.bottom_border_radius | default: 0 }}px;
    border-bottom-right-radius: {{ section.settings.bottom_border_radius | default: 0 }}px;
  }

  @media screen and (max-width: 768px) {
    #sonu-press-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top | default: 40 }}px !important;
      padding-bottom: {{ section.settings.mobile_padding_bottom | default: 26 }}px !important;
      margin-bottom: -{{ section.settings.margin_bottom_negative_mobile | default: 35 }}px !important;
      border-bottom-left-radius: {{ section.settings.mobile_bottom_border_radius | default: 0 }}px;
      border-bottom-right-radius: {{ section.settings.mobile_bottom_border_radius | default: 0 }}px;
    }
  }

  /* SECTION BACKGROUND */
  .press-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    border-bottom-left-radius: inherit;
    border-bottom-right-radius: inherit;
  }

  .press-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* GRID CONTAINER */
  .press-grid-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
    box-sizing: border-box;
  }

  .press-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 40px;
    align-items: stretch;
  }

  @media screen and (max-width: 768px) {
    .press-grid-container {
      padding: 0 !important;
      max-width: 100% !important;
      width: 100% !important;
    }

    .press-grid {
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
  }

  /* LEFT FEATURE CARD */
  .press-left {
    width: 100%;
  }

  .press-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    height: 100%;
    aspect-ratio: 840 / 975;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    box-sizing: border-box;
  }

  .press-card-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .press-card-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    object-position: center;
  }

  .press-card-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.65) 0%, rgba(0, 0, 0, 0.25) 50%, rgba(0, 0, 0, 0) 100%);
    z-index: 2;
  }

  .press-badge {
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 3;
    background: rgba(255, 255, 255, 0.17);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-radius: 100px;
    padding: 8px 18px;
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 500;
    font-size: 11px;
    line-height: 14px;
    color: #FFFFFF;
    box-sizing: border-box;
  }

  .press-content {
    position: relative;
    z-index: 3;
    padding: 40px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    box-sizing: border-box;
  }

  .press-title-text {
    font-family: 'Instrument Sans', sans-serif;
    font-style: normal;
    font-weight: 500;
    font-size: 28px;
    line-height: 1.25;
    color: #FFFFFF;
    margin: 0;
    max-width: 100%;
    white-space: normal;
  }

  .press-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 24px;
    background: #001755;
    color: #fff;
    border-radius: 100px;
    text-decoration: none;
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    font-size: 12px;
    line-height: 14px;
    text-transform: uppercase;
    transition: transform 0.2s, background-color 0.2s;
    box-sizing: border-box;
  }

  .press-btn:hover {
    background-color: #05247a;
    transform: translateY(-2px);
  }

  @media screen and (max-width: 768px) {
    .press-left {
      padding: 0 !important;
      box-sizing: border-box !important;
    }

    .press-card {
      width: auto !important;
      aspect-ratio: auto !important;
      height: 460px !important;
      margin: 0 27px !important;
    }

    .press-badge {
      top: 22px !important;
      left: 18px !important;
      padding: 6px 14px !important;
      font-size: 11px !important;
    }

    .press-content {
      padding: 27px !important;
      gap: 20px !important;
    }

    .press-title-text {
      font-size: 24px !important;
      line-height: 1.25 !important;
      max-width: 280px !important;
    }

    .press-btn {
      background: #1E1E1E !important;
      font-size: 11px !important;
      padding: 10px 20px !important;
    }

    .press-btn-icon-circle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.15);
      margin-left: 2px;
    }
  }

  /* RIGHT ITEMS COLUMN */
  .press-right {
    display: flex;
    flex-direction: column;
    gap: 24px;
    justify-content: space-between;
    height: 100%;
  }

  .press-item {
    background: #FFFFFF;
    border-radius: 20px;
    border: 1px solid rgba(0, 0, 0, 0.04);
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    box-sizing: border-box;
    text-decoration: none;
    color: inherit;
    min-height: 180px;
    flex: 1;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.01);
  }

  .press-item.clickable:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.06);
  }

  .press-item-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: flex-start;
  }

  .press-source-logo img {
    max-height: 28px;
    margin-bottom: 16px;
    object-fit: contain;
    object-position: left;
  }

  .press-source-text {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #001755;
  }

  .press-item-content p {
    font-size: 16px;
    line-height: 1.4;
    color: #001755;
    font-weight: 500;
    max-width: 85%;
    margin: 0;
  }

  .press-arrow {
    position: absolute;
    right: 32px;
    bottom: 32px;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #001755;
    border: 1.5px solid currentColor;
    border-radius: 50%;
    transition: transform 0.2s ease;
    box-sizing: border-box;
  }

  .press-arrow svg {
    width: 14px;
    height: 14px;
  }

  .press-arrow svg path {
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .press-item.clickable:hover .press-arrow {
    transform: scale(1.05);
  }

  @media screen and (max-width: 768px) {
    .press-right.mobile-press-slider {
      display: flex;
      flex-direction: row !important;
      overflow-x: auto;
      gap: 20px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 0 10px !important;
      width: 100% !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
      height: auto !important;
      margin-left:25px !important;
    }

    .press-right.mobile-press-slider::-webkit-scrollbar {
      display: none;
    }

    .press-right.mobile-press-slider .press-item {
      flex: 0 0 312px !important;
      width: 312px !important;
      height: 208px !important;
      border-radius: 20px !important;
      padding: 24px !important;
      margin-bottom: 0 !important;
      scroll-snap-align: start !important;
      box-sizing: border-box !important;
      min-height: auto !important;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02) !important;
    }

    .press-right.mobile-press-slider .press-item:first-child {
      margin-left: 27px !important;
    }

    .press-right.mobile-press-slider .press-item:last-child {
      margin-right: 27px !important;
    }

    .press-right.mobile-press-slider .press-source-logo img {
      max-height: 26px !important;
      margin-bottom: 14px !important;
    }

    .press-right.mobile-press-slider .press-item-content p {
      font-size: 14px !important;
      line-height: 1.4 !important;
      max-width: 90% !important;
    }

    .press-right.mobile-press-slider .press-arrow {
      right: 24px !important;
      bottom: 24px !important;
      width: 26px !important;
      height: 26px !important;
    }
  }

  /* SLIDER FOOTER CONTROL */
  .mobile-press-footer {
    display: none;
  }

  @media screen and (max-width: 768px) {
    .mobile-press-footer {
      display: flex !important;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 10px 27px 0 !important;
      box-sizing: border-box;
    }

    .mobile-press-count {
      font-family: 'Instrument Sans', sans-serif;
      font-weight: 500;
      font-size: 14px;
      line-height: 1.5;
      color: #FFFFFF;
      letter-spacing: 0.05em;
    }

    .mobile-press-dots {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .mobile-press-dots .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.35);
      transition: background-color 0.2s ease;
      cursor: pointer;
    }

    .mobile-press-dots .dot.active {
      background: #FFFFFF;
    }
  }

  /* MEDICAL ADVISORS SECTION */
  .medical-advisors {
    margin-top: 100px;
    box-sizing: border-box;
  }

  .advisor-top {
    display: flex;
    justify-content: space-between;
    gap: 60px;
    align-items: flex-start;
    margin-bottom: 50px;
  }

  .advisor-heading-text {
    color: #fff;
    font-size: 64px;
    line-height: 1.1;
    font-weight: 500;
    margin: 0;
    max-width: 600px;
    font-family: var(--sonu-font-primary);
  }

  .advisor-description {
    color: #fff;
    max-width: 520px;
    font-size: 18px;
    line-height: 1.6;
    opacity: 0.92;
  }

  .advisor-slider-wrapper {
    overflow-x: auto;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    width: 100%;
    box-sizing: border-box;
  }

  .advisor-slider-wrapper::-webkit-scrollbar {
    display: none;
  }

  .advisor-slider {
    display: flex;
    gap: 24px;
    width: max-content;
    padding-bottom: 10px;
  }

  .advisor-card {
    position: relative;
    width: 320px;
    height: 380px;
    border-radius: 18px;
    overflow: hidden;
    scroll-snap-align: start;
    box-sizing: border-box;
  }

  .advisor-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .advisor-card:hover img {
    transform: scale(1.05);
  }

  .advisor-plus {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    font-size: 20px;
    z-index: 2;
    font-weight: 300;
  }

  .advisor-info {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 22px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, transparent 100%);
    color: #fff;
    z-index: 2;
    box-sizing: border-box;
  }

  .advisor-info h4 {
    margin: 0 0 6px;
    font-size: 20px;
    font-weight: 500;
    color: #FFFFFF;
  }

  .advisor-info p {
    margin: 0;
    font-size: 14px;
    opacity: 0.85;
    line-height: 1.3;
  }

  @media screen and (max-width: 768px) {
    .medical-advisors {
      margin-top: 40px !important;
      padding: 0 27px !important;
    }

    .advisor-top {
      flex-direction: column;
      gap: 16px;
      margin-bottom: 30px;
    }

    .advisor-heading-text {
      font-size: 36px !important;
      line-height: 1.2 !important;
    }

    .advisor-description {
      font-size: 15px !important;
      line-height: 1.5 !important;
      max-width: 100% !important;
    }

    .advisor-slider-wrapper {
      margin: 0 -27px;
      padding: 0 27px;
      width: calc(100% + 54px);
    }

    .advisor-card {
      width: 250px !important;
      height: 300px !important;
    }

    .advisor-card img {
      height: 100% !important;
    }
  }
</style>

<section id="sonu-press-{{ section.id }}" class="press-feature">

  <!-- BACKGROUND -->
  <div class="press-bg">
    {% if section.settings.bg_image != blank %}
      <img
        src="{{ section.settings.bg_image | image_url: width: 2200 }}"
        alt=""
        width="{{ section.settings.bg_image.width }}"
        height="{{ section.settings.bg_image.height }}"
        loading="lazy"
      >
    {% endif %}
  </div>

  <div class="press-grid-container">

    <!-- PRESS GRID -->
    <div class="press-grid">

      <!-- LEFT FEATURE CARD -->
      <div class="press-left">
        <div class="press-card">
          <div class="press-card-bg">
            {% if section.settings.feature_image != blank %}
              <img
                src="{{ section.settings.feature_image | image_url: width: 1600 }}"
                alt=""
                width="{{ section.settings.feature_image.width }}"
                height="{{ section.settings.feature_image.height }}"
              >
            {% endif %}
          </div>

          {% if section.settings.badge != blank %}
            <div class="press-badge">
              {{ section.settings.badge }}
            </div>
          {% endif %}

          <div class="press-content sonu-blur-in">
            {%- assign title_tag = section.settings.title_tag | default: 'h3' -%}
            <{{ title_tag }} class="press-title-text">
              {{ section.settings.title }}
            </{{ title_tag }}>

            <a href="{{ section.settings.button_link }}" class="press-btn">
              {{ section.settings.button_text }}
              <span class="press-btn-icon-circle">
                <svg width="10" height="10" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3.5 10.5L10.5 3.5M10.5 3.5H5.25M10.5 3.5V8.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN ITEMS -->
      <div class="press-right {% if section.settings.mobile_press_layout == 'slider' %}mobile-press-slider{% endif %}">
        {% for block in section.blocks %}
          {% if block.type == 'press' %}
            {% assign is_link = false %}
            {% if block.settings.enable_link and block.settings.link != blank %}
              {% assign is_link = true %}
            {% endif %}

            {% if is_link %}
              <a href="{{ block.settings.link }}" class="press-item clickable">
            {% else %}
              <div class="press-item">
            {% endif %}

              <div class="press-item-content">
                {% if block.settings.source_logo != blank %}
                  <div class="press-source-logo">
                    <img
                      src="{{ block.settings.source_logo | image_url: width: 150 }}"
                      alt=""
                      width="{{ block.settings.source_logo.width }}"
                      height="{{ block.settings.source_logo.height }}"
                      loading="lazy"
                    >
                  </div>
                {% elsif block.settings.source != blank %}
                  <strong class="press-source-text">
                    {{ block.settings.source }}
                  </strong>
                {% endif %}

                <p>{{ block.settings.text }}</p>
              </div>

              {% if is_link %}
                <div class="press-arrow">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              {% endif %}

            {% if is_link %}
              </a>
            {% else %}
              </div>
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>

    </div>

    <!-- MOBILE SLIDER CONTROLS -->
    {% if section.settings.mobile_press_layout == 'slider' %}
      <div class="mobile-press-footer">
        <div class="mobile-press-count">
          {% assign press_count = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'press' %}
              {% assign press_count = press_count | plus: 1 %}
            {% endif %}
          {% endfor %}
          <span id="mobilePressCurrent-{{ section.id }}">1</span>/<span id="mobilePressTotal-{{ section.id }}">{{ press_count }}</span>
        </div>

        <div class="mobile-press-dots" id="mobilePressDots-{{ section.id }}">
          {% for block in section.blocks %}
            {% if block.type == 'press' %}
              <span class="dot {% if forloop.first %}active{% endif %}"></span>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

    <!-- MEDICAL ADVISORS -->
    {% if section.settings.enable_advisors %}
      <div class="medical-advisors">
        <div class="advisor-top">
          <div class="advisor-heading sonu-blur-in">
            {%- assign advisor_tag = section.settings.advisor_heading_tag | default: 'h2' -%}
            <{{ advisor_tag }} class="advisor-heading-text">
              {{ section.settings.advisor_heading }}
            </{{ advisor_tag }}>
          </div>

          <div class="advisor-description sonu-blur-in">
            {{ section.settings.advisor_description }}
          </div>
        </div>

        <!-- ADVISORS SLIDER -->
        <div class="advisor-slider-wrapper">
          <div class="advisor-slider" id="advisorSlider-{{ section.id }}">
            {% for block in section.blocks %}
              {% if block.type == 'advisor' %}
                <div class="advisor-card">
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 700 }}"
                      alt="{{ block.settings.name }}"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                      loading="lazy"
                    >
                  {% endif %}

                  <div class="advisor-plus">+</div>

                  <div class="advisor-info">
                    <h4>{{ block.settings.name }}</h4>
                    <p>{{ block.settings.designation }}</p>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

      </div>
    {% endif %}

  </div>

</section>

{% schema %}
{
  "name": "Press Feature Section",
  "settings": [
    {
      "type": "header",
      "content": "Section Layout & Spacing"
    },
    {
      "type": "range",
      "id": "margin_bottom_negative",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 40,
      "unit": "px",
      "label": "Negative Margin Bottom (Desktop)"
    },
    {
      "type": "range",
      "id": "margin_bottom_negative_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 35,
      "unit": "px",
      "label": "Negative Margin Bottom (Mobile)"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Padding Top (Desktop)"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Padding Bottom (Desktop)"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 80,
      "unit": "px",
      "label": "Padding Top (Mobile)"
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 80,
      "unit": "px",
      "label": "Padding Bottom (Mobile)"
    },
    {
      "type": "header",
      "content": "Border Radius Settings"
    },
    {
      "type": "range",
      "id": "bottom_border_radius",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0,
      "unit": "px",
      "label": "Bottom Border Radius (Desktop)"
    },
    {
      "type": "range",
      "id": "mobile_bottom_border_radius",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0,
      "unit": "px",
      "label": "Bottom Border Radius (Mobile)"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Feature Image"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Heading Tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h3"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Read More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
