          "blocks": {}
        },
        "product_1": {
          "type": "_products-bundle-product",
          "name": "t:names.product",
          "settings": {
            "product": "",
            "color_scheme": "",
            "offset_top": 40,
            "offset_left": 29,
            "offset_top_mobile": 40,
            "offset_left_mobile": 29
          },
          "blocks": {}
        },
        "product_2": {
          "type": "_products-bundle-product",
          "name": "t:names.product",
          "settings": {
            "product": "",
            "color_scheme": "",
            "offset_top": 62,
            "offset_left": 42,
            "offset_top_mobile": 62,
            "offset_left_mobile": 42
          },
          "blocks": {}
        },
        "product_3": {
          "type": "_products-bundle-product",
          "name": "t:names.product",
          "settings": {
            "product": "",
            "color_scheme": "",
            "offset_top": 49,
            "offset_left": 70,
            "offset_top_mobile": 49,
            "offset_left_mobile": 70
          },
          "blocks": {}
        }
      },
      "block_order": ["product_1", "product_2", "product_3"]
    }
  ]
}
