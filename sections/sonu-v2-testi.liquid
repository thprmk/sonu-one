    },
    {
      "type": "color",
      "id": "mobile_review_text_color",
      "label": "Mobile Review Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "mobile_review_font_size",
      "label": "Mobile Review Font Size (px)",
      "default": 14,
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_review_line_height",
      "label": "Mobile Review Line Height (px)",
      "default": 22,
      "min": 16,
      "max": 36,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "mobile_author_name_color",
      "label": "Mobile Author Name Color",
      "default": "#3D1B03"
    },
    {
      "type": "range",
      "id": "mobile_author_name_size",
