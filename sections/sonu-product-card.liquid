<style>

  /* FULL WIDTH OPTION */
.full-width-wrapper {
  width: 100%;
  max-width: 100%;
  padding-left: 0;
  padding-right: 0;
}

/* Optional container spacing when full width */
.full-width-wrapper .cards-grid {
  padding-left: 60px;
  padding-right: 60px;
}

@media (max-width: 768px) {
  .full-width-wrapper .cards-grid {
    padding-left: 20px;
    padding-right: 20px;
  }
}


/* DESKTOP */
.product-cards {
  padding: 10px 0 40px 0;
}


/* GRID */
.cards-grid {
  display: grid;
  gap: 20px;
}

.grid-2 { grid-template-columns: repeat(2, 1fr); }
.grid-3 { grid-template-columns: repeat(3, 1fr); }
.grid-4 { grid-template-columns: repeat(4, 1fr); }

/* CARD */
.card {
  display: flex;
  flex-direction: column;
}

/* IMAGE WRAP */
.card-image-wrap {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
}

/* IMAGE */
.card-bg {
  position: relative;
}

.card-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

/* HOVER EFFECT */
.card:hover .card-bg img {
  transform: scale(1.05);
}

/* OVERLAY GRADIENT */
.card-bg::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.6), rgba(0,0,0,0.1));
}

/* DESKTOP OVERLAY CONTENT */
.card-overlay-content {
  position: absolute;
  bottom: 50px;
  left: 50px;
  right: 50px;
  color: #fff;

  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20px;
}

.card-text {
  max-width: 63%;
}


/* TEXT */
.card-title {
  font-size: 32px;
  line-height: 1.2;
  margin:0px;
  font-family:'Instrument Sans';

}

.card-desc {
  margin-top: 5px;
  font-size: 14px;
  opacity: 0.9;
}

/* BUTTONS */
.card-buttons {
  margin-top: 15px;
  display: flex;
  gap: 10px;
  flex-shrink: 0;

}

.btn-outline {
  padding: 8px 16px;
  border: 1px solid #fff;
  border-radius: 20px;
  color: #fff;
  text-decoration: none;
  width: 80px;
  text-align: center;
}

.btn-fill {
  padding: 8px 16px;
  background: #fff;
  color: #000;
  border-radius: 20px;
  text-decoration: none;
  width: 80px;
  text-align: center;
}

/* =========================
   BLUR FADE ANIMATION
   ========================= */

.animate-blur {
  opacity: 0;
  filter: blur(10px);
  transform: translateY(20px);
  animation: blurFade 1s ease forwards;
}

.delay-1 { animation-delay: 0.2s; }
.delay-2 { animation-delay: 0.4s; }

@keyframes blurFade {
  to {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }
}

/* =========================
   MOBILE DESIGN
   ========================= */

.card-mobile-content {
  display: none;
}
/* MOBILE */
@media (max-width: 768px) {
  .product-cards {
    padding: 30px 20px 40px;
  }
}
@media (max-width: 768px) {

  .cards-grid {
    grid-template-columns: 1fr !important;
    gap: 40px;
  }

  .card-overlay-content {
    display: none;
  }

  .card-mobile-content {
    display: flex;
    flex-direction:column;
    justify-content: space-between;
    align-items: flex-start;
    margin-top: 12px;
    gap: 10px;
  }

  .mobile-text {
    flex: 1;
  }

  .card-mobile-content .card-title {
    font-size: 20px;
    color: #4A4741;
  }

  .card-mobile-content .card-desc {
    font-size: 13px;
    color: #555;
  }

  .mobile-btn {
    white-space: nowrap;
    padding: 0px;
    border-radius: 25px;
    background: #1E1E1E;
    color: #fff;
     align-content: space-evenly;
    height:40px;
  }
  .mobile-btn-outline{
  padding:0px;
    border: 1px solid #4A4741;
    border-radius: 20px;
    color: #1E1E1E;
    align-content: space-evenly;
    height:40px;
    text-decoration: none;
    width: 110px;
    max-width: 100%;
    text-align: center;
  }

  .product-cards{
  padding-left:20px;
  padding-right:20px;
}
}

@media screen and (max-width: 768px) {
  .product-cards {
    display: block;
  }
}
</style>
{% comment %}
  Premium Product Cards - Oura Style
{% endcomment %}

<section class="product-cards section">

 <div class="{% if section.settings.full_width %}full-width-wrapper{% else %}page-width{% endif %}">
    <div class="cards-grid grid-{{ section.settings.columns }}">

      {% for block in section.blocks %}
        <div class="card">

          <!-- IMAGE + OVERLAY -->
          <div class="card-image-wrap">
            
            <div class="card-bg">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 1500 }}" alt="">
              {% endif %}
            </div>

            <!-- DESKTOP CONTENT -->
        <div class="card-overlay-content">

  <div class="card-text">
    <h3 class="card-title animate-blur">
      {{ block.settings.title }}
    </h3>

    <p class="card-desc animate-blur delay-1">
      {{ block.settings.description }}
    </p>
  </div>

  <div class="card-buttons animate-blur delay-2">
    {% if block.settings.explore_text != blank %}
      <a href="{{ block.settings.explore_link }}" class="btn-outline">
        {{ block.settings.explore_text }}
      </a>
    {% endif %}

    {% if block.settings.shop_text != blank %}
      <a href="{{ block.settings.shop_link }}" class="btn-fill">
        {{ block.settings.shop_text }}
      </a>
    {% endif %}
  </div>

</div>
          </div>

          <!-- MOBILE CONTENT -->
          <div class="card-mobile-content">

            <div class="mobile-text">
              <h3 class="card-title">
                {{ block.settings.title }}
              </h3>

              <p class="card-desc">
                {{ block.settings.description }}
              </p>
            </div>

            {% comment %} {% if block.settings.shop_text != blank %}
              <a href="{{ block.settings.shop_link }}" class="btn-fill mobile-btn">
                {{ block.settings.shop_text }}
              </a>
            {% endif %} {% endcomment %}
             <div class="card-buttons animate-blur delay-2">
    {% if block.settings.explore_text != blank %}
      <a href="{{ block.settings.explore_link }}" class="btn-outline mobile-btn-outline">
        {{ block.settings.explore_text }}
      </a>
    {% endif %}

    {% if block.settings.shop_text != blank %}
      <a href="{{ block.settings.shop_link }}" class="btn-fill mobile-btn">
        {{ block.settings.shop_text }}
      </a>
    {% endif %}
  </div>

          </div>

        </div>
      {% endfor %}

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Product Cards ",
  "settings": [
    {
      "type": "select",
      "id": "columns",
      "label": "Cards per row",
      "options": [
        { "value": "2", "label": "2 per row" },
        { "value": "3", "label": "3 per row" },
        { "value": "4", "label": "4 per row" }
      ],
      "default": "2"
    }
    ,
{
  "type": "checkbox",
  "id": "full_width",
  "label": "Enable Full Width Layout",
  "default": false
}
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" },

        { "type": "text", "id": "explore_text", "label": "Explore Button", "default": "Explore" },
        { "type": "url", "id": "explore_link", "label": "Explore Link" },

        { "type": "text", "id": "shop_text", "label": "Shop Button", "default": "Shop" },
        { "type": "url", "id": "shop_link", "label": "Shop Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Cards",
      "blocks": [
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}