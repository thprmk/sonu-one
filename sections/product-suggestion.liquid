              "settings": {
                "label": "Eco-Friendly"
              },
              "blocks": {}
            },
            "product_suggestion_badge_WpzEch": {
              "type": "_product-suggestion-badge",
              "name": "t:names.badge",
              "settings": {
                "label": "Colorful"
              },
              "blocks": {}
            }
          },
          "block_order": ["product_suggestion_badge_U6YC6C", "product_suggestion_badge_WpzEch"]
        },
        "product_suggestion_3": {
          "type": "_product-suggestion",
          "name": "t:names.product_suggestion",
          "settings": {
            "title": "Add fun extras",
            "color_scheme": "scheme-2"
          },
          "blocks": {
            "product_suggestion_badge_EchTLq": {
              "type": "_product-suggestion-badge",
              "name": "t:names.badge",
              "settings": {
                "label": "Eco-Friendly"
              },
              "blocks": {}
            },
            "product_suggestion_badge_9fhprG": {
              "type": "_product-suggestion-badge",
              "name": "t:names.badge",
              "settings": {
                "label": "Colorful"
              },
              "blocks": {}
            }
          },
          "block_order": ["product_suggestion_badge_EchTLq", "product_suggestion_badge_9fhprG"]
        }
      },
      "block_order": ["product_suggestion_1", "product_suggestion_2", "product_suggestion_3"]
    }
  ]
}
{% endschema %}
