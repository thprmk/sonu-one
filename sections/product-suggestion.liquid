                "animation_type": "none",
                "animation_delay": 250
              },
              "blocks": {}
            }
          },
          "block_order": ["subheading", "heading"]
        },
        "product_suggestion_1": {
          "type": "_product-suggestion",
          "name": "t:names.product_suggestion",
          "settings": {
            "title": "Pick a top you love",
            "color_scheme": ""
          },
          "blocks": {
            "product_suggestion_badge_XWkTWT": {
              "type": "_product-suggestion-badge",
              "name": "t:names.badge",
              "settings": {
                "label": "Eco-Friendly"
              },
              "blocks": {}
            },
            "product_suggestion_badge_PUqQrJ": {
