{{ 'sonu-custom.css' | asset_url | stylesheet_tag }}

<section 
  id="doctor-section-{{ section.id }}"
  class="doctor-section 
  desktop-{{ section.settings.desktop_layout }} 
  mobile-{{ section.settings.mobile_layout }}"
>
  {% render 'sonu-section-header',
    heading: section.settings.heading,
    heading_tag: section.settings.heading_tag,
    heading_class: '',
    text_align: 'center',
    animate: true
  %}

  <div class="doctor-wrapper">

    {% for block in section.blocks %}
      {% assign words = block.settings.desc | split: ' ' %}
      {% assign trimmed = words | slice: 0, section.settings.trim_words | join: ' ' %}

      <div class="doctor-card">

        <!-- EXACT 244x270 IMAGE -->
        <div class="img-wrap">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.name }}" />
          {% else %}
            <div style="width: 100%; height: 100%; background: #ccc;"></div>
          {% endif %}

          <div class="overlay"></div>

          <div class="img-content">
            <h4>{{ block.settings.name }}</h4>
            <p>{{ block.settings.role }}</p>
          </div>

          <div class="card-arrow">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 5L15 11L9 17" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        <!-- INDENTED DESCRIPTION -->
        <p class="desc">{{ trimmed }}...</p>

        <!-- MODAL DATA (HIDDEN) -->
        <div class="modal-data" hidden>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.name }}">
          {% endif %}
          <h3>{{ block.settings.name }}</h3>
          <p class="role">{{ block.settings.role }}</p>
          <p>{{ block.settings.desc }}</p>
        </div>

      </div>
    {% endfor %}

  </div>

  {% if section.settings.mobile_layout == 'slider' or section.settings.desktop_layout == 'slider' %}
    <div class="team-slider-controls">
      <!-- PROGRESS BAR -->
      {% render 'sonu-progress-bar',
        progress_id: 'team-progress-bar-' | append: section.id,
        container_class: 'carousel-progress team-progress',
        bar_class: 'progress-bar-card team-progress-bar-card'
      %}

      <!-- ARROWS -->
      <div class="carousel-arrows team-arrows">
        {% render 'sonu-nav-arrows',
          prev_class: 'custom-arrow-btn carousel-prev team-prev-btn',
          next_class: 'custom-arrow-btn carousel-next team-next-btn'
        %}
      </div>
    </div>
  {% endif %}

  <!-- MODAL -->
  <div class="modal" id="sonu-modal-{{ section.id }}">
    <div class="modal-box">
      <span class="close sonu-close-{{ section.id }}">&times;</span>
      <div class="modal-inner">
        <div class="left"></div>
        <div class="right"></div>
      </div>
    </div>
  </div>

</section>






{% schema %}
{
  "name": "Team Section",
  "settings": [
    { "type": "text", "id": "heading", "default": "Trusted by doctors", "label": "Heading" },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading type",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "grad_color_1",
      "label": "Gradient Color 1 (Top)",
      "default": "#daf2ff"
    },
    {
      "type": "color",
      "id": "grad_color_2",
      "label": "Gradient Color 2",
      "default": "#eaf8ff"
    },
    {
      "type": "color",
      "id": "grad_color_3",
      "label": "Gradient Color 3",
      "default": "#f7fcff"
    },
    {
      "type": "color",
      "id": "grad_color_4",
      "label": "Gradient Color 4 (Bottom)",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "slider"
    },
    {
      "type": "range",
      "id": "trim_words",
      "min": 10,
      "max": 50,
      "step": 5,
      "default": 20,
      "label": "Trim words"
    }
  ],
  "blocks": [
    {
      "type": "doctor",
      "name": "Doctor",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "role", "label": "Profession" },
        { "type": "textarea", "id": "desc", "label": "Description" }
      ]
    }
  ],
  "presets": [
    { "name": "sonu Team Section" }
  ]
}
{% endschema %}

<script src="{{ 'doctors-testimonials.js' | asset_url }}" defer="defer"></script>
