<section class="science-bg-area">
<style>
  #shopify-section-{{ section.id }} .logo-section {
    {% if section.settings.bg_color_desktop_solid != blank and section.settings.bg_color_desktop_solid != 'transparent' %}
      background-color: {{ section.settings.bg_color_desktop_solid }};
      background-image: none;
    {% else %}
      background: {{ section.settings.bg_color_desktop | default: 'linear-gradient(90deg, #F2EDF4 0%, #EEF1FA 45%, #E8F2FF 100%)' }};
    {% endif %}
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .logo-section {
      {% if section.settings.bg_color_mobile_solid != blank and section.settings.bg_color_mobile_solid != 'transparent' %}
        background-color: {{ section.settings.bg_color_mobile_solid }};
        background-image: none;
      {% else %}
        background: {{ section.settings.bg_color_mobile | default: 'linear-gradient(90deg, #F2EDF4 0%, #EEF1FA 45%, #E8F2FF 100%)' }};
      {% endif %}
      {% if section.settings.bg_image != blank %}
        background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
      {% endif %}
    }
  }
</style>
<section class="logo-section section">

  {% render 'sonu-section-header',
    heading: section.settings.heading,
    heading_tag: section.settings.heading_tag,
    heading_class: 'logo-heading',
    subheading: section.settings.description,
    text_align: 'center',
    animate: true
  %}

  <!-- LOGOS -->
  <div class="logo-container animate-blur delay-3">

    <div class="logo-track" id="logoTrack-{{ section.id }}">

      {% for block in section.blocks %}
        <div class="logo-item">

          {% if block.settings.logo != blank %}
            <img
              src="{{ block.settings.logo | image_url: width: 300 }}"
              alt=""
              loading="lazy"
              width="{{ block.settings.logo.width }}"
              height="{{ block.settings.logo.height }}"
            >
          {% endif %}

        </div>
      {% endfor %}

    </div>

  </div>

  <!-- CTA BUTTON -->
  {% if section.settings.button_text != blank %}
    <div class="logo-button-wrap">

      <a href="{{ section.settings.button_link }}"
         class="logo-btn"
         style="
           background: {{ section.settings.button_bg }};
           color: {{ section.settings.button_text_color }};
         ">
        {{ section.settings.button_text }}
      </a>

    </div>
  {% endif %}

</section>
</section>
{{ 'sonu-custom.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Logo Carousel",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color_background",
      "id": "bg_color_desktop",
      "label": "Desktop Background (Gradient)",
      "default": "linear-gradient(90deg, #F2EDF4 0%, #EEF1FA 45%, #E8F2FF 100%)"
    },
    {
      "type": "color",
      "id": "bg_color_desktop_solid",
      "label": "Desktop Background (Solid Color)",
      "default": "transparent"
    },
    {
      "type": "color_background",
      "id": "bg_color_mobile",
      "label": "Mobile Background (Gradient)",
      "default": "linear-gradient(90deg, #F2EDF4 0%, #EEF1FA 45%, #E8F2FF 100%)"
    },
    {
      "type": "color",
      "id": "bg_color_mobile_solid",
      "label": "Mobile Background (Solid Color)",
      "default": "transparent"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Partners"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading type",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#001755"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo Carousel"
    }
  ]
}
{% endschema %}
<script src="{{ 'sonu-logo-list.js' | asset_url }}" defer="defer"></script>