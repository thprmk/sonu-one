{% comment %}
  SONU Specifications Section 
{% endcomment %}

<section class="sonu-specs-section specs-id-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
    {% if section.settings.bg_image != blank %}
      background-image:url('{{ section.settings.bg_image | image_url: width: 2400 }}');
    {% endif %}
  ">

  <div class="page-width">

    <div class="specs-main-grid">

      <div class="specs-media-col animate-blur-spec">
        {% if section.settings.left_image != blank %}
          <img
            src="{{ section.settings.left_image | image_url: width: 1800 }}"
            alt="{{ section.settings.heading | escape }}"
            class="specs-display-img"
            loading="lazy"
          >
        {% endif %}
      </div>

      <div class="specs-content-col">

        {% if section.settings.heading != blank %}
          {% assign formatted_heading = section.settings.heading
            | replace: '[[', '<span class="specs-highlight">'
            | replace: ']]', '</span>'
            | newline_to_br
          %}
          <h2 class="specs-main-title animate-blur-spec delay-spec-1">
            {{ formatted_heading }}
          </h2>
        {% endif %}

        <div class="specs-features-grid">
          {% for block in section.blocks %}
            <div class="specs-feature-item animate-blur-spec delay-spec-{{ forloop.index }}">

              <div class="specs-item-header">
                {% if block.settings.icon_svg != blank or block.settings.icon_image != blank %}
                  <div class="specs-icon-wrapper">
                    {% if block.settings.icon_svg != blank %}
                      {{ block.settings.icon_svg }}
                    {% elsif block.settings.icon_image != blank %}
                      <img
                        src="{{ block.settings.icon_image | image_url: width: 100 }}"
                        alt=""
                        loading="lazy"
                      >
                    {% endif %}
                  </div>
                {% endif %}

                <h3 class="specs-item-title">
                  {{ block.settings.heading }}
                </h3>
              </div>

              <div class="specs-item-body">
                {{ block.settings.text }}
              </div>

            </div>
          {% endfor %}
        </div>

      </div>

    </div>

    {% if section.settings.note_text != blank %}
      <div class="specs-bottom-note">
        {{ section.settings.note_text }}
      </div>
    {% endif %}

  </div>

</section>

<style>
/* ==========================================================================
   GLOBAL LAYOUT AND STRUCTURE
   ========================================================================== */
.sonu-specs-section {
  position: relative;
  padding: 90px 0;
  background-size: cover !important;
  background-position: center;
  background-repeat: no-repeat !important;
  border-radius: 0px 0px 100px 100px;
  overflow: hidden;
}

.sonu-specs-section::before {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});
  z-index: 1;
}

.sonu-specs-section .page-width {
  position: relative;
  z-index: 2;
}

.specs-main-grid {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 80px;
  align-items: start;
}

/* ==========================================================================
   MEDIA / LEFT COLUMN
   ========================================================================== */
.specs-media-col {
  position: relative;
}

.specs-display-img {
  width: 100%;
  display: block;
  height: auto;
  object-fit: contain;
}

/* ==========================================================================
   CONTENT / RIGHT COLUMN
   ========================================================================== */
.specs-content-col {
  color: {{ section.settings.text_color }};
}

.specs-main-title {
  font-size: 56px;
  line-height: 1.08;
  letter-spacing: -2px;
  font-weight: 400;
  margin-bottom: 50px;
}

.specs-main-title .specs-highlight {
  font-family: "Times New Roman", serif;
  font-style: italic;
}

/* ==========================================================================
   DASHBOARD GRID MATRIX
   ========================================================================== */
.specs-features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 40px 50px;
}

.specs-feature-item {
  position: relative;
}

.specs-item-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 18px;
}

.specs-icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 22px;
  height: 22px;
  flex-shrink: 0;
}

.specs-icon-wrapper svg {
  width: 22px;
  height: 22px;
  fill: currentColor;
}

.specs-icon-wrapper img {
  width: 22px;
  height: 22px;
  object-fit: contain;
}

.specs-item-title {
  font-size: 26px;
  line-height: 1.3;
  font-weight: 400;
  margin: 0;
}

.specs-item-body {
  font-size: 18px;
  line-height: 1.8;
  opacity: .88;
}

.specs-item-body ul {
  margin: 0;
  padding-left: 18px;
}

.specs-item-body li {
  margin-bottom: 8px;
}

.specs-bottom-note {
  grid-column: 1;
  margin-top: 24px;
  color: #fff;
  font-size: 14px;
  line-height: 1.7;
  opacity: .85;
  max-width: 520px;
}

/* ==========================================================================
   ENTRANCE BLUR ANIME INTERFACES
   ========================================================================== */
.animate-blur-spec {
  opacity: 0;
  filter: blur(10px);
  transform: translateY(20px);
  animation: blurFadeSpec 1s ease forwards;
}

.delay-spec-1 { animation-delay: .1s; }
.delay-spec-2 { animation-delay: .2s; }
.delay-spec-3 { animation-delay: .3s; }
.delay-spec-4 { animation-delay: .4s; }
.delay-spec-5 { animation-delay: .5s; }
.delay-spec-6 { animation-delay: .6s; }

@keyframes blurFadeSpec {
  to {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }
}

/* ==========================================================================
   TABLET BREAKPOINT LAYOUTS
   ========================================================================== */
@media(max-width: 1100px){
  .specs-main-grid {
    grid-template-columns: 1fr;
    gap: 50px;
  }
  .specs-media-col {
    max-width: 720px;
    margin: 0 auto;
  }
}

/* ==========================================================================
   MOBILE BREAKPOINT LAYOUTS
   ========================================================================== */
@media(max-width: 768px){
  .sonu-specs-section {
    padding: 70px 0;
    border-radius: 0px;
  }

  {% if section.settings.mobile_bg_image != blank %}
  .specs-id-{{ section.id }} {
    background-image:url('{{ section.settings.mobile_bg_image | image_url: width: 1200 }}') !important;
  }
  {% endif %}

  .specs-main-grid {
    gap: 40px;
  }

  .specs-main-title {
    font-size: 36px;
    text-align: center;
    letter-spacing: -1px;
    margin-bottom: 36px;
  }

  .specs-features-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .specs-item-title {
    font-size: 18px;
  }

  .specs-item-body {
    font-size: 15px;
    line-height: 1.7;
  }

  .specs-bottom-note {
    grid-column: 1 / -1;
    margin-top: 40px !important;
    text-align: left;
    font-size: 12px;
    max-width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "SONU Specifications",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading (Use [[text]] for serif italic)",
      "default": "Tech Specifications"
    },
    {
      "type": "textarea",
      "id": "note_text",
      "label": "Bottom Note"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Image"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg_image",
      "label": "Mobile Background Image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#4a235e"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 20
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Specification",
      "settings": [
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "SVG Icon Code"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "What's Included"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SONU Specifications",
      "blocks": [
        { "type": "spec" },
        { "type": "spec" },
        { "type": "spec" },
        { "type": "spec" }
      ]
    }
  ]
}
{% endschema %}