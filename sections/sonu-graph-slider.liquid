</style>

<script>
document.addEventListener("DOMContentLoaded", function(){

  const slider =
    document.getElementById("researchSlider-{{ section.id }}");

  if(!slider) return;

  const prevBtn =
    slider.parentElement.parentElement.querySelector(".prev");

  const nextBtn =
    slider.parentElement.parentElement.querySelector(".next");

  const progressFill =
    slider.parentElement.parentElement.querySelector(".research-progress-fill");

  /* UPDATE PROGRESS */
/* UPDATE PROGRESS */
function updateProgress(){

  const maxScroll =
    slider.scrollWidth - slider.clientWidth;

  if(maxScroll <= 0){
    progressFill.style.width = "100%";
    progressFill.style.transform = "translateX(0)";
    return;
  }

  /* CURRENT PROGRESS */
  const progress =
    slider.scrollLeft / maxScroll;

  /* VISIBLE WIDTH */
  const visibleWidth =
    slider.clientWidth / slider.scrollWidth;

  /* FINAL WIDTH */
  const fillWidth =
    visibleWidth + (1 - visibleWidth) * progress;

  progressFill.style.width =
    `${fillWidth * 100}%`;

}

  updateProgress();

  slider.addEventListener("scroll", updateProgress);

  /* SLIDE AMOUNT */
  function getSlideAmount(){

    if(window.innerWidth <= 768){
      return slider.clientWidth * 0.9;
    }

    return slider.clientWidth * 0.48;

  }

  /* NEXT */
  nextBtn.addEventListener("click", function(){

    slider.scrollBy({
      left:getSlideAmount(),
      behavior:"smooth"
    });

  });

  /* PREV */
  prevBtn.addEventListener("click", function(){

    slider.scrollBy({
      left:-getSlideAmount(),
      behavior:"smooth"
    });

  });

});
</script>

{% schema %}
{
  "name": "Graph Slider",
  "settings": [

   

    {
      "type":"textarea",
      "id":"description",
      "label":"Description"
    },

    {
      "type":"color",
      "id":"bg_color",
      "label":"Background Color",
      "default":"#f4f1ee"
    },

    {
      "type":"color",
      "id":"heading_color",
      "label":"Heading Color",
      "default":"#3d1d12"
    },

    {
      "type":"color",
      "id":"text_color",
      "label":"Text Color",
      "default":"#3d1d12"
    },

    {
      "type":"color",
      "id":"card_heading_color",
      "label":"Card Heading Color",
      "default":"#3d1d12"
    },

    {
      "type":"text",
      "id":"button_text",
      "label":"Button Text",
      "default":"Learn More"
    },

    {
      "type":"url",
      "id":"button_link",
      "label":"Button Link"
    },

    {
      "type":"color",
      "id":"button_bg",
      "label":"Button Background",
      "default":"#000000"
    },

    {
      "type":"color",
      "id":"button_text_color",
      "label":"Button Text Color",
      "default":"#ffffff"
    }

  ],

  "blocks":[

    {
      "type":"graph",
      "name":"Graph Card",
      "settings":[

        {
          "type":"text",
          "id":"heading",
          "label":"Heading",
          "default":"Reduction in Nasal Congestion"
        },

        {
          "type":"image_picker",
          "id":"graph_image",
          "label":"Graph Image"
        }

      ]
    }

  ],

  "presets":[
    {
      "name":"Graph Slider"
    }
  ]
}
{% endschema %}