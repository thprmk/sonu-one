<style>

  /* =========================
   FONT IMPORT
========================= */
@import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&display=swap');

/* =========================
   COMPARISON SECTION
========================= */

.comparison-section{
  position:relative;
  background:#fff;
  overflow:hidden;
}

/* Gradient Overlay */
.comparison-section::before{
  content:"";
  position:absolute;
  left:0;
  right:0;
  top:0;
  height:369px;
  background:linear-gradient(
    180deg,
    rgba(255,255,255,0) 0%,
    #FFFFFF 100%
  );
  pointer-events:none;
}

/* =========================
   ROW LABELS
========================= */

.comparison-label{
  font-family:'Instrument Sans',sans-serif;
  font-style:normal;
  font-weight:600;
  font-size:14px;
  line-height:17px;
  color:#3D1B03;
  margin:0;
}

/* =========================
   COLUMN BOXES
========================= */

.comparison-column{
  width:101px;
  border-radius:10px;
}

.comparison-column--sonu{
  background:#CEC4BC;
}

.comparison-column--steroids{
  border:1px solid rgba(74,71,65,.5);
  background:#fff;
}

/* =========================
   COLUMN HEADINGS
========================= */

.comparison-column-title{
  font-family:'Instrument Sans',sans-serif;
  font-style:normal;
  font-weight:600;
  font-size:14px;
  line-height:17px;
  color:#3D1B03;
  text-align:center;
}

.comparison-column-title.small{
  max-width:66px;
  margin:auto;
}

/* =========================
   ICONS
========================= */

.comparison-icon{
  width:18px;
  height:18px;
  display:flex;
  align-items:center;
  justify-content:center;
}

.comparison-icon svg{
  width:18px;
  height:18px;
  stroke:#1E1E1E;
}

/* =========================
   BOTTOM VALUES
========================= */

.comparison-value{
  font-family:'Instrument Sans',sans-serif;
  font-style:normal;
  font-weight:400;
  font-size:12px;
  line-height:18px;
  text-align:center;
  color:#1E1E1E;
}

/* =========================
   ARROWS
========================= */

.comparison-arrows{
  display:flex;
  gap:16px;
}

.comparison-arrow{
  width:36px;
  height:36px;
  border-radius:50%;
  border:1px solid #4A4741;
  background:#fff;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
}

.comparison-arrow svg{
  width:16px;
  height:16px;
  stroke:#4A4741;
}

/* =========================
   SCIENCE CONTENT
========================= */

.science-content{
  margin-top:80px;
}

.science-heading{
  font-family:'Instrument Sans',sans-serif;
  font-style:normal;
  font-weight:400;
  font-size:32px;
  line-height:39px;
  color:#3D1B03;
  margin:0 0 24px;
}

.science-description{
  font-family:'Instrument Sans',sans-serif;
  font-style:normal;
  font-weight:400;
  font-size:14px;
  line-height:22px;
  color:#1E1E1E;
  margin:0;
}

/* =========================
   MOBILE
========================= */

@media (max-width:768px){

  .comparison-label{
    font-size:14px;
    line-height:17px;
  }

  .comparison-column-title{
    font-size:14px;
    line-height:17px;
  }

  .comparison-value{
    font-size:12px;
    line-height:18px;
  }

  .science-heading{
    font-size:32px;
    line-height:39px;
    font-weight:400;
  }

  .science-description{
    font-size:14px;
    line-height:22px;
  }

}



/* FORCE FIGMA TYPOGRAPHY */

.sleep-layout,
.sleep-layout *{
  font-family: 'Instrument Sans', sans-serif !important;
}

/* Backed by Science. Trusted by Doctors. */
.publication-title{
  font-family: 'Instrument Sans', sans-serif !important;
  font-weight: 400 !important;
  font-size: 32px !important;
  line-height: 39px !important;
  color: #3D1B03 !important;
  letter-spacing: 0 !important;
}

/* Description */
.publication-text{
  font-family: 'Instrument Sans', sans-serif !important;
  font-weight: 400 !important;
  font-size: 14px !important;
  line-height: 22px !important;
  color: #1E1E1E !important;
}

/* Clinically Proven, Side Effects, etc */
.feature-label h3{
  font-family: 'Instrument Sans', sans-serif !important;
  font-weight: 600 !important;
  font-size: 14px !important;
  line-height: 17px !important;
  color: #3D1B03 !important;
}

/* SONU Band & Intranasal Steroids */
.featured-header h2,
.compare-header h2{
  font-family: 'Instrument Sans', sans-serif !important;
  font-weight: 600 !important;
  font-size: 14px !important;
  line-height: 17px !important;
  color: #3D1B03 !important;
}

/* Minutes / Days */
.featured-text,
.compare-text{
  font-family: 'Instrument Sans', sans-serif !important;
  font-weight: 400 !important;
  font-size: 12px !important;
  line-height: 18px !important;
  color: #1E1E1E !important;
}
</style>

{%- liquid
  assign use_padding_inline = true
  if section.settings.container == 'fixed'
    assign use_padding_inline = false
  endif
-%}

{%- capture section_style -%}
  {% render 'border-style', settings: section.settings %}
  {% render 'spacing-style', settings: section.settings, use_padding_inline: use_padding_inline %}
{%- endcapture -%}

<div
  class="section custom-liquid-section spacing-style border-style color-{{ section.settings.color_scheme }}"
  style="{{ section_style | strip_newlines | strip }}"
>
  <div class="section__container section-grid section-grid--{{ section.settings.container }}">
    <div class="section__content">
      {{ section.settings.custom_liquid }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:names.custom_liquid",
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "t:settings.liquid_code",
      "info": "t:info.custom_liquid"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "container",
      "label": "t:settings.container",
      "options": [
        { "value": "full", "label": "t:options.full" },
        { "value": "fixed", "label": "t:options.fixed" }
      ],
      "default": "fixed"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.borders",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "label": "t:settings.border_width",
      "default": 1,
      "visible_if": "{{ section.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.border_opacity",
      "default": 100,
      "visible_if": "{{ section.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "select",
      "id": "device",
      "label": "t:settings.devices",
      "options": [
        {
          "value": "desktop",
          "label": "t:options.desktop"
        },
        {
          "value": "mobile",
          "label": "t:options.mobile"
        }
      ],
      "default": "desktop"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 50,
      "visible_if": "{{ section.settings.device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 50,
      "visible_if": "{{ section.settings.device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.device == 'desktop' and section.settings.container == 'full' }}"
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.device == 'desktop' and section.settings.container == 'full' }}"
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48,
      "visible_if": "{{ section.settings.device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48,
      "visible_if": "{{ section.settings.device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "padding-inline-start-mobile",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.device == 'mobile' and section.settings.container == 'full' }}"
    },
    {
      "type": "range",
      "id": "padding-inline-end-mobile",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.device == 'mobile' and section.settings.container == 'full' }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.custom_liquid",
      "category": "t:categories.custom"
    }
  ]
}
{% endschema %}
