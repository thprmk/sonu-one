  height:68px;
  border-radius:0;
  overflow:hidden;
  border:2px solid transparent;
  cursor:pointer;
}

.thumbnail-item.active{
  border-color:#112a73;
}

.thumbnail-item img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* =========================
   PRODUCT INFO
========================= */

.product-info{
  padding-top:40px;
}

.product-title{
  font-size:40px;
  line-height:1.05;
  font-weight:100;
  color:#112a73;
  margin-bottom:24px;
}

.product-description{
  max-width:520px;
  font-size:16px;
  line-height:1.7;
  color:#444;
  margin-bottom:30px;
}

.product-description p{
  margin:0;
}

.product-price{
  margin-bottom:8px;
}

.current-price{
  font-size:40px;
  font-weight:400;
  color:#112a73;
}

.compare-price{
  font-size:24px;
  color:#999;
}

/* =========================
   FSA HSA
========================= */

.fsa-hsa-info{
  margin-bottom:34px;
}

.fsa-badge{
  background:none;
  padding:0;
  color:#000;
  font-size:14px;
  font-weight:400;
}

/* =========================
   OPTIONS
========================= */

.options-row{
  display:flex;
  align-items:flex-end;
  gap:40px;
  margin-bottom:34px;
}

.option-label{
  font-size:13px;
  color:#000;
  font-weight:400;
  text-transform:none;
  letter-spacing:0;
  margin-bottom:10px;
}

.color-swatches{
  gap:10px;
}

.swatch-color{
  width:38px;
  height:38px;
  border-radius:50%;
}

.color-swatch.active .swatch-color{
  box-shadow:
  0 0 0 2px #6c4db7,
  0 0 0 4px #fff;
}

/* =========================
   QUANTITY
========================= */

.quantity-selector{
  border:1px solid #d7dbe7;
  border-radius:4px;
  height:42px;
  background:#fff;
  padding:0;
}

.quantity-btn{
  width:38px;
  height:40px;
  font-size:18px;
  color:#6b7280;
}

.quantity-number{
  width:10px;
  font-size:15px;
  color:#111827;
}

/* =========================
   STOCK
========================= */

.stock-status{
  margin-bottom:34px;
}

.in-stock{
  color:#000;
  font-size:14px;
  display:flex;
  align-items:center;
  gap:8px;
}

.in-stock::before{
  content:'';
  width:8px;
  height:8px;
  border-radius:50%;
  background:#7fb23a;
}

.out-of-stock{
  color:#e53935;
}

/* =========================
   BUTTONS
========================= */

.action-buttons{
  display:flex;
  gap:14px;
}

.btn{
  height:54px;
  border-radius:999px;
  font-size:14px;
  font-weight:700;
  min-width:240px;
}

.btn-primary{
  background:#001755;
  border:1px solid #001755;
  color:#fff;
}

.btn-primary:hover{
  background:#0d2058;
  border-color:#0d2058;
}

.btn-secondary{
  background:#fff;
  border:1px solid #112a73;
  color:#112a73;
}

.btn-secondary:hover{
  background:#f7f8fc;
}

/* =========================
   FEATURES
========================= */

.features-list{
  display:none;
}

/* =========================
   RESPONSIVE
========================= */

