<style>
  #shopify-section-{{ section.id }} .v2-testimonial-video-section {
    {%- if section.settings.section_bg_gradient != blank -%}
      background: {{ section.settings.section_bg_gradient }} !important;
    {%- else -%}
      background-color: {{ section.settings.section_bg_color | default: 'transparent' }} !important;
      background-image: none !important;
    {%- endif -%}
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
    {%- if section.settings.section_bg_image != blank -%}
      background-image: url('{{ section.settings.section_bg_image | image_url: width: 2000 }}') !important;
      background-size: cover !important;
      background-position: center !important;
      background-repeat: no-repeat !important;
    {%- endif -%}
  }
  
  #shopify-section-{{ section.id }} .v2-section-title {
    margin-bottom: {{ section.settings.desktop_heading_margin_bottom }}px !important;
  }
  
  #shopify-section-{{ section.id }} .v2-review-card {
    background: {{ section.settings.card_bg_color }} !important;
    border-color: {{ section.settings.card_border_color }} !important;
    border-width: {{ section.settings.card_border_width }}px !important;
    border-style: solid !important;
    border-radius: {{ section.settings.card_border_radius }}px !important;
    padding: {{ section.settings.card_padding }}px !important;
  }
  
  #shopify-section-{{ section.id }} .v2-review-text {
    color: {{ section.settings.desktop_review_text_color }} !important;
  }
  
  #shopify-section-{{ section.id }} .v2-review-author h6 {
    color: {{ section.settings.desktop_author_name_color }} !important;
  }
  
  #shopify-section-{{ section.id }} .v2-review-author span {
    color: {{ section.settings.desktop_author_role_color }} !important;
  }
  
  #shopify-section-{{ section.id }} .v2-desktop-rating-stars-row {
    color: {{ section.settings.star_color }} !important;
    display: flex;
    gap: 4px;
    margin-top: 12px;
  }
  
  #shopify-section-{{ section.id }} .v2-desktop-rating-stars-row svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }
  
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .v2-testimonial-video-section {
      padding-top: {{ section.settings.mobile_padding_top }}px !important;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px !important;
      {%- if section.settings.section_bg_image_mobile != blank -%}
        background-image: url('{{ section.settings.section_bg_image_mobile | image_url: width: 1000 }}') !important;
        background-size: cover !important;
        background-position: center !important;
        background-repeat: no-repeat !important;
      {%- elsif section.settings.section_bg_image != blank -%}
        background-image: url('{{ section.settings.section_bg_image | image_url: width: 1000 }}') !important;
        background-size: cover !important;
        background-position: center !important;
        background-repeat: no-repeat !important;
      {%- else -%}
        background-image: none !important;
      {%- endif -%}
    }
    
    #shopify-section-{{ section.id }} .v2-section-title {
      margin-bottom: {{ section.settings.mobile_heading_margin_bottom }}px !important;
    }
    
    #shopify-section-{{ section.id }} .v2-mobile-review-card {
      background: {{ section.settings.mobile_card_bg_color }} !important;
      border-color: {{ section.settings.mobile_card_border_color }} !important;
      border-radius: {{ section.settings.mobile_card_border_radius }}px !important;
      padding: {{ section.settings.mobile_card_padding }}px !important;
    }
    
    #shopify-section-{{ section.id }} .v2-mobile-review-quote {
      color: {{ section.settings.mobile_review_text_color }} !important;
    }
    
    #shopify-section-{{ section.id }} .v2-mobile-author-name {
      color: {{ section.settings.mobile_author_name_color }} !important;
    }
    
    #shopify-section-{{ section.id }} .v2-mobile-author-role {
      color: {{ section.settings.mobile_author_role_color }} !important;
    }
    
    #shopify-section-{{ section.id }} .v2-mobile-rating-stars-row {
      color: {{ section.settings.star_color }} !important;
    }
  }
</style>

<section class="v2-testimonial-video-section {% if section.settings.full_width %}v2-full-width{% else %}v2-contained{% endif %}">
  <div class="v2-page-width">
    {%- capture heading_style -%}color: {{ section.settings.heading_color }};{%- endcapture -%}
    {%- assign heading_class_with_tag = 'v2-section-title ' | append: section.settings.heading_tag | default: 'h2' -%}
    {% render 'sonu-section-header',
      heading: section.settings.heading,
      heading_tag: section.settings.heading_tag,
      heading_class: heading_class_with_tag,
      heading_style: heading_style,
      text_align: 'center',
      animate: true
    %}

    <div class="v2-desktop-layout">
      <div class="v2-desktop-dual-slider">
        <div class="v2-desktop-reviews-container">
          <div class="swiper v2-reviews-swiper" id="v2-reviewsSwiperDesktop">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                <div class="swiper-slide">
                  <div class="v2-review-grid v2-offset-grid">
                    {% for i in (1..4) %}
                      {% assign review_key = 'review_' | append: i %}
                      {% assign name_key = 'name_' | append: i %}
                      {% assign role_key = 'role_' | append: i %}
                      {% if block.settings[review_key] != blank %}
                        <div class="v2-review-card v2-review-card-{{ i }}">
                          <div class="v2-review-text rte">
                            {{ block.settings[review_key] }}
                          </div>
                          <div class="v2-review-author">
                            <h4>{{ block.settings[name_key] }}</h4>
                            <span>{{ block.settings[role_key] }}</span>
                          </div>
                          <div class="v2-desktop-rating-stars-row">
                            {%- for j in (1..5) -%}
                              <svg viewBox="0 0 15 15" xmlns="http://www.w3.org/2000/svg">
                                <path d="M7.415 0L9.58 4.793L14.83 5.174L10.806 8.572L12.062 13.682L7.415 10.913L2.768 13.682L4.024 8.572L0 5.174L5.25 4.793L7.415 0Z" fill="currentColor"/>
                              </svg>
                            {%- endfor -%}
                          </div>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
            <div class="v2-reviews-pagination swiper-pagination"></div>
          </div>
        </div>

        <div class="v2-desktop-video-container">
          <div class="v2-desktop-video-swiper-wrapper">
            <div class="swiper v2-video-swiper" id="v2-videoSwiperDesktop">
              <div class="swiper-wrapper">
                {% for block in section.blocks %}
                  <div class="swiper-slide v2-video-slide">
                    <div class="v2-video-wrapper-desktop">
                      {{ block.settings.video | video_tag: autoplay: true, muted: true, loop: true, controls: false, playsinline: true }}
                      {% if block.settings.video_overlay_image != blank %}
                        <div class="v2-video-overlay-badge">
                          <img src="{{ block.settings.video_overlay_image | img_url: '300x' }}" alt="Product Box Overlay" loading="lazy">
                        </div>
                      {% endif %}
                    </div>
                  </div>
                {% endfor %}
              </div>
            </div>
            <div class="swiper-button-prev v2-desktop-video-prev"></div>
            <div class="swiper-button-next v2-desktop-video-next"></div>
          </div>
        </div>
      </div>
    </div>

    {%- assign total_slides_count = 0 -%}
    {%- for block in section.blocks -%}
      {%- for i in (1..4) -%}
        {%- assign review_key = 'review_' | append: i -%}
        {%- if block.settings[review_key] != blank -%}
          {%- assign total_slides_count = total_slides_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}

    <div class="v2-mobile-layout">
      <div class="v2-mobile-testimonial-container" id="v2-mobile-testimonial-container-{{ section.id }}">
        <div class="v2-mobile-testimonial-track">
          {%- assign slide_counter = 0 -%}
          {%- for block in section.blocks -%}
            {%- for i in (1..4) -%}
              {%- assign review_key = 'review_' | append: i -%}
              {%- assign name_key = 'name_' | append: i -%}
              {%- assign role_key = 'role_' | append: i -%}
              {%- if block.settings[review_key] != blank -%}
                <div class="v2-mobile-testimonial-slide" data-index="{{ slide_counter }}" {{ block.shopify_attributes }}>
                  <div class="v2-mobile-media-panel">
                    <div class="v2-mobile-video-wrapper">
                      {%- if block.settings.video != blank -%}
                        {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
                        {%- if block.settings.video_overlay_image != blank -%}
                          <div class="v2-video-overlay-badge mobile-overlay">
                            <img src="{{ block.settings.video_overlay_image | img_url: '200x' }}" alt="Product Box Overlay" loading="lazy">
                          </div>
                        {%- endif -%}
                      {%- else -%}
                        <div style="width: 100%; height: 100%; background: #eaeaea; display: flex; align-items: center; justify-content: center; font-family: sans-serif; color: #999; line-height: normal; padding: 20px; text-align: center;">
                          Upload Video Asset
                        </div>
                      {%- endif -%}
                    </div>
                  </div>

                  <div class="v2-mobile-content-panel">
                    <div class="v2-mobile-review-card">
                      <div class="v2-mobile-review-quote rte">
                        “{{ block.settings[review_key] | replace: '"', '' | replace: '“', '' | replace: '”', '' }}”
                      </div>

                      <h4 class="v2-mobile-author-name h4">
                        {{ block.settings[name_key] | escape }}
                      </h4>

                      <div class="v2-mobile-author-role">
                        {{ block.settings[role_key] | escape }}
                      </div>

                      <div class="v2-mobile-rating-stars-row">
                        {%- for j in (1..5) -%}
                          <svg viewBox="0 0 15 15" xmlns="http://www.w3.org/2000/svg">
                            <path d="M7.415 0L9.58 4.793L14.83 5.174L10.806 8.572L12.062 13.682L7.415 10.913L2.768 13.682L4.024 8.572L0 5.174L5.25 4.793L7.415 0Z" fill="currentColor"/>
                          </svg>
                        {%- endfor -%}
                      </div>
                    </div>
                  </div>
                </div>
                {%- assign slide_counter = slide_counter | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endfor -%}
        </div>

        {%- if total_slides_count > 1 -%}
          <div class="v2-mobile-indicator-bar">
            <span class="v2-mobile-counter-label">
              <span class="v2-mobile-current-index">1</span> / {{ total_slides_count }}
            </span>
            <div class="v2-mobile-indicator-line-track">
              <div class="v2-mobile-indicator-line-fill"></div>
            </div>
            <div class="v2-mobile-nav-arrows">
              <button class="v2-mobile-nav-arrow v2-mobile-prev-slide" aria-label="Previous Slide">
                <svg width="10" height="16" viewBox="0 0 10 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 2L2 8L8 14" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
                </svg>
              </button>
              <button class="v2-mobile-nav-arrow v2-mobile-next-slide" aria-label="Next Slide">
                <svg width="10" height="16" viewBox="0 0 10 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2 2L8 8L2 14" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
                </svg>
              </button>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{{ 'sonu-custom.css' | asset_url | stylesheet_tag }}

{{ 'swiper.css' | asset_url | stylesheet_tag }}
{{ 'swiper.js' | asset_url | script_tag }}



{% schema %}
