{% capture children %}
  {% content_for 'blocks' %}
{% endcapture %}
{%- liquid
  assign children = children | strip_newlines | strip | split: '<!-- @testimonialFeature/split -->' | compact
  assign medias = ''
  assign main_content = ''

  for child in children
    assign parts = child | split: '<!-- @testimonialInner/split -->'
    assign medias = medias | append: parts[1]
    assign main_content = main_content | append: parts[2]
    unless forloop.last
      assign medias = medias | append: '<!-- @testimonialMedia/split -->'
      assign main_content = main_content | append: '<!-- @testimonialContent/split -->'
    endunless
  endfor

  assign media_items = medias | strip_newlines | strip | split: '<!-- @testimonialMedia/split -->' | compact
  assign main_items = main_content | strip_newlines | strip | split: '<!-- @testimonialContent/split -->' | compact

  assign loop = true
  assign autoplay = section.settings.autoplay
  assign autoplay_delay = section.settings.autoplay_delay

  assign use_padding_inline = true
  if section.settings.container == 'page-width'
    assign use_padding_inline = false
  endif

  assign section_alignment = section.settings.alignment
  assign control_classes = 'absolute inset-0 justify-start lg:justify-end self-end'
  assign pagination_classes = ''
  if section_alignment == 'center'
    assign control_classes = ''
    assign pagination_classes = ''
  endif

  assign content_p_inline_max = 80
  assign content_pt_max = 80
  assign content_pb_max = 60
  if section.settings.media_width == 'wide'
    assign content_p_inline_max = 60
    assign content_pt_max = 60
    assign content_pb_max = 40
  endif
-%}
{% capture content_style %}
  {%- render 'clamp-calculate-style', property_name: 'padding-inline', min_value: 20, max_value: content_p_inline_max, max_breakpoint: 1455 -%}
  {%- render 'clamp-calculate-style', property_name: 'padding-block-start', min_value: 40, max_value: content_pt_max, max_breakpoint: 1455 -%}
  {%- render 'clamp-calculate-style', property_name: 'padding-block-end', min_value: 40, max_value: content_pb_max, max_breakpoint: 1455 -%}
{% endcapture %}
{% capture classes %}
  section testimonials-split-slider testimonials-split-slider--{{ section_alignment }} testimonials-split-slider--media-{{ section.settings.media_position }} testimonials-split-slider--media-{{ section.settings.media_width }}
  spacing-style color-{{ section.settings.color_scheme }}
{% endcapture %}

<style>
  /* Custom CSS Overrides to fix the alignment of shorter content blocks */
  #section-{{ section.id }} .testimonial-split-content {
    justify-content: flex-start !important;
    gap: 24px !important;
  }
  #section-{{ section.id }} .swiper.swiper-equal-height {
    flex: 0 1 auto !important;
    width: 100%;
  }
</style>

<div
  id="section-{{ section.id }}"
  class="{{ classes | strip_newlines | strip }}"
  style="{% render 'spacing-style', settings: section.settings, use_padding_inline: use_padding_inline %}"
>
  <div class="section__container {{ section.settings.container }}">
    <testimonials-split-slider
      class="block md:flex relative border-style"
      style="{% render 'border-style', settings: section.settings %}"
    >
      <div class="testimonials-split-slider__medias grid">
        {% for item in media_items %}
          <div
            class="testimonials-split-slider__media h-full row-span-full col-span-full{% if forloop.first %} active{% endif %}"
            ref="mediaItems[]"
          >
            {{ item }}
          </div>
        {% endfor %}
      </div>
      <div
        class="testimonials-split-slider__content flex flex-col spacing-style"
        style="{{ content_style }}"
      >
        {% if section.settings.heading != blank %}
          <div class="section__header">
            {% render 'text',
              fallback_text: section.settings.heading,
              preset: section.settings.heading_preset,
              font_family: section.settings.heading_font,
              font_size: section.settings.heading_font_size,
              font_size_mobile: section.settings.heading_font_size_mobile,
              font_weight: section.settings.heading_font_weight,
              line_height: section.settings.heading_line_height,
              highlight_style: section.settings.heading_highlight_style,
              highlight_font_style: section.settings.heading_highlight_font_style,
              highlight_shape_color: section.settings.heading_highlight_shape_color,
              highlight_text_color: section.settings.heading_highlight_text_color,
              text_alignment: section_alignment,
              text_alignment_mobile: section_alignment,
              width: '100%',
              width_mobile: '100%',
              animation_type: section.settings.heading_animation_type,
              animation_delay: section.settings.heading_animation_delay
            %}
          </div>
        {% endif %}
        <testimonial-split-content
          class="testimonial-split-content flex flex-col justify-start gap-6 relative flex-1"
          ref="content"
          data-section-id="{{ section.id }}"
        >
          <script type="application/json" ref="config">
            {
              "shopifyBlocks": true,
              "loop": {{ loop }},
              "autoplay":{% if autoplay %}{ "delay": {{ autoplay_delay | times: 1000 }} }{% else %}false{% endif %},
              "pagination": { "type": "progressbar" },
              "counter": true
            }
          </script>
          <div ref="container" class="swiper swiper-equal-height flex-1">
            <div class="swiper-wrapper">
              {% for item in main_items %}
                <div class="swiper-slide" ref="slides[]">
                  {{ item }}
                </div>
              {% endfor %}
            </div>
          </div>
          {%- render 'carousel-controls', counter: true, pagination: true, pagination_class: pagination_classes, class: control_classes -%}
        </testimonial-split-content>
      </div>
    </testimonials-split-slider>
  </div>
  <template id="testimonial-feature-content-template">
    {{ children }}
  </template>
</div>

