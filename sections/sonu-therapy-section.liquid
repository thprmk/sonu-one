{% comment %}
  SONU Therapy Editorial Section
{% endcomment %}

<section class="sonu-therapy-editorial section">

  <div class="sonu-therapy-page-width">

    <div class="sonu-therapy-grid">

      <!-- LEFT COLUMN: Editorial Content -->
      <div class="sonu-therapy-editorial-content sonu-therapy-animate-blur sonu-therapy-delay-4">
        {% if section.settings.heading != blank %}
          {% assign formatted_heading = section.settings.heading
            | replace: '[[', '<span class="sonu-therapy-highlight">'
            | replace: ']]', '</span>'
            | newline_to_br
          %}
          <h2 class="sonu-therapy-heading">
            {{ formatted_heading }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="sonu-therapy-description">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>

      <!-- MIDDLE COLUMN: Image Wrap -->
      <div class="sonu-therapy-image-wrap sonu-therapy-animate-blur">
        {% if section.settings.desktop_image != blank %}
          <img
            src="{{ section.settings.desktop_image | image_url: width: 1400 }}"
            alt=""
            class="sonu-therapy-image sonu-therapy-desktop-image"
            loading="lazy"
          >
        {% endif %}

        {% if section.settings.mobile_image != blank %}
          <img
            src="{{ section.settings.mobile_image | image_url: width: 900 }}"
            alt=""
            class="sonu-therapy-image sonu-therapy-mobile-image"
            loading="lazy"
          >
        {% endif %}
      </div>

      <!-- RIGHT COLUMN: Stats Cards -->
      <div class="sonu-therapy-stats">
        {% for block in section.blocks %}
          <div class="sonu-therapy-stat sonu-therapy-animate-blur sonu-therapy-delay-{{ forloop.index }}">

            <div class="sonu-therapy-stat-top">
              <div class="sonu-therapy-number">
                {% if block.settings.prefix != blank %}
                  <span class="sonu-therapy-prefix">
                    {{ block.settings.prefix }}
                  </span>
                {% endif %}

                <span class="sonu-therapy-counter"
                      data-target="{{ block.settings.number }}">
                  0
                </span>

                {% if block.settings.postfix != blank %}
                  <span class="sonu-therapy-postfix">
                    {{ block.settings.postfix }}
                  </span>
                {% endif %}
              </div>

              {% if block.settings.heading != blank %}
                <h3 class="sonu-therapy-stat-heading">
                  {{ block.settings.heading }}
                </h3>
              {% endif %}
            </div>

            {% if block.settings.text != blank %}
              <div class="sonu-therapy-stat-text">
                {{ block.settings.text }}
              </div>
            {% endif %}

          </div>
        {% endfor %}
      </div>

    </div>

  </div>

</section>

<style>

@font-face {
  font-family: 'pp-editorial';
  src: url('{{ "PPEditorialNew-Regular.otf" | asset_url }}') format('opentype');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

/* SECTION */
.sonu-therapy-editorial{
  background:#E7DED5;
  padding:100px 0;
  overflow:hidden;
}

/* PAGE WIDTH */
.sonu-therapy-page-width{
  max-width:1400px;
  margin:auto;
  padding-left: 50px;
  padding-right: 50px;
  width:100%;
  box-sizing: border-box;
}

/* GRID */
.sonu-therapy-grid{
  display:grid;
  grid-template-columns: 1.15fr 1fr 0.95fr;
  gap:60px;
  align-items: center;
}

/* IMAGE */
.sonu-therapy-image-wrap{
  position: sticky;
  top: 100px;
  width: 100%;
}

.sonu-therapy-image{
  width:100%;
  display:block;
  border-radius:24px;
}

.sonu-therapy-mobile-image{
  display:none;
}

/* STATS */
.sonu-therapy-stats{
  display:flex;
  flex-direction:column;
  gap: 20px;
}

/* SINGLE STAT CARD */
.sonu-therapy-stat{
  background: #FAF6F0;
  border-radius: 16px;
  padding: 24px 28px;
  text-align: left;
  border: none;
  box-shadow: 0 4px 20px rgba(61, 27, 3, 0.02);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.sonu-therapy-stat:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(61, 27, 3, 0.05);
}

.sonu-therapy-stat-top {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 12px;
}

/* NUMBER */
.sonu-therapy-number{
  display:inline-flex;
  align-items:baseline;
  color:#3D1B03;
  line-height:1;
  font-family:var(--sonu-font-primary);
}

.sonu-therapy-counter{
  font-size:54px;
  letter-spacing:-2px;
  font-weight:200;
}

.sonu-therapy-prefix,
.sonu-therapy-postfix{
  font-size:32px;
  line-height:1;
}

/* HEADING */
.sonu-therapy-stat-heading{
  margin:0;
  font-family: var(--sonu-font-primary);
  font-style: normal;
  font-weight: 400;
  font-size: 20px;
  color: #3D1B03;
  line-height: 1.2;
}

/* TEXT */
.sonu-therapy-stat-text{
  font-size:14px;
  line-height:1.5;
  color:rgba(30, 30, 30, 0.8);
  font-family:'Instrument Sans', sans-serif;
  margin: 0;
  text-align: left;
}

/* EDITORIAL CONTENT */
.sonu-therapy-editorial-content{
  padding-top:0;
}

/* MAIN HEADING */
.sonu-therapy-heading{
  color:#3D1B03;
  font-size:52px;
  line-height:1.1;
  letter-spacing:-1.5px;
  font-weight:400;
  margin-bottom:32px;
  font-family:'Instrument Sans', sans-serif;
}

/* HIGHLIGHT */
.sonu-therapy-highlight{
  font-family:'pp-editorial', serif;
  font-style:italic;
}

/* DESCRIPTION */
.sonu-therapy-description{
  font-size:16px;
  line-height:1.6;
  color:rgba(30, 30, 30, 0.85);
  font-family:'Instrument Sans', sans-serif;
}

.sonu-therapy-description p {
  margin: 0 0 16px 0;
}

.sonu-therapy-description p:last-child {
  margin-bottom: 0;
}

.sonu-therapy-description p strong {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: #1E1E1E;
  margin-bottom: 8px;
}

/* ANIMATION */
.sonu-therapy-animate-blur{
  opacity:0;
  filter:blur(10px);
  transform:translateY(20px);
  animation:sonuTherapyBlurFade 1s ease forwards;
}

.sonu-therapy-delay-1{animation-delay:.1s;}
.sonu-therapy-delay-2{animation-delay:.2s;}
.sonu-therapy-delay-3{animation-delay:.3s;}
.sonu-therapy-delay-4{animation-delay:.4s;}

@keyframes sonuTherapyBlurFade{
  to{
    opacity:1;
    filter:blur(0);
    transform:translateY(0);
  }
}

/* TABLET */
@media(max-width:1100px){
  .sonu-therapy-grid{
    grid-template-columns: 1fr 1.1fr;
    gap:40px;
    align-items: start;
  }
  .sonu-therapy-editorial-content {
    grid-column: span 2;
  }
  .sonu-therapy-heading{
    font-size:46px;
  }
}

/* MOBILE */
@media(max-width:768px){
  .sonu-therapy-editorial{
    background:#ffffff;
    padding:40px 0;
  }

  .sonu-therapy-page-width{
    padding: 0 24px;
  }

  .sonu-therapy-grid{
    grid-template-columns:1fr;
    gap:32px;
  }

  .sonu-therapy-editorial-content {
    grid-column: span 1;
    text-align: center;
  }

  .sonu-therapy-heading {
    font-size: 28px !important;
    line-height: 1.2 !important;
    margin-bottom: 16px;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .sonu-therapy-description {
    font-size: 14px !important;
    line-height: 1.5 !important;
    text-align: left;
    max-width: 100%;
  }

  .sonu-therapy-description p strong {
    font-size: 16px;
    text-align: center;
  }

  .sonu-therapy-image-wrap{
    margin: 0 auto;
    max-width: 100%;
  }

  .sonu-therapy-desktop-image{
    display:none;
  }

  .sonu-therapy-mobile-image{
    display:block;
    border-radius:12px;
  }

  .sonu-therapy-stats {
    gap: 16px;
  }

  .sonu-therapy-stat {
    padding: 20px 24px;
    border-radius: 12px;
  }

  .sonu-therapy-counter {
    font-size: 40px;
  }

  .sonu-therapy-prefix,
  .sonu-therapy-postfix {
    font-size: 24px;
  }

  .sonu-therapy-stat-heading {
    font-size: 16px;
  }

  .sonu-therapy-stat-text {
    font-size: 13px;
    line-height: 1.4;
  }
}

</style>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const counters = document.querySelectorAll(".sonu-therapy-counter[data-target]");

  counters.forEach(counter => {

    const target = parseFloat(counter.dataset.target);

    if(isNaN(target)) return;

    let current = 0;

    const duration = 1600;

    const increment =
      target / (duration / 16);

    function updateCounter() {

      current += increment;

      if (current < target) {

        counter.innerText =
          Math.floor(current);

        requestAnimationFrame(updateCounter);

      } else {

        counter.innerText = target;

      }

    }

    updateCounter();

  });

});
</script>

{% schema %}
{
  "name": "SONU Therapy Editorial",
  "settings": [

    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },

    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },

    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Revolutionary personalized,\n[[non-invasive]] Therapeutics"
    },

    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    }

  ],

  "blocks": [

    {
      "type": "stat",
      "name": "Stat",
      "settings": [

        {
          "type": "text",
          "id": "prefix",
          "label": "Prefix"
        },

        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "2"
        },

        {
          "type": "text",
          "id": "postfix",
          "label": "Postfix",
          "default": "x"
        },

        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Improvement"
        },

        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }

      ]
    }

  ],

  "presets": [
    {
      "name": "SONU Therapy Editorial",
      "blocks": [
        {
          "type": "stat"
        },
        {
          "type": "stat"
        },
        {
          "type": "stat"
        }
      ]
    }
  ]
}
{% endschema %}