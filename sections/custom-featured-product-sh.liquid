{%- liquid
  assign product = all_products[section.settings.product] | default: product
  assign current_variant = product.selected_or_first_available_variant
-%}

<div id="shopify-section-{{ section.id }}" class="custom-prod-wrapper" style="
  --card-bg-color: {{ section.settings.card_bg_color }};
  {% if section.settings.bg_gradient != blank %}
    background: {{ section.settings.bg_gradient }};
  {% elsif section.settings.bg_color != blank %}
    background-color: {{ section.settings.bg_color }};
  {% endif %}
  {% if section.settings.bg_image != blank %}
    --bg-image-desktop: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
  {% endif %}
  {% if section.settings.mobile_bg_image != blank %}
    --bg-image-mobile: url('{{ section.settings.mobile_bg_image | image_url: width: 1000 }}');
  {% elsif section.settings.bg_image != blank %}
    --bg-image-mobile: url('{{ section.settings.bg_image | image_url: width: 1000 }}');
  {% endif %}
  --padding-top: {{ section.settings.padding_top | default: 80 }}px;
  --padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
  --padding-top-mobile: {{ section.settings.padding_top_mobile | default: 60 }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile | default: 60 }}px;
">
  <style>
    #shopify-section-{{ section.id }} .custom-prod-wrapper {
      {% if section.settings.bg_image != blank %}
        background-image: var(--bg-image-desktop);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
      {% endif %}
    }
    #shopify-section-{{ section.id }} .custom-prod-container {
      padding-top: var(--padding-top, 80px) !important;
      padding-bottom: var(--padding-bottom, 80px) !important;
    }
    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} .custom-prod-wrapper {
        {% if section.settings.bg_image != blank or section.settings.mobile_bg_image != blank %}
          background-image: var(--bg-image-mobile);
        {% endif %}
      }
      #shopify-section-{{ section.id }} .custom-prod-container {
        padding-top: var(--padding-top-mobile, 60px) !important;
        padding-bottom: var(--padding-bottom-mobile, 60px) !important;
      }
    }
  </style>
  <div class="custom-prod-container">
    
    <!-- Gallery Slideshow -->
    <div class="custom-prod-gallery swiper" data-autoplay="false">
      <div class="swiper-wrapper">
        {% if product.images.size > 0 %}
          {% for image in product.images %}
            <div class="swiper-slide custom-prod-gallery__slide">
              <img src="{{ image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" width="100%" height="auto">
            </div>
          {% endfor %}
        {% else %}
          <div class="swiper-slide custom-prod-gallery__slide">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
      </div>
      
      {% if product.images.size > 1 %}
        <div class="custom-prod-gallery__controls">
          <button class="custom-prod-gallery__arrow custom-prod-gallery__arrow--prev" aria-label="Previous">
            <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 9L1 5L5 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="custom-prod-gallery__pagination"></div>
          <button class="custom-prod-gallery__arrow custom-prod-gallery__arrow--next" aria-label="Next">
            <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 9L5 5L1 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {% endif %}
    </div>

    <!-- Product Card Content -->
    <div class="custom-prod-card">
      <div class="custom-prod-card__inner">
        
        <!-- Product Title -->
        <{{ section.settings.heading_tag | default: 'h2' }} class="custom-prod-title">{{ product.title | default: 'SONU Band' }}</{{ section.settings.heading_tag | default: 'h2' }}>
        
        <!-- Stars & Reviews -->
        <div class="custom-prod-reviews">
          <div class="custom-prod-stars">
            {% for i in (1..5) %}
              <svg width="18" height="17" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 0L11.0206 6.21885H17.5595L12.2694 10.0623L14.29 16.2812L9 12.4377L3.71 16.2812L5.73056 10.0623L0.440482 6.21885H6.97938L9 0Z" fill="#FFCD0F"/>
              </svg>
            {% endfor %}
          </div>
          <span class="custom-prod-reviews-text">{{ section.settings.reviews_text | default: '66 reviews' }}</span>
        </div>

        <!-- Description -->
        <div class="custom-prod-desc">
          <p>{{ section.settings.description | default: product.description }}</p>
        </div>

        <!-- Price & FDA Props -->
        <div class="custom-prod-price-area">
          <div class="custom-prod-price">
            <span class="custom-prod-price__amount">{{ current_variant.price | default: product.price | default: 29900 | money }}</span>
          </div>
          <div class="custom-prod-props">
            <span>FDA Approved | FSA/HSA Eligible | VA Approved</span>
          </div>
        </div>

        <!-- Swatches and Quantity Box -->
        <div class="custom-prod-options-row">
          
          <!-- Swatches -->
          <div class="custom-prod-swatches-box">
            <div class="custom-prod-swatches-header">
              <span class="custom-prod-swatches-title">Color:</span>
              <span class="custom-prod-swatch-label">{{ current_variant.options[color_option_index] | default: 'Black' }}</span>
            </div>
            <div class="custom-prod-swatches">
              {% assign color_option_index = -1 %}
              {% for option in product.options_with_values %}
                {% if option.name == 'Color' or option.name == 'color' %}
                  {% assign color_option_index = forloop.index0 %}
                {% endif %}
              {% endfor %}

              {% if color_option_index >= 0 %}
                {% assign shown_colors = '' %}
                {% for variant in product.variants %}
                  {% assign color_value = variant.options[color_option_index] %}
                  {% unless shown_colors contains color_value %}
                    {% assign shown_colors = shown_colors | append: color_value | append: ',' %}
                    <div 
                      class="custom-prod-swatch{% if variant.id == current_variant.id %} active{% endif %}" 
                      data-variant-id="{{ variant.id }}" 
                      data-color="{{ color_value | escape }}"
                      data-available="{{ variant.available }}"
                      data-price="{{ variant.price | money }}"
                    >
                      <span class="custom-prod-swatch__inner" style="background-color: {% if color_value contains 'Black' or color_value contains 'black' %}#1E1E1E{% else %}#C4C3C9{% endif %};"></span>
                    </div>
                  {% endunless %}
                {% endfor %}
              {% else %}
                <!-- Static Fallback Swatches matching Figma -->
                <div class="custom-prod-swatch active" data-color="Black">
                  <span class="custom-prod-swatch__inner" style="background-color: #1E1E1E;"></span>
                </div>
                <div class="custom-prod-swatch" data-color="Gray">
                  <span class="custom-prod-swatch__inner" style="background-color: #C4C3C9;"></span>
                </div>
              {% endif %}
            </div>
          </div>

          <!-- Quantity & Stock Status nested together -->
          <div class="custom-prod-qty-container">
            <div class="custom-prod-qty-box">
              <span class="custom-prod-qty-title">Quantity</span>
              <div class="custom-prod-qty-selector">
                <button type="button" class="custom-prod-qty-btn custom-prod-qty-btn--minus" aria-label="Decrease quantity">−</button>
                <span class="custom-prod-qty-value">1</span>
                <button type="button" class="custom-prod-qty-btn custom-prod-qty-btn--plus" aria-label="Increase quantity">+</button>
              </div>
            </div>
            <!-- Stock Status -->
            <div class="custom-prod-stock">
              <span class="custom-prod-stock__indicator"></span>
              <span class="custom-prod-stock__text">In stock, ready to ship</span>
            </div>
          </div>

        </div>

        <!-- Affirm APR Widget -->
        <div class="custom-prod-affirm">
          <span class="custom-prod-affirm__apr-badge">0% APR</span>
          <span class="custom-prod-affirm__text">or as low as $27/mo with <span class="custom-prod-affirm__brand">affirm</span>. <a href="#">See if you qualify</a></span>
        </div>

        <!-- Buy Buttons -->
        <div class="custom-prod-actions">
          <button type="button" class="custom-prod-buy-btn button button--primary" data-variant-id="{{ current_variant.id }}">
            BUY NOW
          </button>
          <a href="#" class="custom-prod-secondary-btn">
            TRY RISK FREE FOR 45 DAYS
          </a>
        </div>

      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Featured Product",
  "tag": "section",
  "class": "custom-featured-product-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Select Product"
    },
    {
      "type": "text",
      "id": "reviews_text",
      "label": "Reviews Text",
      "default": "66 reviews"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Custom Description",
      "info": "Overrides product default description if filled"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#F4EFEA"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Background Gradient"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg_image",
      "label": "Mobile Background Image"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading Tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "p", "label": "Paragraph (P)" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Desktop Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Desktop Padding Bottom"
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Mobile Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Mobile Padding Bottom"
    }
  ],
  "presets": [
    {
      "name": "Custom Featured Product"
    }
  ]
}
{% endschema %}
