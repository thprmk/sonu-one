<style>
.custom-new-footer {
  position: relative;
  {%- if section.settings.bg_image != blank -%}
    background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
  {%- else -%}
    background-image: url('https://cdn.shopify.com/s/files/1/0992/3166/2451/files/Rectangle_42.webp?v=1780063233');
  {%- endif -%}
  {%- if section.settings.bg_gradient != blank -%}
    background: {{ section.settings.bg_gradient }};
  {%- elsif section.settings.bg_color != blank -%}
    background-color: {{ section.settings.bg_color }};
  {%- endif -%}
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  color: {{ section.settings.text_color | default: '#FFFFFF' }};
  padding: {{ section.settings.padding_top | default: 80 }}px 80px {{ section.settings.padding_bottom | default: 40 }}px 80px;
  font-family: 'Instrument Sans', sans-serif;
  overflow: hidden;
  z-index: 1;
  margin-top: {{ section.settings.margin_top | default: 0 }}px;
}

.custom-footer-container {
  display: grid;
  grid-template-columns: 320px 1fr;
  grid-template-rows: auto auto;
  column-gap: 80px;
  row-gap: 48px;
  max-width: 1440px;
  margin: 0 auto;
}

/* LOGO */
.custom-footer-logo-wrap {
  grid-column: 1;
  grid-row: 1;
  align-self: start;
}

.custom-footer-logo {
  max-width: {{ section.settings.logo_width | default: 180 }}px;
  height: auto;
  object-fit: contain;
  display: block;
}

/* PAYMENTS */
.custom-footer-payments {
  grid-column: 2;
  grid-row: 1;
  justify-self: end;
  align-self: start;
}

.custom-payments-desktop-only {
  display: block;
}

.custom-payments-mobile-only {
  display: none;
}

.custom-payments-desktop-only ul {
  display: flex;
  align-items: center;
  gap: 8px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.custom-payments-desktop-only svg {
  height: 24px;
  width: auto;
  display: block;
}

/* NEWSLETTER */
.custom-footer-newsletter-wrap {
  grid-column: 1;
  grid-row: 2;
  align-self: start;
  display: flex;
  flex-direction: column;
}

.custom-footer-desc {
  font-size: 18px;
  line-height: 1.5;
  color: {{ section.settings.text_color | default: '#FFFFFF' }};
  margin: 0 0 20px 0;
  max-width: 320px;
}

.custom-footer-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
  width: 100%;
}

.custom-footer-input-wrapper {
  position: relative;
  width: 100%;
}

.custom-footer-input-wrapper input {
  width: 100%;
  padding: 14px 20px;
  border-radius: 30px;
  border: 1px solid {{ section.settings.input_border | default: 'rgba(255,255,255,0.3)' }};
  background: {{ section.settings.input_bg | default: 'rgba(255,255,255,0.05)' }};
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: {{ section.settings.text_color | default: '#FFFFFF' }};
  font-size: 16px;
  box-sizing: border-box;
  outline: none;
  transition: border-color 0.2s ease;
}

.custom-footer-input-wrapper input:focus {
  border-color: rgba(255, 255, 255, 0.8);
}

.custom-footer-input-wrapper input::placeholder {
  color: rgba(255, 255, 255, 0.6);
}

.custom-footer-inline-submit {
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  display: none; /* Only visible on mobile */
  align-items: center;
  justify-content: center;
  padding: 8px;
}

.custom-footer-desktop-submit {
  width: fit-content;
  padding: 14px 28px;
  border-radius: 30px;
  border: none;
  background: {{ section.settings.btn_bg | default: '#FFFFFF' }};
  color: {{ section.settings.btn_text_color | default: '#000000' }};
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.custom-footer-desktop-submit:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

/* LINKS GRID */
.custom-footer-links-column-wrapper {
  display: contents;
}

.custom-footer-links-grid {
  grid-column: 2;
  grid-row: 2;
  align-self: start;
  display: flex;
  justify-content: space-between;
  width: 100%;
  gap: 20px;
}

.custom-footer-col {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.custom-footer-col h4 {
  font-size: 16px;
  font-weight: 500;
  color: {{ section.settings.heading_color | default: 'rgba(255,255,255,0.5)' }};
  margin: 0;
  text-transform: capitalize;
  letter-spacing: 0.05em;
}

.custom-footer-col a {
  font-size: 16px;
  color: {{ section.settings.text_color | default: '#FFFFFF' }};
  text-decoration: none;
  transition: opacity 0.2s ease;
  line-height: 1.3;
}

.custom-footer-col a:hover {
  color: {{ section.settings.link_hover_color | default: 'rgba(255,255,255,0.7)' }};
}

/* DIVIDER */
.custom-footer-divider {
  border: none;
  border-top: 1px solid rgba(255, 255, 255, 0.15);
  margin: 60px 0 30px 0;
  width: 100%;
}

/* BOTTOM FOOTER */
.custom-footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 1440px;
  margin: 0 auto;
  width: 100%;
  flex-wrap: wrap;
  gap: 20px;
}

.custom-footer-bottom-links-desktop {
  display: flex;
  gap: 24px;
}

.custom-footer-bottom-links-desktop a {
  font-size: 14px;
  color: {{ section.settings.text_color | default: '#FFFFFF' }};
  text-decoration: none;
  opacity: 0.8;
  transition: opacity 0.2s ease;
}

.custom-footer-bottom-links-desktop a:hover {
  color: {{ section.settings.link_hover_color | default: 'rgba(255,255,255,0.7)' }};
  opacity: 1;
}

.custom-footer-bottom-links-mobile {
  display: none;
}

.custom-footer-copyright {
  font-size: 14px;
  color: {{ section.settings.heading_color | default: 'rgba(255,255,255,0.5)' }};
  margin: 0;
}

/* RESPONSIVE LAYOUT */
@media screen and (max-width: 1024px) {
  .custom-footer-container {
    column-gap: 40px;
  }
}

@media screen and (max-width: 768px) {
  .custom-new-footer {
    padding: 80px 40px 48px 40px;
    margin-top: {{ section.settings.margin_top_mobile | default: 0 }}px;
  }

  .custom-footer-container {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .custom-footer-logo-wrap {
    order: 1;
    align-self: start;
    margin-bottom: 0;
  }

  .custom-footer-payments {
    order: 2;
    align-self: start;
    justify-self: start;
    width: 100%;
  }

  .custom-payments-desktop-only {
    display: none;
  }

  .custom-payments-mobile-only {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .custom-mobile-payment-icons {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .custom-mobile-payment-icons svg {
    height: 22px;
    width: auto;
    display: block;
  }

  .custom-mobile-payment-text {
    font-size: 15px;
    color: {{ section.settings.text_color | default: '#FFFFFF' }};
    font-weight: 500;
  }

  .custom-footer-links-column-wrapper {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .custom-footer-links-grid {
    order: 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 20px;
    width: 100%;
  }

  .custom-footer-newsletter-wrap {
    order: 4;
    width: 100%;
  }

  .custom-footer-desc {
    font-size: 18px;
    margin-bottom: 24px;
    max-width: 100%;
  }

  .custom-footer-input-wrapper input {
    padding: 14px 50px 14px 18px; /* Extra padding on right for arrow */
  }

  .custom-footer-inline-submit {
    display: flex;
  }

  .custom-footer-desktop-submit {
    display: none;
  }

  .custom-footer-divider {
    margin: 48px 0 32px 0;
  }

  .custom-footer-bottom {
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  .custom-footer-bottom-links-desktop {
    display: none;
  }

  .custom-footer-bottom-links-mobile {
    display: grid;
    grid-template-columns: max-content max-content max-content;
    gap: 20px 32px;
    width: 100%;
  }

  .custom-footer-bottom-links-mobile a {
    font-size: 14px;
    color: {{ section.settings.text_color | default: '#FFFFFF' }};
    text-decoration: none;
    opacity: 0.8;
  }

  .custom-footer-copyright {
    font-size: 13px;
    line-height: 1.5;
  }
}
</style>

<footer class="custom-new-footer">
  <div class="custom-footer-container">
    
    <!-- LOGO -->
    <div class="custom-footer-logo-wrap">
      <a href="{{ section.settings.logo_link | default: '/' }}">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 500 }}" alt="{{ section.settings.logo.alt | default: shop.name }}" class="custom-footer-logo">
        {%- else -%}
          <img src="https://soundhealthsonu.myshopify.com/cdn/shop/files/logo.png?height=108&v=1776786182" alt="SoundHealth Logo" class="custom-footer-logo">
        {%- endif -%}
      </a>
    </div>

    <!-- PAYMENTS -->
    {%- if section.settings.show_payments -%}
      <div class="custom-footer-payments">
        <!-- DESKTOP PAYMENT ICONS -->
        <div class="custom-payments-desktop-only">
          <ul>
            {%- assign payment_types = section.settings.payments_desktop | split: ',' -%}
            {%- for type in payment_types -%}
              {%- assign type_stripped = type | strip -%}
              {%- if type_stripped != blank -%}
                <li>
                  {{ type_stripped | payment_type_svg_tag }}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
        
        <!-- MOBILE PAYMENT ICONS -->
        <div class="custom-payments-mobile-only">
          <ul class="custom-mobile-payment-icons">
            {%- assign payment_types_mobile = section.settings.payments_mobile | split: ',' -%}
            {%- for type in payment_types_mobile -%}
              {%- assign type_stripped = type | strip -%}
              {%- if type_stripped != blank -%}
                <li>
                  {{ type_stripped | payment_type_svg_tag }}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
          {%- if section.settings.payments_mobile_label != blank -%}
            <span class="custom-mobile-payment-text">{{ section.settings.payments_mobile_label }}</span>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <!-- NEWSLETTER -->
    <div class="custom-footer-newsletter-wrap">
      {%- if section.settings.newsletter_desc != blank -%}
        <p class="custom-footer-desc">{{ section.settings.newsletter_desc }}</p>
      {%- endif -%}
      
      {% form 'customer', class: 'custom-footer-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="custom-footer-input-wrapper">
          <input type="email" name="contact[email]" placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your Email' }}" required autocomplete="email">
          <button type="submit" class="custom-footer-inline-submit" aria-label="Subscribe">
            <svg width="18" height="12" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 1L17 6L12 11" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M1 6H17" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        {%- if section.settings.newsletter_button_text != blank -%}
          <button type="submit" class="custom-footer-desktop-submit">{{ section.settings.newsletter_button_text }}</button>
        {%- endif -%}
      {% endform %}
    </div>

    <!-- LINKS GRID -->
    <div class="custom-footer-links-grid">
      <!-- COLUMN 1 (Company & Resources) -->
      <div class="custom-footer-links-column-wrapper">
        <!-- COMPANY -->
        <div class="custom-footer-col col-company">
          {%- if section.settings.menu_company != blank -%}
            {%- assign menu_company = linklists[section.settings.menu_company] -%}
            <h4>{{ menu_company.title }}</h4>
            {%- for link in menu_company.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          {%- else -%}
            <h4>Company</h4>
            <a href="/pages/about-us">About Us</a>
            <a href="/pages/leadership">Leadership</a>
            <a href="/pages/medical-advisory-board">Medical Advisory Board</a>
            <a href="/pages/careers">Careers</a>
            <a href="/pages/newsroom">Newsroom</a>
          {%- endif -%}
        </div>
        <!-- RESOURCES -->
        <div class="custom-footer-col col-resources">
          {%- if section.settings.menu_resources != blank -%}
            {%- assign menu_resources = linklists[section.settings.menu_resources] -%}
            <h4>{{ menu_resources.title }}</h4>
            {%- for link in menu_resources.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          {%- else -%}
            <h4>Resources</h4>
            <a href="/pages/collateral-library">Collateral Library</a>
            <a href="/pages/health-care-professional">Health Care Professional</a>
            <a href="/pages/learn">Learn</a>
          {%- endif -%}
        </div>
      </div>

      <!-- COLUMN 2 (Support & Connect) -->
      <div class="custom-footer-links-column-wrapper">
        <!-- SUPPORT -->
        <div class="custom-footer-col col-support">
          {%- if section.settings.menu_support != blank -%}
            {%- assign menu_support = linklists[section.settings.menu_support] -%}
            <h4>{{ menu_support.title }}</h4>
            {%- for link in menu_support.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          {%- else -%}
            <h4>Support</h4>
            <a href="/pages/faq">FAQ</a>
            <a href="/pages/contact-us">Contact Us</a>
            <a href="/pages/partners">Partners</a>
          {%- endif -%}
        </div>
        <!-- CONNECT -->
        <div class="custom-footer-col col-connect">
          {%- if section.settings.menu_connect != blank -%}
            {%- assign menu_connect = linklists[section.settings.menu_connect] -%}
            <h4>{{ menu_connect.title }}</h4>
            {%- for link in menu_connect.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          {%- else -%}
            <h4>Connect</h4>
            <a href="https://facebook.com/SoundHealth" target="_blank" rel="noopener">Facebook</a>
            <a href="https://instagram.com/SoundHealth" target="_blank" rel="noopener">Instagram</a>
            <a href="https://x.com/SoundHealth" target="_blank" rel="noopener">X</a>
            <a href="https://linkedin.com/company/SoundHealth" target="_blank" rel="noopener">LinkedIn</a>
            <a href="https://youtube.com/SoundHealth" target="_blank" rel="noopener">Youtube</a>
          {%- endif -%}
        </div>
      </div>
    </div>

  </div>

  <hr class="custom-footer-divider">

  <!-- BOTTOM FOOTER -->
  <div class="custom-footer-bottom">
    <!-- DESKTOP BOTTOM LINKS -->
    <div class="custom-footer-bottom-links-desktop">
      {%- if section.settings.menu_bottom_desktop != blank -%}
        {%- assign menu_bottom_desktop = linklists[section.settings.menu_bottom_desktop] -%}
        {%- for link in menu_bottom_desktop.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms of Use</a>
        <a href="/pages/biometric-notice">Biometric Notice</a>
        <a href="/pages/warranty-return-policy">Warranty & Return Policy</a>
      {%- endif -%}
    </div>
    <!-- MOBILE BOTTOM LINKS -->
    <div class="custom-footer-bottom-links-mobile">
      {%- if section.settings.menu_bottom_mobile != blank -%}
        {%- assign menu_bottom_mobile = linklists[section.settings.menu_bottom_mobile] -%}
        {%- for link in menu_bottom_mobile.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/policies/terms-of-service">Terms & Conditions</a>
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/pages/accessibility">Accessibility</a>
        <a href="/pages/ip-notice">IP Notice</a>
        <a href="/pages/security-center">Security Center</a>
      {%- endif -%}
    </div>
    
    <p class="custom-footer-copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_text | default: "SoundHealth All rights reserved. Designed and developed by Spinta digital" }}
    </p>
  </div>
</footer>

