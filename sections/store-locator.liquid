{%- liquid
  assign type = section.settings.type
  assign columns = section.settings.columns
  assign columns_xl = columns | at_most: 3
  assign columns_lg = columns | at_most: 2
  assign columns_md = columns | at_most: 2
  assign column_gap = section.settings.column_gap
  assign columns_mobile = section.settings.columns_mobile | plus: 0
  assign enable_swipe_on_mobile = section.settings.enable_swipe_on_mobile
  assign swipe_custom_width_column = section.settings.swipe_custom_width_column
  assign container = section.settings.container

  assign swipe_mobile_classes = ''
  assign swipe_mobile_inner_classes = ''

  if enable_swipe_on_mobile
    assign swipe_mobile_classes = ' swipe-mobile swipe-mobile--[columns]-cols' | replace: '[columns]', columns_mobile
    assign swipe_mobile_inner_classes = ' swipe__inner'

    if swipe_custom_width_column
      assign swipe_mobile_classes = swipe_mobile_classes | append: ' swipe-mobile--custom-width'
    endif
  endif
-%}
{%- capture grid_style -%}
  {% render 'layout-panel-style', settings: section.settings, type: 'grid', columns_mobile: columns_mobile, columns_md: columns_md, columns_lg: columns_lg, columns_xl: columns_xl, columns_xxl: columns %}
  {% render 'gap-style', settings: section.settings %}
{%- endcapture -%}
<div
  id="section-{{ section.id }}"
  class="section store-locator spacing-style color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="section__container section-grid section-grid--{{ container }}">
    {% if type == 'carousel' %}
      <carousel-slider
        class="store-locator__wrapper block carousel carousel--grid carousel--visible"
        style="{{ grid_style }}"
      >
        <script type="application/json" ref="config">
          {
           "loop": false,
            "slidesPerView": {{ columns_md }},
            "spaceBetween": {{ column_gap }},
            "mousewheel": {
              "enabled": true,
              "forceToAxis": true,
              "thresholdTime": 300,
              "thresholdDelta": 10
            },
            "navigationPosition": {
              "enabled": true,
              "selector": ".media .media__image"
            },
            "pagination": { "type": "progressbar" },
            "destroyBelow": 768,
            "counter": false ,
            "breakpoints": {
              "1024": {
                "slidesPerView": {{ columns_lg }}
              },
              "1200": {
                "slidesPerView": {{ columns_xl }}
              },
              "1440": {
                "slidesPerView": {{ columns }}
              }
            }
          }
        </script>
        <div
          class="swiper{{ swipe_mobile_classes }}"
          ref="container"
          style="{% if swipe_custom_width_column %} --swipe-column-width: {{ section.settings.swipe_column_width | divided_by: 100.0 }};{% endif %}"
        >
          <div class="swiper-wrapper layout-panel-grid-mobile gap-style{{ swipe_mobile_inner_classes }}">
            {% for block in section.blocks %}
              <div class="f-column swiper-slide">
                {% render block %}
              </div>
            {% endfor %}
          </div>
        </div>
        {% render 'carousel-controls', ref: 'controls', type: 'relative', class: 'hidden md:flex' %}
      </carousel-slider>
    {% else %}
      <div class="store-locator__wrapper{{ swipe_mobile_classes }}">
        <div
          class="store-locator__inner layout-panel-grid gap-style{{ swipe_mobile_inner_classes }}"
          style="{{ grid_style }}"
        >
          {% for block in section.blocks %}
            <div class="f-column">
              {% render block %}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</div>
{% schema %}
{
  "name": "t:names.store_locator",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "blocks": [
