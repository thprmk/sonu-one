<section class="science-bg-area">
<section class="logo-section section" style="
  {% if section.settings.bg_gradient != blank %}
    background: {{ section.settings.bg_gradient }};
  {% else %}
    background-color: {{ section.settings.bg_color | default: 'transparent' }};
  {% endif %}
  {% if section.settings.bg_image != blank %}
    --bg-image-desktop: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
  {% endif %}
  {% if section.settings.mobile_bg_image != blank %}
    --bg-image-mobile: url('{{ section.settings.mobile_bg_image | image_url: width: 1000 }}');
  {% elsif section.settings.bg_image != blank %}
    --bg-image-mobile: url('{{ section.settings.bg_image | image_url: width: 1000 }}');
  {% endif %}
  --padding-top: {{ section.settings.padding_top | default: 20 }}px;
  --padding-bottom: {{ section.settings.padding_bottom | default: 40 }}px;
  --padding-top-mobile: {{ section.settings.padding_top_mobile | default: 0 }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile | default: 0 }}px;
">
  <style>
    #shopify-section-{{ section.id }} .logo-section {
      {% if section.settings.bg_image != blank %}
        background-image: var(--bg-image-desktop);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
      {% endif %}
      padding-top: var(--padding-top, 20px) !important;
      padding-bottom: var(--padding-bottom, 40px) !important;
    }
    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} .logo-section {
        {% if section.settings.bg_image != blank or section.settings.mobile_bg_image != blank %}
          background-image: var(--bg-image-mobile);
        {% endif %}
        padding-top: var(--padding-top-mobile, 0px) !important;
        padding-bottom: var(--padding-bottom-mobile, 0px) !important;
      }
    }
  </style>

  {% render 'sonu-section-header',
    heading: section.settings.heading,
    heading_tag: section.settings.heading_tag,
    heading_class: 'logo-heading',
    subheading: section.settings.description,
    text_align: 'center',
    animate: true
  %}

  <!-- LOGOS -->
  <div class="logo-container animate-blur delay-3">

    <div class="logo-track" id="logoTrack-{{ section.id }}">

      {% for block in section.blocks %}
        <div class="logo-item">

          {% if block.settings.logo != blank %}
            <img
              src="{{ block.settings.logo | image_url: width: 300 }}"
              alt=""
              loading="lazy"
              width="{{ block.settings.logo.width }}"
              height="{{ block.settings.logo.height }}"
            >
          {% endif %}

        </div>
      {% endfor %}

    </div>

  </div>

  <!-- CTA BUTTON -->
  {% if section.settings.button_text != blank %}
    <div class="logo-button-wrap">

      <a href="{{ section.settings.button_link }}"
         class="logo-btn"
         style="
           background: {{ section.settings.button_bg }};
           color: {{ section.settings.button_text_color }};
         ">
        {{ section.settings.button_text }}
      </a>

    </div>
  {% endif %}

</section>
</section>
{{ 'sonu-custom.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Logo Carousel",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg_image",
      "label": "Mobile Background Image"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Background Gradient"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color Fallback",
      "default": "transparent"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 20,
      "unit": "px",
      "label": "Desktop Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "Desktop Padding Bottom"
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "Mobile Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "Mobile Padding Bottom"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Partners"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading type",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#001755"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo Carousel"
    }
  ]
}
{% endschema %}
<script src="{{ 'sonu-logo-list.js' | asset_url }}" defer="defer"></script>