{%- liquid
  assign bg_color = section.settings.bg_color
  assign bg_gradient = section.settings.bg_gradient
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
-%}

<div id="shopify-section-{{ section.id }}" class="custom-card-slider-wrapper image-bg-{{ section.id }}" style="
  {% if bg_gradient != blank %}
    background: {{ bg_gradient }};
  {% elsif bg_color != blank %}
    background-color: {{ bg_color }};
  {% endif %}
  --padding-top: {{ padding_top }}px;
  --padding-bottom: {{ padding_bottom }}px;
  --padding-top-mobile: {{ padding_top_mobile }}px;
  --padding-bottom-mobile: {{ padding_bottom_mobile }}px;
">
  <style>
    #shopify-section-{{ section.id }} .custom-card-slider-wrapper {
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
    }
    
    {% if section.settings.bg_image != blank %}
    .image-bg-{{ section.id }} {
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
    }
    {% endif %}

    @media screen and (max-width: 768px) {
      .image-bg-{{ section.id }} {
        {% if section.settings.mobile_bg_image != blank %}
          background-image: url('{{ section.settings.mobile_bg_image | image_url: width: 1000 }}') !important;
        {% elsif section.settings.bg_image != blank %}
          background-image: url('{{ section.settings.bg_image | image_url: width: 1000 }}') !important;
        {% endif %}
      }
    }
  </style>

  <div class="custom-card-slider-container">
    
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="custom-card-slider-header">
        {% if section.settings.subheading != blank %}
          <span class="custom-card-slider-subheading">{{ section.settings.subheading }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <{{ section.settings.heading_tag | default: 'h2' }} class="custom-card-slider-heading">{{ section.settings.heading }}</{{ section.settings.heading_tag | default: 'h2' }}>
        {% endif %}
      </div>
    {% endif %}

    <!-- Swiper Carousel -->
    <div class="swiper custom-card-swiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide custom-card-slide" {{ block.shopify_attributes }}>
            <div class="custom-card-slide__inner">
              
              <!-- Background Image -->
              <div class="custom-card-slide__image">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
              
              <!-- Overlay Gradient -->
              <div class="custom-card-slide__overlay"></div>

              <!-- Top Badge/Pill -->
              {% if block.settings.top_badge != blank %}
                <div class="custom-card-slide__top-badge">
                  <span>{{ block.settings.top_badge }}</span>
                </div>
              {% endif %}

              <!-- Slide Contents -->
              <div class="custom-card-slide__content">
                {% if block.settings.title != blank %}
                  <h3 class="custom-card-slide__title">{{ block.settings.title }}</h3>
                {% endif %}
                
                {% if block.settings.description != blank %}
                  <p class="custom-card-slide__desc">{{ block.settings.description }}</p>
                {% endif %}

                {% if block.settings.bottom_badge != blank %}
                  <div class="custom-card-slide__bottom-badge">
                    <span>{{ block.settings.bottom_badge }}</span>
                  </div>
                {% endif %}
              </div>

            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- Navigation & Progress Controls at Bottom -->
    <div class="custom-card-controls-row">
      <div class="custom-card-progressbar swiper-pagination"></div>
      
      <div class="custom-card-arrows">
        <button class="custom-card-nav-btn custom-card-nav-btn--prev" aria-label="Previous">
          <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7 13L1 7L7 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="custom-card-nav-btn custom-card-nav-btn--next" aria-label="Next">
          <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 13L7 7L1 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Card Slider",
  "tag": "section",
  "class": "custom-card-slider-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading type",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "p", "label": "Paragraph" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F3EEF9"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Background Gradient"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg_image",
      "label": "Mobile Background Image"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Padding Bottom"
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Padding Top Mobile"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Padding Bottom Mobile"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Background Image"
        },
        {
          "type": "text",
          "id": "top_badge",
          "label": "Top Badge Text",
          "default": "How it Works"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Gentle sound, delivered through bone"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "The Spatial Sleep band rests on your forehead and sends soft acoustic vibrations through your skull — no earbuds needed."
        },
        {
          "type": "text",
          "id": "bottom_badge",
          "label": "Bottom Badge Text",
          "default": "No effort required · Works while you rest"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Card Slider",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "top_badge": "How it Works",
            "title": "Gentle sound, delivered through bone",
            "description": "The Spatial Sleep band rests on your forehead and sends soft acoustic vibrations through your skull — no earbuds needed. Each ear receives a slightly different frequency, and your brain naturally blends them into a calming rhythm that guides you toward sleep.",
            "bottom_badge": "No effort required · Works while you rest"
          }
        },
        {
          "type": "card",
          "settings": {
            "top_badge": "Why it Takes Time",
            "title": "Think of pushing a swing",
            "description": "One push barely moves it. But small, steady pushes — timed just right — build into a deep, effortless rhythm. That's how neural entrainment works. Each night, Spatial Sleep gives your brain another gentle push toward its natural sleep frequency.",
            "bottom_badge": "2–4 weeks to build momentum"
          }
        },
        {
          "type": "card",
          "settings": {
            "top_badge": "Consistency Matters",
            "title": "Every night counts",
            "description": "In clinical studies, participants who used the band nightly saw the strongest results — insomnia severity dropped by nearly 50% over four weeks, with three-quarters no longer qualifying as having insomnia.",
            "bottom_badge": "Lin et al., Journal of Sleep Medicine, 2025 · Consistent with broader acoustic entrainment research"
          }
        }
      ]
    }
  ]
}
{% endschema %}
