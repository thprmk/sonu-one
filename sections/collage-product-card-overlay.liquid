{%- liquid
  assign left_columns = ''
  assign right_columns = ''
-%}
{%- capture inline_style -%}
  {% render 'clamp-calculate-style', property_name: 'zigzag-offset', min_value: 50, max_value: 190 %}
{%- endcapture -%}
<div
  class="section-{{ section.id }} collage-product-card-overlay border-style spacing-style color-{{ section.settings.color_scheme }}"
  style="{% render 'border-style', settings: section.settings %}{% render 'spacing-style', settings: section.settings %}{{ inline_style }}"
>
  <div class="page-width">
    <div
      class="collage-product-card-overlay__wrapper swipe-mobile swipe-mobile--1-cols"
      style="{% render 'gap-style', column_gap: 60, column_gap_mobile: 8 %}"
    >
      <div class="collage-product-card-overlay__grid swipe__inner">
        {%- for block in section.blocks -%}
          {%- capture col_html -%}
            <div class="collage-product-card-overlay__column">
              {%- render block -%}
            </div>
          {%- endcapture -%}
          {%- liquid
            assign modulo = forloop.index0 | modulo: 2

            if modulo == 0
              assign left_columns = left_columns | append: col_html
            else
              assign right_columns = right_columns | append: col_html
            endif
          -%}
        {%- endfor -%}
        <div class="collage-product-card-overlay__cols collage-product-card-overlay__cols-first">{{ left_columns }}</div>
        <div class="collage-product-card-overlay__cols collage-product-card-overlay__cols-last">{{ right_columns }}</div>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "t:names.collage",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.borders",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "label": "t:settings.border_width",
      "default": 1,
      "visible_if": "{{ section.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.border_opacity",
      "default": 100,
      "visible_if": "{{ section.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "select",
      "id": "device",
      "label": "t:settings.devices",
      "options": [
        {
          "value": "desktop",
          "label": "t:options.desktop"
        },
        {
          "value": "mobile",
          "label": "t:options.mobile"
        }
      ],
      "default": "desktop"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 100,
      "visible_if": "{{ section.settings.device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 100,
      "visible_if": "{{ section.settings.device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48,
      "visible_if": "{{ section.settings.device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48,
      "visible_if": "{{ section.settings.device == 'mobile' }}"
    }
  ],
  "blocks": [
    {
      "type": "product-overlay-card"
    }
  ],
  "presets": [
    {
      "name": "t:names.collage_product_card_overlay",
      "category": "t:categories.basic",
      "settings": {
        "color_scheme": "scheme-1",
        "border": "none",
        "border_width": 1,
        "border_opacity": 100,
        "border_radius": 0,
        "device": "desktop",
        "padding-block-start": 100,
        "padding-block-end": 100,
        "padding-block-start-mobile": 48,
        "padding-block-end-mobile": 48
      },
      "blocks": {
        "product_overlay_card_1": {
          "type": "product-overlay-card",
          "name": "t:names.product_overlay_card",
          "settings": {
            "product": "",
            "product_image_ratio": "1/1",
            "image_ratio": "adapt",
            "image_ratio_mobile": "adapt",
            "color_scheme": "scheme-inverse",
            "border_radius": 20,
            "enable_preload_image": false
          },
          "blocks": {}
        },
        "product_overlay_card_2": {
          "type": "product-overlay-card",
          "name": "t:names.product_overlay_card",
          "settings": {
            "product": "",
            "product_image_ratio": "1/1",
            "image_ratio": "adapt",
            "image_ratio_mobile": "adapt",
            "color_scheme": "scheme-inverse",
            "border_radius": 20,
            "enable_preload_image": false
          },
          "blocks": {}
        },
        "product_overlay_card_3": {
          "type": "product-overlay-card",
          "name": "t:names.product_overlay_card",
          "settings": {
            "product": "",
            "product_image_ratio": "1/1",
            "image_ratio": "adapt",
            "image_ratio_mobile": "adapt",
            "color_scheme": "scheme-inverse",
            "border_radius": 20,
            "enable_preload_image": false
          },
          "blocks": {}
        },
        "product_overlay_card_4": {
          "type": "product-overlay-card",
          "name": "t:names.product_overlay_card",
          "settings": {
            "product": "",
            "product_image_ratio": "1/1",
            "image_ratio": "adapt",
            "image_ratio_mobile": "adapt",
            "color_scheme": "scheme-inverse",
            "border_radius": 20,
            "enable_preload_image": false
          },
          "blocks": {}
        }
      },
      "block_order": ["product_overlay_card_1", "product_overlay_card_2", "product_overlay_card_3", "product_overlay_card_4"]
    }
  ]
}
{% endschema %}
