<style>
  @media screen and (min-width: 750px) {
    .custom-section.hide-desktop {
      display: none !important;
    }
  }
</style>

{%- liquid
  assign content_direction = section.settings.content_direction
  assign vertical_on_mobile = section.settings.vertical_on_mobile

  assign use_color_scheme_in_container = section.settings.use_color_scheme_in_container
  assign use_padding_inline = true
  if section.settings.container == 'page-width' and use_color_scheme_in_container == false
    assign use_padding_inline = false
  endif
-%}
{%- capture inline_style -%}
  {%- unless use_color_scheme_in_container -%}
  {% render 'border-style', settings: section.settings %}
  {%- endunless -%}
{%- endcapture -%}
{%- capture content_wrapper_class -%}
  custom-section__content spacing-style gap-style
  layout-panel-flex
  layout-panel-flex--{{ content_direction | default: 'column' }}
  {% if content_direction == 'row' and vertical_on_mobile %}mobile-column{% endif %}
  grid-column-gap--{{ section.settings.column_gap }}
  grid-row-gap--{{ section.settings.row_gap }}
  {% if use_color_scheme_in_container %}border-style color-{{ section.settings.color_scheme }}{% endif %}
{%- endcapture -%}
{%- capture content_wrapper_style -%}
  {%- render 'layout-panel-style', settings: section.settings, type: 'flex' -%}
  {%- render 'spacing-style', settings: section.settings, use_padding_inline: use_padding_inline -%}
  {%- render 'gap-style', settings: section.settings -%}
  {%- if use_color_scheme_in_container -%}
    {% render 'border-style', settings: section.settings %}
  {%- endif -%}
{%- endcapture -%}
<div
  class="section custom-section {{ section.settings.container }}{% if section.settings.hide_desktop %} hide-desktop{% endif %}{% unless use_color_scheme_in_container %} border-style color-{{ section.settings.color_scheme }}{% else %} inherit-color-scheme{% endunless %}"
  style="background-color: {{ section.settings.background_color }}; {{ inline_style | replace: '  ', ' ' | strip | strip_newlines }}"
>
  <div
    class="{{ content_wrapper_class | replace: '  ', ' ' | strip | strip_newlines }}"
    style="{{ content_wrapper_style | replace: '  ', ' ' | strip | strip_newlines }}"
  >
    {% content_for 'blocks' %}
  </div>
</div>
