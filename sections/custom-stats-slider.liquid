{%- liquid
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
-%}

<div id="shopify-section-{{ section.id }}" class="custom-stats-wrapper" style="
  background-color: {{ bg_color }}; 
  --text-color: {{ text_color }}; 
  --padding-top: {{ section.settings.padding_top }}px; 
  --padding-bottom: {{ section.settings.padding_bottom }}px;
  --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
">
  <div class="custom-stats-container">
    
    {% if section.settings.heading != blank %}
      <div class="custom-stats-header">
        <h2 class="custom-stats-section-heading" style="color: {{ text_color }};">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="custom-stats-slider-row">
      <div class="swiper custom-stats-swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide custom-stats-slide" {{ block.shopify_attributes }}>
              
              <div class="custom-stats-image-wrap">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 1000 }}" alt="{{ block.settings.stat_label | escape }}" loading="lazy" class="custom-stats-img">
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'custom-stats-img placeholder-svg' }}
                {% endif %}
              </div>

              <div class="custom-stats-content">
                {% if block.settings.stat_number != blank %}
                  <div class="custom-stats-number" style="color: {{ text_color }};">{{ block.settings.stat_number }}</div>
                {% endif %}

                {% if block.settings.stat_label != blank %}
                  <div class="custom-stats-label" style="color: {{ text_color }};">{{ block.settings.stat_label }}</div>
                {% endif %}

                {% if block.settings.description != blank %}
                  <p class="custom-stats-desc" style="color: {{ text_color }};">{{ block.settings.description }}</p>
                {% endif %}
              </div>

            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Bottom Navigation & Progress bar row -->
    <div class="custom-stats-controls-row">
      <div class="custom-stats-progressbar swiper-pagination"></div>
      
      <div class="custom-stats-arrows">
        <button class="custom-stats-nav-btn custom-stats-nav-btn--prev" aria-label="Previous">
          <svg width="10" height="18" viewBox="0 0 10 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 17L1 9L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="custom-stats-nav-btn custom-stats-nav-btn--next" aria-label="Next">
          <svg width="10" height="18" viewBox="0 0 10 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 17L9 9L1 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Stats Slider",
  "tag": "section",
  "class": "custom-stats-slider-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading (Optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#3D1B03"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Desktop Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Desktop Padding Bottom"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Mobile Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Mobile Padding Bottom"
    }
  ],
  "blocks": [
    {
      "type": "stat_slide",
      "name": "Stat Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Select Slide Image"
        },
        {
          "type": "text",
          "id": "stat_number",
          "label": "Stat Number/Percentage",
          "default": "2x"
        },
        {
          "type": "text",
          "id": "stat_label",
          "label": "Stat Title/Label",
          "default": "Improvement"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Stat Description",
          "default": "SONU patients showed a 2X improvement in nasal congestion symptoms compared to placebo."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Stats Slider",
      "blocks": [
        {
          "type": "stat_slide",
          "settings": {
            "stat_number": "2x",
            "stat_label": "Improvement",
            "description": "SONU patients showed a 2X improvement in nasal congestion symptoms compared to placebo."
          }
        },
        {
          "type": "stat_slide",
          "settings": {
            "stat_number": "90%",
            "stat_label": "Satisfaction",
            "description": "Over 90% of active users reported highly satisfying levels of overnight relief."
          }
        }
      ]
    }
  ]
}
{% endschema %}
