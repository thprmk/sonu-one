{{ 'sonu-custom.css' | asset_url | stylesheet_tag }}

<section 
  id="doctor-section-{{ section.id }}"
  class="doctor-section 
  desktop-{{ section.settings.desktop_layout }} 
  mobile-{{ section.settings.mobile_layout }}"
  style="
    {% if section.settings.bg_gradient != blank %}
      background: {{ section.settings.bg_gradient }};
    {% elsif section.settings.bg_color != blank %}
      background-color: {{ section.settings.bg_color }};
      background-image: none;
    {% else %}
      --grad-color-1: {{ section.settings.grad_color_1 | default: '#daf2ff' }};
      --grad-color-2: {{ section.settings.grad_color_2 | default: '#eaf8ff' }};
      --grad-color-3: {{ section.settings.grad_color_3 | default: '#f7fcff' }};
      --grad-color-4: {{ section.settings.grad_color_4 | default: '#ffffff' }};
    {% endif %}
    {% if section.settings.bg_image != blank %}
      --bg-image-desktop: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
    {% endif %}
    {% if section.settings.mobile_bg_image != blank %}
      --bg-image-mobile: url('{{ section.settings.mobile_bg_image | image_url: width: 1000 }}');
    {% elsif section.settings.bg_image != blank %}
      --bg-image-mobile: url('{{ section.settings.bg_image | image_url: width: 1000 }}');
    {% endif %}
    --padding-top: {{ section.settings.padding_top | default: 40 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 40 }}px;
    --padding-top-mobile: {{ section.settings.padding_top_mobile | default: 60 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile | default: 60 }}px;
  "
>
  <style>
    #doctor-section-{{ section.id }} {
      padding-top: var(--padding-top, 40px) !important;
      padding-bottom: var(--padding-bottom, 40px) !important;
      {% if section.settings.bg_image != blank %}
        background-image: var(--bg-image-desktop);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
      {% endif %}
    }
    @media screen and (max-width: 768px) {
      #doctor-section-{{ section.id }} {
        padding-top: var(--padding-top-mobile, 60px) !important;
        padding-bottom: var(--padding-bottom-mobile, 60px) !important;
        {% if section.settings.bg_image != blank or section.settings.mobile_bg_image != blank %}
          background-image: var(--bg-image-mobile);
        {% endif %}
      }
    }
  </style>
  {% render 'sonu-section-header',
    heading: section.settings.heading,
    heading_tag: section.settings.heading_tag,
    heading_class: '',
    text_align: 'center',
    animate: true
  %}

  <div class="doctor-wrapper">

    {% for block in section.blocks %}
      {% assign words = block.settings.desc | split: ' ' %}
      {% assign trimmed = words | slice: 0, section.settings.trim_words | join: ' ' %}

      <div class="doctor-card">

        <!-- EXACT 244x270 IMAGE -->
        <div class="img-wrap">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.name }}" />
          {% else %}
            <div style="width: 100%; height: 100%; background: #ccc;"></div>
          {% endif %}

          <div class="overlay"></div>

          <div class="img-content">
            <h4>{{ block.settings.name }}</h4>
            <p>{{ block.settings.role }}</p>
          </div>
        </div>

        <!-- INDENTED DESCRIPTION -->
        <p class="desc">{{ trimmed }}...</p>

        <!-- MODAL DATA (HIDDEN) -->
        <div class="modal-data" hidden>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.name }}">
          {% endif %}
          <h3>{{ block.settings.name }}</h3>
          <p class="role">{{ block.settings.role }}</p>
          <p>{{ block.settings.desc }}</p>
        </div>

      </div>
    {% endfor %}

  </div>

  {% if section.settings.mobile_layout == 'slider' %}
    <div class="team-slider-container hide-desktop">
      
      <!-- PROGRESS BAR (FULL WIDTH) -->
      {% render 'sonu-progress-bar',
        progress_id: 'team-progress-bar-' | append: section.id,
        container_class: 'team-progress',
        bar_class: 'team-progress-bar-card'
      %}

      <!-- ARROWS (RIGHT ALIGNED) -->
      <div class="team-arrows">
        {% render 'sonu-nav-arrows',
          prev_class: 'team-arrow-btn team-prev-btn',
          next_class: 'team-arrow-btn team-next-btn'
        %}
      </div>

    </div>
  {% endif %}

  <!-- MODAL -->
  <div class="modal" id="sonu-modal-{{ section.id }}">
    <div class="modal-box">
      <span class="close sonu-close-{{ section.id }}">&times;</span>
      <div class="modal-inner">
        <div class="left"></div>
        <div class="right"></div>
      </div>
    </div>
  </div>

</section>






{% schema %}
{
  "name": "Team Section",
  "settings": [
    { "type": "text", "id": "heading", "default": "Trusted by doctors", "label": "Heading" },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading type",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (Overrides default gradient)",
      "default": "transparent"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Background Gradient (Overrides bg color)"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg_image",
      "label": "Mobile Background Image"
    },
    {
      "type": "color",
      "id": "grad_color_1",
      "label": "Default Gradient Color 1 (Top)",
      "default": "#daf2ff"
    },
    {
      "type": "color",
      "id": "grad_color_2",
      "label": "Gradient Color 2",
      "default": "#eaf8ff"
    },
    {
      "type": "color",
      "id": "grad_color_3",
      "label": "Gradient Color 3",
      "default": "#f7fcff"
    },
    {
      "type": "color",
      "id": "grad_color_4",
      "label": "Gradient Color 4 (Bottom)",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "slider"
    },
    {
      "type": "range",
      "id": "trim_words",
      "min": 10,
      "max": 50,
      "step": 5,
      "default": 20,
      "label": "Trim words"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "Desktop Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "Desktop Padding Bottom"
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Mobile Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Mobile Padding Bottom"
    }
  ],
  "blocks": [
    {
      "type": "doctor",
      "name": "Doctor",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "role", "label": "Profession" },
        { "type": "textarea", "id": "desc", "label": "Description" }
      ]
    }
  ],
  "presets": [
    { "name": "sonu Team Section" }
  ]
}
{% endschema %}

<script src="{{ 'doctors-testimonials.js' | asset_url }}" defer="defer"></script>
