<script
  src="{{ 'testimonial-slider-element.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
{% capture children %}
  {% content_for 'blocks' %}
{% endcapture %}

{% liquid
  assign slides = children | strip_newlines | strip | split: '<!-- @testimonialItem/split -->' | compact
  assign medias = ''
  for slide in slides
    assign parts = slide | split: '<!-- @testimonialInner/split -->'
    assign medias = medias | append: parts[1]
    unless forloop.last
      assign medias = medias | append: '<!-- @testimonialMedia/split -->'
    endunless
  endfor

  assign medias_array = medias | strip_newlines | strip | split: '<!-- @testimonialMedia/split -->' | compact

  assign autoplay = section.settings.autoplay
  assign autoplay_delay = section.settings.autoplay_delay | times: 1000
%}

<div
  id="section-{{ section.id }}"
  class="section testimonials-slider spacing-style color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="section__container {{ section.settings.container }}">
    <testimonial-slider
      class="block relative"
      id="slider-{{ section.id }}"
      data-section-id="{{ section.id }}"
      data-options='{"autoplay": {{ autoplay }}, "autoplayDelay": {{ autoplay_delay }}, "pauseOnHover": false}'
    >
      <div
        class="testimonial-slider__wrapper"
        role="region"
        aria-live="polite"
      >
        <!-- Thumbnails -->
        <div
          class="testimonial-slider__thumbnails"
          ref="thumbnails"
          id="slider-thumbnails-{{ section.id }}"
        >
          {% for media in medias_array %}
            <div
              class="testimonial-slider__thumbnail{% if forloop.first %} testimonial-slider__thumbnail--active{% endif %}"
              data-index="{{ forloop.index0 }}"
            >
              {{ media }}
            </div>
          {% endfor %}
        </div>

        <!-- Main Slider -->
        <div
          class="testimonial-slider__container"
          ref="container"
          id="slider-container-{{ section.id }}"
        >
          <div
            class="testimonial-slider__track"
            ref="track"
            role="list"
            aria-atomic="false"
            id="slider-track-{{ section.id }}"
          >
            {% for slide in slides %}
              <div
                class="testimonial-slider__slide{% if forloop.first %} testimonial-slider__slide--active{% endif %}"
                data-index="{{ forloop.index0 }}"
                role="listitem"
              >
                {{ slide }}
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- Controls -->
        <div class="testimonial-slider__controls-wrapper">
          <div
            class="testimonial-slider__controls"
            ref="controls"
            id="slider-controls-{{ section.id }}"
          >
            <div
              class="testimonial-slider__counter"
              ref="counter"
              id="slider-counter-{{ section.id }}"
              aria-live="polite"
              aria-atomic="true"
            ></div>
            <div
              class="testimonial-slider__pagination"
              ref="pagination"
              id="slider-pagination-{{ section.id }}"
              role="progressbar"
              aria-label="{{ 'accessibility.slide_progress' | t }}"
            >
              <div class="testimonial-slider__progress"></div>
            </div>
            <div class="testimonial-slider__nav-buttons">
              <button
                ref="prev"
                id="slider-prevBtn-{{ section.id }}"
                class="button-unstyled testimonial-slider__button testimonial-slider__button--prev"
                data-action="prev"
                aria-label="{{ 'accessibility.slideshow_previous' | t }}"
                aria-controls="slider-track-{{ section.id }}"
              >
                {% render 'icon', icon: 'caret-left' %}
              </button>
              <button
                ref="next"
                id="slider-nextBtn-{{ section.id }}"
                class="button-unstyled testimonial-slider__button testimonial-slider__button--next"
                data-action="next"
                aria-label="{{ 'accessibility.slideshow_next' | t }}"
                aria-controls="slider-track-{{ section.id }}"
              >
                {% render 'icon', icon: 'caret-right' %}
              </button>
            </div>
          </div>
        </div>
      </div>
    </testimonial-slider>
    {%- render 'no-js-message' -%}
  </div>
</div>

