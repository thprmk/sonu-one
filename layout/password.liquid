{%- liquid
  assign language_support_rtl = settings.language_support_rtl
  if settings.enable_rtl and language_support_rtl != blank
    assign language_support_rtl_list = language_support_rtl | split: ','
    if language_support_rtl_list contains localization.language.iso_code
      assign enable_rtl = true
    endif
  endif
-%}
<!doctype html>
<html
  lang="{{ request.locale.iso_code }}"
  {% if enable_rtl %}
    dir="rtl"
  {% endif %}
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}
    {% render 'color-schemes' %}

    {% # Inline critical CSS for above-the-fold content %}
    {% render 'critical-css' %}

    {{ 'theme.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'password.css' | asset_url | stylesheet_tag }}

    {% render 'styles' %}
    {% render 'meta-tags' %}
    {% render 'fonts' %}
    {% render 'scripts' %}
    {% render 'css-nojs' %}
    {%- if enable_rtl -%}
      {{ 'rtl.css' | asset_url | stylesheet_tag: preload: true }}
    {%- endif -%}

    {{ content_for_header }}
  </head>
  <body
    {% unless settings.animations_enabled %}
      data-motion-disabled="true"
    {% endunless %}
    class="{% if settings.animations_enabled %}animations-enabled {% endif %}"
  >
    <script src="{{ 'critical.js' | asset_url }}" type="module" defer></script>
    <script src="{{ 'password-dialog.js' | asset_url }}" type="module"></script>
    {% section 'main-password-header' %}
    <main
      id="MainContent"
      class="main-content password-main-content overflow-x-clip flex-grow justify-center"
      role="main"
    >
      {{ content_for_layout }}
    </main>
    <div class="password-footer flex justify-center items-center">
      <p class="password-enter__powered-by flex items-center gap-2">
        {{ 'content.powered_by' | t }}
        <a
          href="//shopify.com"
          rel="nofollow"
          target="_blank"
          aria-label="Shopify"
          aria-describedby="a11y-new-window-message"
          class="inline-flex"
        >
          {{- 'icon-shopify.svg' | inline_asset_content -}}
        </a>
      </p>
    </div>
  </body>
</html>
