{% assign product = closest.product %}

<product-badge
  class="block product-badges spacing-style"
  data-product-id="{{ product.id }}"
  {{ block.shopify_attributes }}
  style="{% render 'spacing-style', settings: block.settings %}"
>
  {% render 'product-badges',
    product: product,
    use_variant: true,
    show_custom_badges: block.settings.show_custom_badges,
    show_soldout_badge: block.settings.show_sold_out_badge,
    show_sale_badge: block.settings.show_sale_badge,
    sale_badge_type: block.settings.sale_badge_type
  %}
</product-badge>

{% schema %}
{
  "name": "t:names.product_badges",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_badges"
    },
    {
      "type": "checkbox",
      "id": "show_custom_badges",
      "label": "t:settings.show_custom_badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sold_out_badge",
      "label": "t:settings.show_sold_out_badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "t:settings.show_sale_badge",
      "default": true
    },
    {
      "type": "select",
      "id": "sale_badge_type",
      "label": "t:settings.sale_badge_type",
      "options": [
        { "value": "text", "label": "t:options.text" },
        { "value": "percentage", "label": "t:options.percentage" },
        {
          "value": "fixed_amount",
          "label": "t:options.fixed_amount"
        }
      ],
      "default": "text",
      "visible_if": "{{ block.settings.show_sale_badge == true }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_badges",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
