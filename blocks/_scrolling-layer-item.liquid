{% liquid
  assign block_index = section.blocks | find_index: 'id', block.id
%}

{% capture item_style %}
  {% render 'clamp-calculate-style', property_name: 'padding-block', min_value: 24, max_value: 50 %}
{% endcapture %}
<div
  class="scrolling-layer-item spacing-style flex flex-col md:flex-row gap-y-7 md:gap-x-8 xl:gap-x-10 xxl:gap-x-12 color-{{ section.settings.color_scheme }}"
  style="{{ item_style | strip_newlines | strip }}"
  data-index="{{ block_index }}"
  {{ block.shopify_attributes }}
>
  <div class="scrolling-layer-item__inner flex items-start gap-x-4 md:gap-x-8 xl:gap-x-10 xxl:gap-x-12">
    {% comment %} <div class="scrolling-layer-item__icon shrink-0 flex items-center justify-center">
      {% comment %} {% render 'icon-or-image',
        icon: block.settings.icon,
        width: block.settings.icon_width,
        width_mobile: block.settings.icon_width_mobile,
        icon_size: block.settings.icon_size
      %} {% endcomment %}
    </div> {% endcomment %}
    <div class="scrolling-layer-item__content">
      {% content_for 'blocks' %}
    </div>
  </div>
  <div class="scrolling-layer-item__media border-style media-mask-clip" style="--border-radius: {{ block.settings.image_border_radius }}px;">
    {% render 'responsive-image', mode: 'liquid', image: block.settings.image, image_ratio: block.settings.image_ratio %}
  </div>
</div>
