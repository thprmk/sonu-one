{% liquid
  assign inherit_color_scheme = block.settings.inherit_color_scheme
  assign color_scheme = block.settings.color_scheme

  if inherit_color_scheme
    assign color_scheme = ''
  endif
%}
{% render 'icon-box',
  style: 'default',
  direction: 'vertical',
  text_align: block.settings.text_align,
  link: block.settings.link,
  icon: block.settings.icon,
  icon_width: block.settings.icon_width,
  icon_width_mobile: block.settings.icon_width_mobile,
  icon_size: block.settings.icon_size,
  icon_spacing: 10,
  inherit_color_scheme: inherit_color_scheme,
  color_scheme: color_scheme,
  border_radius: block.settings.border_radius,
  image_upload: block.settings.icon_image_upload,
  heading: block.settings.heading,
  heading_preset: block.settings.heading_preset,
  text: block.settings.text,
  text_color: 'subtext',
  content_row_gap: 12,
  block_attributes: block.shopify_attributes
%}
<!-- @iconBoxInner/split -->
{% render 'icon-box',
  style: 'default',
  direction: 'horizontal',
  text_align: 'left',
  link: block.settings.link,
  icon: block.settings.icon,
  icon_width: block.settings.icon_width,
  icon_width_mobile: block.settings.icon_width_mobile,
  icon_size: block.settings.icon_size,
  icon_spacing: 16,
  image_upload: block.settings.icon_image_upload,
  heading: block.settings.heading,
  heading_preset: block.settings.heading_preset,
  text: block.settings.text,
  text_color: 'subtext',
  content_row_gap: 12
%}
<!-- @iconBox/split -->
