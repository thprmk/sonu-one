{% liquid
  assign preset = block.settings.type_preset
  capture heading_classes
    if preset == 'custom'
      echo ' custom-typography '
      if block.settings.font_size != ''
        echo ' custom-font-size '
      endif
    elsif preset == 'paragraph'
      echo ' rte '
    endif
  endcapture
%}
{%- capture styles -%}
  {% render 'typography-style', settings: block.settings %}
{%- endcapture -%}
<div
  class="customer__content"
  {{ block.shopify_attributes }}
>
  <div class="rich-text">
    <h2 class="{{ preset }} {{ heading_classes }}" style="{{ styles | strip | strip_newlines }}">
      {{ 'customer.orders.title' | t }}
    </h2>
  </div>

  {% paginate customer.orders by 20 %}
    {%- if customer.orders.size > 0 -%}
      <div class="table-container table-container--mobile-scrollable fixed-side">
        <table class="table order-history">
          <caption class="visually-hidden">
            {{ 'customer.orders.title' | t }}
          </caption>
          <thead>
            <tr>
              <th id="ColumnOrder" scope="col" class="h6">
                {{ 'customer.orders.order_number' | t }}
              </th>
              <th id="ColumnDate" scope="col" class="h6">
                {{ 'customer.orders.date' | t }}
              </th>
              <th id="ColumnPayment" scope="col" class="h6">
                {{ 'customer.orders.payment_status' | t }}
              </th>
              <th id="ColumnFulfillment" scope="col" class="h6">
                {{ 'customer.orders.fulfillment_status' | t }}
              </th>
              <th id="ColumnTotal" scope="col" class="h6">
                {{ 'customer.orders.total' | t }}
              </th>
            </tr>
          </thead>
          <tbody>
            {%- for order in customer.orders -%}
              <tr>
                <td
                  id="RowOrder"
                  headers="ColumnOrder"
                  data-label="{{ 'customer.orders.order_number' | t }}"
                >
                  <a
                    href="{{ order.customer_url }}"
                    aria-label="{{ 'customer.orders.order_number_link' | t: number: order.name }}"
                    class="reversed-link"
                  >
                    <span class="reversed-link__text">{{ order.name }}</span>
                  </a>
                </td>
                <td
                  headers="RowOrder ColumnDate"
                  data-label="{{ 'customer.orders.date' | t }}"
                >
                  {{ order.created_at | time_tag: format: 'date' }}
                </td>
                <td
                  headers="RowOrder ColumnPayment"
                  data-label="{{ 'customer.orders.payment_status' | t }}"
                >
                  {{ order.financial_status_label }}
                </td>
                <td
                  headers="RowOrder ColumnFulfillment"
                  data-label="{{ 'customer.orders.fulfillment_status' | t }}"
                >
                  {{ order.fulfillment_status_label }}
                </td>
                <td
                  headers="RowOrder ColumnTotal"
                  data-label="{{ 'customer.orders.total' | t }}"
                >
                  {{ order.total_net_amount | money_with_currency }}
                </td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    {%- else -%}
      <p>{{ 'customer.orders.none' | t }}</p>
    {%- endif -%}

    {%- if paginate.pages > 1 -%}
      {%- if paginate.parts.size > 0 -%}
        <nav
          class="pagination"
          role="navigation"
          aria-label="{{ 'actions.pagination.label' | t }}"
        >
          <ul class="list-unstyled" role="list">
            {%- if paginate.previous -%}
              <li>
                <a
                  href="{{ paginate.previous.url }}"
                  aria-label="{{ 'actions.pagination.previous' | t }}"
                >
                  <svg aria-hidden="true" focusable="false" viewBox="0 0 10 6">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
                  </svg>
                </a>
              </li>
            {%- endif -%}

            {%- for part in paginate.parts -%}
              <li>
                {%- if part.is_link -%}
                  <a
                    href="{{ part.url }}"
                    aria-label="{{ 'actions.pagination.page' | t: number: part.title }}"
                  >
                    {{- part.title -}}
                  </a>
                {%- else -%}
                  {%- if part.title == paginate.current_page -%}
                    <span
                      aria-current="page"
                      aria-label="{{ 'actions.pagination.page' | t: number: part.title }}"
                    >
                      {{- part.title -}}
                    </span>
                  {%- else -%}
                    <span>{{ part.title }}</span>
                  {%- endif -%}
                {%- endif -%}
              </li>
            {%- endfor -%}

            {%- if paginate.next -%}
              <li>
                <a
                  href="{{ paginate.next.url }}"
                  aria-label="{{ 'actions.pagination.next' | t }}"
                >
                  <svg aria-hidden="true" focusable="false" viewBox="0 0 10 6">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
                  </svg>
                </a>
              </li>
            {%- endif -%}
          </ul>
        </nav>
      {%- endif -%}
    {%- endif -%}
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "t:names.account_orders",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "type_preset",
      "label": "t:settings.heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:options.h1"
        },
        {
          "value": "h2",
          "label": "t:options.h2"
        },
        {
          "value": "h3",
          "label": "t:options.h3"
        },
        {
          "value": "h4",
          "label": "t:options.h4"
        },
        {
          "value": "h5",
          "label": "t:options.h5"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "h4"
    },
    {
      "type": "select",
      "id": "font",
      "label": "t:settings.font",
      "options": [
        {
          "value": "var(--font-body--family)",
          "label": "t:options.body"
        },
        {
          "value": "var(--font-heading--family)",
          "label": "t:options.heading"
        }
      ],
      "default": "var(--font-body--family)",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "id": "font_weight",
      "type": "select",
      "label": "t:settings.font_weight",
      "default": "",
      "options": [
        {
          "value": "",
          "label": "t:options.inherit"
        },
        {
          "value": "300",
          "label": "t:options.light"
        },
        {
          "value": "400",
          "label": "t:options.regular"
        },
        {
          "value": "500",
          "label": "t:options.medium"
        },
        {
          "value": "600",
          "label": "t:options.semi_bold"
        },
        {
          "value": "700",
          "label": "t:options.bold"
        },
        {
          "value": "800",
          "label": "t:options.extra_bold"
        },
        {
          "value": "900",
          "label": "t:options.black"
        }
      ],
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "t:settings.font_size",
      "default": 15,
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "t:settings.font_size_mobile",
      "default": 15,
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "t:settings.line_height",
      "options": [
        {
          "value": "tight",
          "label": "t:options.tight"
        },
        {
          "value": "normal",
          "label": "t:options.normal"
        },
        {
          "value": "loose",
          "label": "t:options.loose"
        }
      ],
      "default": "normal",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    }
  ]
}
{% endschema %}
