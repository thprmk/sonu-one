{%- if block.settings.text != blank -%}
  {%- liquid
    assign words = block.settings.text | strip | split: ''
    assign total_words = block.settings.text | strip | split: ' ' | size
    assign str = ''
    for word in words
      assign str = str | append: word
    endfor
    if total_words > 1
      assign str = str | append: ' '
    endif
    assign str_length = str | size
    assign str_index = str_length | minus: 1

    assign text_color = block.settings.text_color
    assign text_color_gradient = block.settings.text_color_gradient | default: '#000000'
  -%}
  {%- capture inline_style -%}
    --char-length: {{ str_length }};
    {%- if text_color == 'gradient' -%}
      --color-gradient: {{ text_color_gradient }};
    {% endif %}
    {% render 'clamp-calculate-style', property_name: 'char-size', min_value: block.settings.font_size_mobile, max_value: block.settings.font_size %}
    {% render 'border-style', settings: block.settings %}
  {%- endcapture -%}
  <div
    class="spinning-icon-badge-block relative rounded border-style color-{{ block.settings.color_scheme }}"
    style="{{ inline_style }}"
    {{ block.shopify_attributes }}
  >
    {%- if str_length > 2 -%}
      <div
        class="spinning-icon-badge custom-typography"
        style="{% render 'typography-style', preset: 'custom', settings: block.settings %}"
      >
        <div class="spinning-icon-badge__chars absolute flex items-center justify-center w-full h-full z-1 color-{{ text_color }}">
          {%- for i in (0..str_index) -%}
            {%- assign char = str | slice: i, 1 -%}
            <span style="--char-id: {{ i }};">{{- char -}}</span>
          {%- endfor -%}
        </div>
        <div class="spinning-icon-badge__icon absolute rounded flex items-center justify-center">
          {% render 'icon-or-image', icon: block.settings.icon, image_upload: block.settings.image_upload %}
        </div>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}
