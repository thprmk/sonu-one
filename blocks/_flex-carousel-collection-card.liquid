{%- liquid
  assign collection = block.settings.collection
-%}
{%- capture container_width -%}{%- if section.settings.container == 'page-width--full' -%}100vw{%- else -%}(min(100vw, {{ settings.page_width | plus: 32 }}px) - 32px){%- endif -%}{%- endcapture -%}
{%- capture image_sizes -%}
  {%- if section.settings.slides_per_view == 'auto' -%}
    {%- if block.settings.width != 'fit-content' and block.settings.width_mobile != 'fit-content' -%}
      {%- liquid
        assign width = 100
        if block.settings.width == 'custom'
          assign width = block.settings.custom_width
        endif

        assign width_mobile = 100 
        if block.settings.width_mobile == 'custom'
          assign width_mobile = block.settings.custom_width_mobile
        endif

        assign width_ratio = width | divided_by: 100.0
        assign width_ratio_mobile = width_mobile | divided_by: 100.0
      -%}
      (min-width: 768px) calc({{ container_width }} * {{ width_ratio }}), calc({{ container_width }} * {{ width_ratio_mobile }})
    {%- endif -%}
  {%- else -%}
    {%- liquid
      assign columns = section.settings.columns
      assign columns_mobile = section.settings.columns_mobile | plus: 0
    -%}
    (min-width: 768px) calc({{ container_width }} / {{ columns }}), calc({{ container_width }} / {{ columns_mobile }})
  {%- endif -%}
{%- endcapture -%}
<div
  class="collection-card-block swiper-slide-custom size-style"
  style="{% render 'size-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>
  {% render 'collection-card',
    collection: collection,
    section: section,
    text_alignment: block.settings.text_alignment,
    image: block.settings.image,
    image_ratio: block.settings.image_ratio,
    image_preload: block.settings.enable_preload_image,
    image_sizes: image_sizes,
    show_product_count: block.settings.show_product_count,
    show_description: block.settings.show_description,
    description: block.settings.description,
    title: block.settings.title,
    title_preset: block.settings.title_preset
  %}
</div>
{% schema %}
{
  "name": "t:names.collection_card",
  "tag": null,
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:names.collection"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "left",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "right",
          "label": "t:options.right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:content.media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image",
      "info": "t:info.collection_image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:settings.aspect_ratio",
      "options": [
        { "value": "inherit", "label": "t:options.use_global_settings" },
        { "value": "adapt", "label": "t:options.auto" },
        { "value": "1/1", "label": "t:options.square" },
        { "value": "4/5", "label": "t:options.portrait" },
        { "value": "3/4", "label": "t:options.portrait_3_4" },
        { "value": "16/9", "label": "t:options.landscape" },
        { "value": "4/3", "label": "t:options.landscape_4_3" }
      ],
      "default": "inherit"
    },
    {
      "type": "header",
      "content": "t:content.content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:settings.title",
      "info": "t:info.collection_title"
    },
    {
      "type": "select",
      "id": "title_preset",
      "label": "t:settings.title_preset",
      "options": [
        {
          "value": "h3",
          "label": "t:options.h3"
        },
        {
          "value": "h4",
          "label": "t:options.h4"
        },
        {
          "value": "h5",
          "label": "t:options.h5"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        }
      ],
      "default": "h6"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "t:settings.show_product_count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "t:settings.show_description",
      "default": false
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:settings.description",
      "info": "t:info.collection_description",
      "visible_if": "{{ block.settings.show_description == true }}"
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit"
        },
        {
          "value": "fill",
          "label": "t:options.fill"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fill"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "t:settings.width_mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit"
        },
        {
          "value": "fill",
          "label": "t:options.fill"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fill"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == 'custom' }}"
    },
    {
      "type": "header",
      "content": "t:content.advanced"
    },
    {
      "type": "checkbox",
      "id": "enable_preload_image",
      "label": "t:settings.enable_preload_image",
      "info": "t:info.enable_preload_image"
    }
  ],
  "presets": [
    {
      "name": "t:names.collection_card",
      "category": "t:categories.collection"
    }
  ]
}
{% endschema %}
