{%- liquid
  assign wrap_tag = 'div'
  if block.settings.link != blank
    assign wrap_tag = 'a'
  endif
-%}
<{{ wrap_tag }}
  class="image-stack block rounded overflow-hidden relative z-1 shrink-0"
  {% if block.settings.link != blank %}
    href="{{ block.settings.link }}"
  {% endif %}
  {{ block.shopify_attributes }}
>
  {% render 'responsive-image', mode: 'liquid', image: block.settings.image, default_alt: shop.name, widths: '60, 120', sizes: '60px' %}
</{{ wrap_tag }}>
{% schema %}
{
  "name": "t:names.image",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    }
  ],
  "presets": [
    {
      "name": "t:names.image"
    }
  ]
}
{% endschema %}
