{%- liquid
  assign block_index = section.blocks | find_index: 'id', block.id
  assign section_index = section.index

  assign loading = 'lazy'
  if block_index == 0 and section_index <= 3
    assign loading = 'eager'
  endif

  assign fetchpriority = 'low'
  if block_index == 0 and section_index == 1
    assign fetchpriority = 'high'
  endif

  assign image_desktop = block.settings.image
  assign image_mobile = block.settings.image_mobile
  assign aspect_ratio = image_desktop.aspect_ratio | default: '16/9'
  assign aspect_ratio_mobile = image_mobile.aspect_ratio | default: aspect_ratio

  assign slide_height = section.settings.slide_height
  assign section_container = section.settings.container
  assign content_position = section.settings.content_position

  assign media_wrap_tag = 'div'
  if settings.animations_enabled
    assign media_wrap_tag = 'motion-component'
  endif

  assign dialog_component_id = 'dialog-component--' | append: block.id
  assign dialog_id = 'dialog--' | append: block.id

  assign product_list = block.settings.product_list
  assign product_count = product_list.count

  if product_list == blank
    assign product_count = 2
  endif
-%}
{%- capture style -%}
  --ratio: {{ aspect_ratio }};
  --ratio-mobile: {{ aspect_ratio_mobile }};
{%- endcapture -%}
<div
  class="lookbook-slide__block swiper-slide"
  ref="slides[]"
  data-color-scheme="color-{{ block.settings.color_scheme }}"
  {{ block.shopify_attributes }}
>
  <div class="lookbook-slide{% if section_container == 'full' and content_position == 'inside' %} section-grid{% else %} grid{% endif %}">
    <div class="lookbook-slide__media relative row-span-full col-span-full overflow-hidden">
      {%- if image_desktop == blank -%}
        <{{ media_wrap_tag }}
          class="slide__media-placeholder h-full{% if image_mobile != blank %} hidden md:block{% else %} block{% endif %}"
          {% if settings.animations_enabled %}
            data-motion="zoom-out"
          {% endif %}
        >
          <div
            class="media w-full h-full overflow-hidden"
            {% if slide_height == 'adapt' %}
              style="{{ style }}"
            {% endif %}
          >
            {% capture current %}{% cycle 1, 2 %}{% endcapture %}
            {{ 'lifestyle-' | append: current | placeholder_svg_tag: 'placeholder w-full h-full' }}
          </div>
        </{{ media_wrap_tag }}>
      {%- endif -%}
      {%- if image_desktop != blank or image_mobile != blank -%}
        {%- liquid
          assign widths = '480, 535, 640, 750, 767, 828, 960, 1024, 1280, 1440, 1680, 1920, 2560, 3840'
          assign width_values = widths | split: ','
        -%}

        {%- capture sizes -%}
          {%- if section_container == 'full' -%}100vw{%- else -%}min({{ settings.page_width }}, 100vw){%- endif -%}
        {%- endcapture -%}

        {% capture mobile_srcset %}
          {%- if image_mobile != blank -%}
            {%- for w in width_values -%}
              {%- assign w_int = w | strip -%}
              {{ image_mobile | image_url: width: w_int }} {{ w_int }}w{%- unless forloop.last -%}, {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}
        {% endcapture %}

        <{{ media_wrap_tag }}
          class="w-full h-full block{% if image_desktop == blank %} md:hidden{% endif %}"
          {% if settings.animations_enabled %}
            data-motion="zoom-out"
            data-motion-hold
          {% endif %}
        >
          <picture
            class="media w-full h-full overflow-hidden"
            {% if slide_height == 'adapt' %}
              style="{{ style }}"
            {% endif %}
          >
            {%- if image_desktop != blank and image_mobile != blank -%}
              <source
                media="(max-width: 767px)"
                srcset="{{ mobile_srcset | strip | strip_newlines }}"
                width="{{ image_mobile.width }}"
                height="{{ image_mobile.height }}"
                sizes="{{ sizes }}"
              >
            {%- endif -%}
            {%- liquid
              if image_desktop == blank
                assign image_desktop = image_mobile
              endif

              assign image_desktop_height = image_desktop.width | divided_by: image_desktop.aspect_ratio | ceil
              assign image_desktop_alt = image_desktop.alt | default: shop.name | escape
            -%}
            {{-
              image_desktop
              | image_url: width: image_desktop.width
              | image_tag:
                loading: loading,
                width: image_desktop.width,
                height: image_desktop_height,
                alt: image_desktop_alt,
                fetchpriority: fetchpriority,
                class: 'media__image',
                sizes: sizes,
                widths: widths
            -}}
          </picture>
        </{{ media_wrap_tag }}>
      {%- endif -%}
      {%- if block.settings.toggle_overlay -%}
        <div
          class="overlay overlay--solid absolute inset-0 pointer-events-none"
          style="--overlay-layer: var(--layer-flat);--overlay-color: {{ block.settings.overlay_color.rgb }};--overlay-color-alpha: {{ block.settings.overlay_color.alpha }};"
        ></div>
      {%- endif -%}
    </div>
    <div class="lookbook-slide__content relative col-span-full content-overlay-style">
      <div class="flex items-end justify-between gap-2 md:gap-3 w-full">
        <div class="lookbook-slide__content-inner color-{{ block.settings.color_scheme }}">
          <div class="lookbook-slide__heading">
            {%- if block.settings.heading != blank -%}
              {%- liquid
                assign heading = block.settings.heading
                assign heading_preset = block.settings.heading_preset
              -%}
              <h2 class=" flex-grow {{ heading_preset }}">{{ heading }}</h2>
            {%- endif -%}
          </div>
        </div>
        {%- capture product_cards -%}
          <ul class="lookbook-slide__products list-unstyled w-full flex flex-col">
            {%- if product_list != blank -%}
              {%- for product in block.settings.product_list -%}
                <li class="lookbook-slide__product">
                  {% render 'product-card-horizontal',
                    product: product,
                    media_width_desktop: 90,
                    image_ratio: section.settings.pcard_image_ratio,
                    show_badges: section.settings.pcard_show_badges,
                    show_vendor: section.settings.pcard_show_vendor,
                    show_type: section.settings.pcard_show_type
                  %}
                </li>
              {%- endfor -%}
            {%- else -%}
              {%- for i in (1..product_count) -%}
                <li class="lookbook-slide__product">
                  {% render 'product-card-horizontal',
                    product: blank,
                    media_width_desktop: 90,
                    image_ratio: section.settings.pcard_image_ratio,
                    show_badges: section.settings.pcard_show_badges,
                    show_vendor: section.settings.pcard_show_vendor,
                    show_type: section.settings.pcard_show_type
                  %}
                </li>
              {%- endfor -%}
            {%- endif -%}
          </ul>
        {%- endcapture -%}
        <lookbook-slide-popover
          class="lookbook-slide__popover-wrapper shrink-0 flex flex-col justify-end relative"
          {% if product_count > 0 %}
            open
          {% endif %}
        >
          {%- if product_count > 0 -%}
            <div
              ref="popover"
              class="lookbook-slide__popover w-full hidden md:flex flex-col border-style color-{{ block.settings.popover_color_scheme }}"
              style="{% render 'border-style', border_radius: settings.dialog_radius  %}"
            >
              <div class="lookbook-slide__popover-header flex items-center justify-between gap-2">
                <p class="lookbook-slide__popover-heading h6 m-0">{{ 'content.shop_item_count' | t: count: product_count }}</p>
                <button
                  on:click="/closePopover"
                  class="lookbook-slide__popover-close button-unstyled cursor-pointer flex items-center justify-center relative"
                  aria-label="{{ 'actions.close' | t }}"
                >
                  {% render 'icon', icon: 'close', size: 'large' %}
                </button>
              </div>
              <div class="lookbook-slide__popover-body flex-1 v-scrollable" data-lenis-prevent>
                {{ product_cards }}
              </div>
            </div>

            <dialog-component id="{{ dialog_component_id }}" ref="dialogComponent">
              <dialog
                id="{{ dialog_id }}"
                ref="dialog"
                class="lookbook-slide__dialog dialog dialog--modal dialog--drawer-mobile-bottom overflow-hidden{% unless settings.dialog_color_scheme_inherit %} color-{{ settings.dialog_color_scheme }}{% endunless %}"
                scroll-lock
              >
                <button
                  class="dialog__close dialog__close--absolute"
                  on:click="/closeDialog"
                  aria-label="{{ 'accessibility.close_dialog' | t }}"
                >
                  {% render 'icon', icon: 'close', size: 'large' %}
                </button>
                <div class="dialog__content flex flex-col">
                  <div class="dialog__header flex items-center justify-between gap-2">
                    <p class="lookbook-slide__popover-heading h6 m-0">{{ 'content.shop_item_count' | t: count: product_count }}</p>
                  </div>
                  <div class="dialog__body flex-1 v-scrollable">
                    {{ product_cards }}
                  </div>
                </div>
              </dialog>
            </dialog-component>
          {%- endif -%}
          <div class="color-{{ block.settings.color_scheme }}">
            <button
              on:click="/openPopover"
              class="lookbook-slide__popover-toggle btn btn--secondary btn--medium absolute bottom-0 right-0"
              {% if product_count < 1 %}
                disabled
              {% endif %}
              aria-label="{{ 'content.item_count' | t: count: product_count }}"
            >
              {% render 'icon', icon: 'tag' %}
              <span class="btn__text hidden md:block">
                {{ 'content.item_count' | t: count: product_count }}
              </span>
              <span class="btn__text block md:hidden">
                {{ product_count }}
              </span>
            </button>
          </div>
        </lookbook-slide-popover>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "t:names.lookbook",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:settings.image_mobile"
    },
    {
      "type": "checkbox",
      "id": "toggle_overlay",
      "label": "t:settings.media_overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:settings.overlay_color",
      "alpha": true,
      "default": "#00000033",
      "visible_if": "{{ block.settings.toggle_overlay }}"
    },
    {
      "type": "header",
      "content": "t:content.content"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "t:settings.products",
      "limit": 12
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "<p>Shop The Look</p>"
    },
    {
      "type": "select",
      "id": "heading_preset",
      "label": "t:settings.heading_preset",
      "options": [
        {
          "value": "h1",
          "label": "t:options.h1"
        },
        {
          "value": "h2",
          "label": "t:options.h2"
        },
        {
          "value": "h3",
          "label": "t:options.h3"
        },
        {
          "value": "h4",
          "label": "t:options.h4"
        },
        {
          "value": "h5",
          "label": "t:options.h5"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        }
      ],
      "default": "h1"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "t:names.popover"
    },
    {
      "type": "color_scheme",
      "id": "popover_color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "t:names.lookbook",
      "category": "t:categories.product_list"
    }
  ]
}
{% endschema %}
