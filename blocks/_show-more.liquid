{% doc %}
  @param {string} children - Children content
{% enddoc %}
{% liquid
  assign show_more_button_label = 'actions.show_more' | t
  assign show_less_button_label = 'actions.show_less' | t
%}
{%- capture button_attributes -%}ref="showMoreButton" on:click="/toggle" data-show-more-label="{{ show_more_button_label | escape }}" data-show-less-label="{{ show_less_button_label | escape }}"{%- endcapture -%}

<show-more-wrapper-component class="block" data-max-height="{{ block.settings.limit_height }}">
  {{ children }}
  <div
    class="show-more-button absolute left-0 bottom-0 w-full flex justify-center items-end spacing-style"
    style="{%- render 'clamp-calculate-style', property_name: 'padding-block-end', min_value: block.settings.padding-block-end-mobile, max_value: block.settings.padding-block-end, max_breakpoint: 1455 -%}"
    ref="showMoreButtonWrapper"
    {{ block.shopify_attributes }}
  >
    {% render 'button',
      with_wrapper: false,
      tag: 'button',
      label: show_more_button_label,
      style: block.settings.style,
      size: block.settings.size,
      icon: block.settings.icon,
      icon_style: block.settings.icon_style,
      icon_only: block.settings.icon_only,
      mobile_full_width: block.settings.mobile_full_width,
      attributes: button_attributes
    %}
  </div>
</show-more-wrapper-component>

{% stylesheet %}
  .show-more-button {
    background: linear-gradient(180deg, rgb(var(--color-background) / 0%) 0%, rgb(var(--color-background) / 100%) 60%);
    height: 25svh;
    z-index: 1;
    padding-inline: var(--page-padding);
  }

  .show-more-button--expanded {
    --padding-block-start-mobile: 2.4rem;
    --padding-block-start: 6rem;

    position: relative;
    background: none;
    height: auto;
    padding-bottom: 0;
  }
{% endstylesheet %}

