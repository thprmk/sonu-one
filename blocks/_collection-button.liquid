{%- liquid
  assign closest_collection = closest.collection
  assign collection_url = closest_collection.url
-%}
{% render 'button',
  label: block.settings.label,
  link: collection_url,
  style: block.settings.style,
  size: block.settings.size,
  icon: block.settings.icon,
  icon_style: block.settings.icon_style,
  icon_only: block.settings.icon_only,
  mobile_full_width: block.settings.mobile_full_width,
  block: block
%}
{% schema %}
{
  "name": "t:names.button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:settings.label"
