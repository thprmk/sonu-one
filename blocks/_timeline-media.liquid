{% liquid
  assign main_image = block.settings.image_1
  assign main_image_width = block.settings.image_width_1
  assign main_image_ratio = block.settings.image_ratio_1

  assign second_image = block.settings.image_2
  assign second_image_ratio = block.settings.image_ratio_2

  if main_image_ratio == 'adapt'
    assign main_image_ratio = main_image.aspect_ratio | default: 1
  else
    assign ratio = main_image_ratio | split: '/'
    assign width = ratio[0] | plus: 0.0
    assign height = ratio[1] | plus: 0.0
    assign main_image_ratio = width | divided_by: height
  endif

  if second_image_ratio == 'adapt'
    assign second_image_ratio = second_image.aspect_ratio | default: 1
  else
    assign ratio = second_image_ratio | split: '/'
    assign width = ratio[0] | plus: 0.0
    assign height = ratio[1] | plus: 0.0
    assign second_image_ratio = width | divided_by: height
  endif

  # The ratio of the image height to the wrapper height in %
  assign percent = 89

  if main_image_ratio >= 1
    assign percent = 75
  endif

  if second_image != blank
    if second_image_ratio >= 1 and main_image_ratio >= 1 or second_image_ratio < 1 and main_image_ratio < 1
      assign percent = 89
    endif
  endif

  assign main_image_ratio = main_image_ratio | plus: 0.0
  assign wrapper_ratio = main_image_ratio | times: percent | divided_by: main_image_width
%}
<div
  class="timeline-media-block timeline-media relative"
  style="--block-ratio: {{ wrapper_ratio }};"
  {{ block.shopify_attributes }}
>
  <div
    class="timeline-media__image timeline-media__image--first"
    style="--width: 100%; --border-radius: {{ block.settings.image_border_radius_1 }}px;"
  >
    {% content_for 'block', type: 'spinning-icon-badge', id: 'spinning-icon-badge' %}

    <div class="media-mask-clip border-style">
      {% render 'responsive-image',
        mode: 'js',
        image: block.settings.image_1,
        image_ratio: block.settings.image_ratio_1
      %}
    </div>
  </div>
</div>

<style>
.timeline-media {
  display: flex;
  justify-content: center;
  align-items: center;
}

.timeline-media__image--first {
  position: relative !important;
  width: 100% !important;
  max-width: 600px;
  margin: 0 auto !important;
  left: auto !important;
  right: auto !important;
}

.timeline-media__image--secondary {
  display: none !important;
}
</style>

