{%- liquid
  capture subheading
    content_for 'block', type: '_simple-text', id: 'subheading'
  endcapture
  capture heading
    content_for 'block', type: '_simple-text', id: 'heading'
  endcapture
  capture text
    content_for 'block', type: '_simple-text', id: 'text'
  endcapture
  capture button
    content_for 'block', type: 'button', id: 'button'
  endcapture
  capture badge
    content_for 'blocks'
  endcapture

  assign loading = 'lazy'
  assign fetchpriority = 'low'
  if block.settings.image_preload
    assign loading = 'eager'
    assign fetchpriority = 'high'
  endif
-%}
{%- capture card_image_sizes -%}(min-width: 768px) 520px, 100vw{%- endcapture -%}
{%- capture card_image -%}
  <div class="image-card__media-wrapper relative w-full h-full">
    {% render 'responsive-image',
      mode: 'liquid',
      sizes: card_image_sizes,
      image: block.settings.image,
      image_mobile: block.settings.image_mobile,
      image_ratio: block.settings.image_ratio,
      image_ratio_mobile: block.settings.image_ratio_mobile,
      default_alt: shop.name,
      loading: loading,
      fetchpriority: fetchpriority
    %}
    {%- if block.settings.toggle_overlay -%}
      {% render 'overlay', overlay_color: block.settings.overlay_color %}
    {%- endif -%}
  </div>
{%- endcapture -%}

<div
  class="scrolling-card-layered__card-inner border-style color-{{ section.settings.color_scheme }}"
  style="{% render 'border-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>
  {% render 'image-card',
    mode: 'dynamic',
    card_link: block.settings.card_link,
    card_image: card_image,
    subheading: subheading,
    heading: heading,
    text: text,
    button: button,
    card_badge: badge,
    card_badge_color: block.settings.card_label_text_color.rgb,
    settings: block.settings
  %}
</div>

{% schema %}
{
  "name": "t:names.image_card",
  "tag": null,
