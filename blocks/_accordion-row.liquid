<details
  ref="item[]"
  class="accordion__details{% if block.settings.open_row_by_default %} is-open{% endif %}"
  {% if block.settings.open_row_by_default %}
    open
  {% endif %}
  {{ block.shopify_attributes }}
>
  <summary ref="summary[]" class="accordion__summary flex" on:click="/onSummaryClick">
    <span class="accordion__summary-text">
      {% if block.settings.icon != 'none' or block.settings.image_upload != blank %}
        {% render 'icon-or-image',
          icon: block.settings.icon,
          image_upload: block.settings.image_upload,
          class_name: 'accordion__summary-icon',
          width: block.settings.width,
          width_mobile: block.settings.width_mobile,
          attributes: block.shopify_attributes,
          icon_size: block.settings.icon_size
        %}
      {% endif %}
      {{ block.settings.text }}
    </span>
    {% render 'icon', icon: 'caret-down', class: 'flex shrink-0 accordion__summary-arrow icon--caret' %}
    {% render 'icon', icon: 'plus', class: 'flex shrink-0 accordion__summary-arrow' %}
  </summary>
  <div ref="content[]" class="accordion__content">
    <div class="accordion__inner">
      {% content_for 'blocks' %}
    </div>
  </div>
</details>
