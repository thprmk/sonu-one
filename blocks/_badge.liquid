{% capture subtext %}
  {% if block.settings.subtext != blank %}
    {% render 'text', 
      text: block.settings.subtext, 
      preset: block.settings.subtext_type_preset, 
      font_size: block.settings.subtext_font_size, 
      font_size_mobile: block.settings.subtext_font_size_mobile, 
      font_family: block.settings.subtext_font, 
      font_weight: block.settings.subtext_font_weight,
      line_height: block.settings.subtext_line_height,
      class: 'badge-subtext'
    %}
  {% endif %}
{% endcapture %}

{% capture text %}
  {% render 'text', block: block, class: 'badge-text' %}
{% endcapture %}

{% capture style %}
  --text-color: {{ block.settings.text_color }};--subtext-color: {{ block.settings.subtext_text_color }};
{% endcapture %}

{% render 'badge',
  mode: 'float',
  text: text,
  subtext: subtext,
  settings: block.settings,
  style: style,
  shopify_attributes: block.shopify_attributes
%}

