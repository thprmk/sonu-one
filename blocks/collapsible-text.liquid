{%- liquid
  assign is_read_more = false
  assign wrap_tag = 'div'
  if block.settings.line_limit != 'none'
    assign is_read_more = true
    assign wrap_tag = 'read-more'
  endif
-%}
{%- capture children -%}
  {% render 'text', block: block %}
{%- endcapture -%}
<{{ wrap_tag }}
  class="read-more flex flex-col items-start gap-3"
  {%- if is_read_more -%}
    data-toggle-class="text-limit-{{ block.settings.line_limit }}"
    data-show-text="{{ 'content.view_more' | t }}"
    data-hide-text="{{ 'content.view_less' | t }}"
  {% endif %}
  {{ block.shopify_attributes }}
>
  {%- if is_read_more -%}
    <div
      class="read-more__content relative"
      ref="readMoreContent"
    >
      {{ children }}
    </div>
    <button
      ref="readMoreButton"
      on:click="/onToggleClick"
      class="read-more__toggle no-js-hidden btn btn--medium btn--{{ block.settings.button_style }}"
    >
      <span ref="readMoreButtonText" class="btn__text">{{ 'content.view_more' | t }}</span>
    </button>
  {%- else -%}
    {{ children }}
  {%- endif -%}
</{{ wrap_tag }}>

