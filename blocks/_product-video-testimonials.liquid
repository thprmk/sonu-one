{%- liquid
  assign product_resource = closest.product
  assign testimonials = product_resource.metafields.foxtheme.video_testimonials.value
  assign number_testimonials = testimonials | size
-%}
{%- if testimonials != blank -%}
  <link
    rel="stylesheet"
    href="{{ 'product-video-testimonials.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript>{{ 'product-video-testimonials.css' | asset_url | stylesheet_tag }}</noscript>
  <script
    src="{{ 'product-video-testimonials.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
  {%- liquid
    unless settings.dialog_color_scheme_inherit
      assign dialog_color_scheme = settings.dialog_color_scheme
    else
      assign first_color_scheme = settings.color_schemes | first
      assign dialog_color_scheme = first_color_scheme
    endunless

    assign thumbnails_html = ''
    assign toggles_html = ''
    assign slides_html = ''
  -%}
  {%- capture dialog_component_id -%}dialog-component--{{ section.id }}-{{ block.id }}{%- endcapture -%}
  {%- capture dialog_id -%}dialog--{{ section.id }}-{{ block.id }}{%- endcapture -%}
  {%- for testimonial in testimonials -%}
    {%- liquid
      assign testimonial_image = testimonial.image.value
      assign testimonial_video = testimonial.video.value
    -%}

    {%- capture toggle_html -%}
      <div class="video-testimonial__toggle-wrap">
        <button
          class="button-unstyled video-testimonial__toggle cursor-pointer media-hover--scale rounded overflow-hidden"
          is="toggle-video-testimonials"
          data-index={{ forloop.index0 }}
          aria-controls="{{ dialog_id }}"
          aria-haspopup="true"
          aria-label="{{ 'accessibility.toggle_content' | t }}"
        >
          <div class="video-testimonial__toggle-media rounded media-mask-clip">
            {% render 'responsive-image',
              mode: 'liquid',
              image: testimonial_image,
              image_ratio: '1/1',
              default_alt: shop.name,
              sizes: '78px',
              widths: '78, 156' 
            %}
          </div>
        </button>
      </div>
      {%- endcapture -%}
    {%- assign toggles_html = toggles_html | append: toggle_html -%}

    {%- capture thumbnail_html -%}
      <div class="video-testimonial__thumbnail swiper-slide carousel__thumbnail media-hover--scale rounded focus-within--absolute">
        <button type="button" class="video-testimonial__thumbnail-media button-unstyled cursor-pointer rounded media-mask-clip">
          {% render 'responsive-image',
            mode: 'liquid',
            image: testimonial_image,
            image_ratio: '1/1',
            default_alt: shop.name,
            sizes: '78px',
            widths: '78, 156'
          %}
        </button>
      </div>
    {%- endcapture -%}
    {%- assign thumbnails_html = thumbnails_html | append: thumbnail_html -%}

    {%- capture slide_html -%}
      <div
        class="video-testimonial media swiper-slide relative z-0"
        style="--ratio: {{ block.settings.video_ratio }};"
      >
        {%- capture video_poster_sizes -%}calc(min(100vw, 362px) - 32px){%- endcapture -%}
        {% render 'video',
          disable_controls: true,
          enable_toggle_button: true,
          enable_toggle_volume_button: true,
          video: testimonial_video,
          video_loop: true,
          video_autoplay: true,
          video_preview_image: testimonial_video.preview_image,
          video_overlay: block.settings.toggle_video_overlay,
          video_overlay_color: block.settings.video_overlay_color,
          sizes: video_poster_sizes,
          widths: '330, 660, 990, 1320',
          video_ratio: 'inherit',
          section_id: section.id
        %}
        {%- liquid
          assign featured_media = product_resource.featured_media
          assign featured_media_alt = product_resource.featured_media.alt
          assign featured_media_type = featured_media.media_type
          if featured_media_type == 'model' or featured_media_type == 'video'
            assign featured_media = product_resource.featured_media.preview_image
          endif
  
          assign has_quick_add = false
          assign show_quick_add = settings.pcard_show_quick_add
          assign show_quick_add_mobile = settings.pcard_show_quick_add_mobile
          if product.available
            if show_quick_add or show_quick_add_mobile
              assign has_quick_add = true
            endif
          endif
        -%}
        {%- capture card_style -%}
          {%- if has_quick_add -%}
          --quick-add-display: {% if show_quick_add %}flex{% else %}none{% endif %};
          --quick-add-display-mobile: {% if show_quick_add_mobile %}flex{% else %}none{% endif %};
          {%- endif -%}
        {%- endcapture -%}
        <div
          class="video-testimonial__product-card absolute z-2 flex items-center gap-3 color-scheme-inverse"
          style="{{ card_style }}"
        >
          <div class="video-testimonial__product-card__image-wrap shrink-0">
            <a
              class="video-testimonial__product-card__image block media-mask-clip"
              href="{% render 'product-card-variant-url', product: product_resource %}"
              aria-label="{{ product_resource.title | escape }}"
              tabindex="-1"
            >
              {% render 'responsive-image',
                mode: 'liquid',
                image: featured_media,
                default_alt: featured_media_alt,
                image_ratio: '1/1',
                sizes: '50px',
                widths: '100, 150, 200',
                svg_placeholder: 'product-1',
                img_class: 'w-full',
                use_hover: false
              %}
            </a>
          </div>
          <div class="video-testimonial__product-card__info flex-grow flex flex-col gap-1">
            <a
              class="video-testimonial__product-card__title reversed-link text-limit-1-line"
              href="{% render 'product-card-variant-url', product: product_resource %}"
              tabindex="-1"
            >
              <span class="reversed-link__text">{{ product_resource.title }}</span>
            </a>
            {% render 'price',
              ref: false,
              show_unit_price: true,
              use_variant: false,
              product_resource: product_resource
            %}
          </div>
          {%- if has_quick_add -%}
            <div class="video-testimonial__product-card__action product-card__action shrink-0">
              {% render 'quick-add',
                product: product,
                section_id: section.id,
                block: block,
                button_icon: 'cart',
                button_style: 'icon_only',
                button_size: 'medium',
                mode: 'combine'
              %}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endcapture -%}
    {%- assign slides_html = slides_html | append: slide_html -%}
  {%- endfor -%}
  <div
    class="video-testimonials-block flex flex-col gap-3"
    {{ block.shopify_attributes }}
  >
    {%- if block.settings.heading != blank -%}
      <h2 class="video-testimonials__heading {{ block.settings.heading_preset }}">
        {{ block.settings.heading }}
      </h2>
    {%- endif -%}
    <div class="video-testimonials__videos">
      <div is="swipe-component" class="edge__shadows">
        <div
          class="video-testimonials__toggles swipe__element swipe-all swipe-all--auto-cols"
          style="{% render 'gap-style', column_gap: 8, column_gap_mobile: 8 %}"
        >
          <div class="swipe__inner">{{ toggles_html }}</div>
        </div>
      </div>
      <dialog-component id="{{ dialog_component_id }}">
        <dialog
          id="{{ dialog_id }}"
          ref="dialog"
          class="video-testimonials__dialog dialog dialog--modal dialog--drawer-mobile-bottom overflow-hidden color-{{ dialog_color_scheme }}"
          scroll-lock
        >
          <button
            class="dialog__close dialog__close--absolute"
            on:click="/closeDialog"
            aria-label="{{ 'accessibility.close_dialog' | t }}"
          >
            {% render 'icon', icon: 'close', size: 'large' %}
          </button>
          <div class="dialog__content flex flex-col gap-3">
            {%- if block.settings.heading != blank -%}
              <h2 class="{{ block.settings.heading_preset }}">
                {{ block.settings.heading }}
              </h2>
            {%- endif -%}
            <flex-carousel
              class="carousel carousel--grid w-full"
              style="{% render 'gap-style', column_gap: 8, column_gap_mobile: 8 %};--f-columns-xxl: 1; --f-columns-mobile: 1;"
            >
              <script type="application/json" ref="config">
                {
                  "slidesPerView": 1,
                  "spaceBetween": 8,
                  "loop": false,
                  "autoplay": false,
                  "counter": false,
                  "thumbnails": {
                    "enabled": true,
                    "slidesPerView": "auto",
                    "spaceBetween": 4
                  },
                  "mousewheel": {
                    "enabled": true,
                    "forceToAxis": true,
                    "thresholdTime": 300,
                    "thresholdDelta": 10
                  }
                }
              </script>
              <div ref="thumbnails" class="video-testimonials__thumbnails edge__shadows z-0">
                <div class="swiper carousel__thumbnails-swiper">
                  <div class="swiper-wrapper">
                    {{ thumbnails_html }}
                  </div>
                </div>
              </div>
              <div
                class="video-testimonials__slider relative border-style"
                style="{% render 'border-style', border_radius: block.settings.video_border_radius %}"
              >
                <div class="swiper" ref="container">
                  <div class="swiper-wrapper">
                    {{ slides_html }}
                  </div>
                </div>
                {%- if number_testimonials > 1 -%}
                  {% render 'carousel-controls',
                    ref: 'controls',
                    type: 'absolute',
                    navigation_inside: true,
                    navigation_size: 'small',
                    pagination: false,
                    counter: false
                  %}
                {%- endif -%}
              </div>
            </flex-carousel>
          </div>
        </dialog>
      </dialog-component>
    </div>
  </div>
{%- endif -%}
{% schema %}
{
  "name": "t:names.video_testimonials",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Video testimonials"
    },
    {
      "type": "select",
      "id": "heading_preset",
      "label": "t:settings.preset",
      "options": [
        {
          "value": "h3",
          "label": "t:options.h3"
        },
        {
          "value": "h4",
          "label": "t:options.h4"
        },
        {
          "value": "h5",
          "label": "t:options.h5"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        }
      ],
      "default": "h5"
    },
    {
      "type": "header",
      "content": "t:content.video"
    },
    {
      "type": "select",
      "id": "video_ratio",
      "label": "t:settings.aspect_ratio",
      "options": [
        {
          "value": "1/1",
          "label": "t:options.square"
        },
        {
          "value": "4/5",
          "label": "t:options.portrait"
        },
        {
          "value": "3/4",
          "label": "t:options.portrait_3_4"
        },
        {
          "value": "9/16",
          "label": "t:options.portrait_9_16"
        }
      ],
      "default": "9/16"
    },
    {
      "type": "checkbox",
      "id": "toggle_video_overlay",
      "label": "t:settings.media_overlay"
    },
    {
      "type": "color",
      "id": "video_overlay_color",
      "label": "t:settings.overlay_color",
      "alpha": true,
      "default": "#0000001a",
      "visible_if": "{{ block.settings.toggle_video_overlay }}"
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:names.video_testimonials",
      "category": "t:categories.basic"
    }
  ]
}
{% endschema %}
