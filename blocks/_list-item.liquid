<li
  class="list-item-block list-item inline-flex gap-3"
  {{ block.shopify_attributes }}
>
  <div class="list-item__icon inline-flex items-center shrink-0">
    {%- render 'text', block: block, text: '&nbsp;' -%}
    {%- render 'icon',
      icon: block.settings.icon,
      size: block.settings.icon_size,
      width: block.settings.icon_width,
      width_mobile: block.settings.icon_width_mobile
    %}
  </div>
  {%- render 'text', block: block -%}
</li>
