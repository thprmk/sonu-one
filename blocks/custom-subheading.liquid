{% capture highlighted_text %}
  {{ block.settings.text
    | replace: '[[', '<span class="sonu-highlight">'
    | replace: ']]', '</span>'
  }}
{% endcapture %}

{% render 'text',
  block: block,
  text: highlighted_text
%}
{% schema %}
{
  "name": "Custom Subheading",
  "tag": null,
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Subheading Text",
      "default": "<p>Your subheading here</p>"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text Transform",
      "options": [
        {
          "value": "none",
          "label": "Normal"
        },
        {
          "value": "uppercase",
          "label": "UPPERCASE"
        },
        {
          "value": "lowercase",
          "label": "lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "none"
    },
    {
      "type": "text_alignment",
      "id": "custom_text_alignment",
      "label": "Text Alignment",
      "default": "left"
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "Typography",
      "options": [
        {
          "value": "text-subheading",
          "label": "Subheading"
        },
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        }
      ],
      "default": "text-subheading"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
        {
          "value": "fit-content",
          "label": "Fit Content"
        },
        {
          "value": "100%",
          "label": "Full Width"
        }
      ],
      "default": "100%"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "Width Mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "Fit Content"
        },
        {
          "value": "100%",
          "label": "Full Width"
        }
      ],
      "default": "100%"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Color",
      "options": [
        {
          "value": "text",
          "label": "Text"
        },
        {
          "value": "subtext",
          "label": "Subtext"
        }
      ],
      "default": "text"
    }
  ],
  "presets": [
    {
      "name": "Custom Subheading",
      "category": "Basic"
    }
  ]
}
{% endschema %}

<style>
@font-face {
  font-family: 'pp-editorial';
  src: url('{{ "PPEditorialNew-RegularItalic.woff2" | asset_url }}') format('woff2');
}

/* Force Instrument Sans everywhere */
.text-block,
.text-block *,
p,
p * {
  font-family: 'Instrument Sans', sans-serif !important;
  font-weight: 500 !important;
}

/* Override highlighted text */
.sonu-highlight {
  font-family: 'pp-editorial' !important;
  font-style: italic;
  font-weight: 400 !important;
}
</style>